---
/**
 * Índice de LUGARES (`/lugares`, `/en/places`, `/fr/lieux`).
 *
 * Es la puerta de entrada a las ~300 fichas, que hasta el 13-jul-2026 eran
 * páginas HUÉRFANAS: solo el sitemap las conocía y ninguna página las
 * enlazaba, así que Google apenas las indexaba (248 de ~500 URLs).
 * Enlazado desde el pie → alcanzable desde cualquier página del sitio.
 *
 * Estático puro (sin JS de cliente, CLAUDE.md §3.5).
 */
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import { useTranslations, placeTypePlural } from "../i18n/ui";
import { SITE, type Locale } from "../config/site";
import { placeUrl, homePath, placesIndexPath } from "../i18n/utils";
import { abs, breadcrumbSchema } from "../lib/schema";
import { publishedPlaces, groupByType } from "../lib/places";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}
const { locale, alternates } = Astro.props;
const t = useTranslations(locale);

const places = await publishedPlaces(locale);
const groups = groupByType(places);

const canonical = abs(placesIndexPath(locale));
const breadcrumb = breadcrumbSchema([
  { name: SITE.name, url: abs(homePath(locale)) },
  { name: t("places.title"), url: canonical },
]);

// ItemList: ayuda a Google a descubrir las fichas desde esta misma página.
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: t("places.title"),
  numberOfItems: places.length,
  itemListElement: places.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.data.name,
    url: abs(placeUrl(locale, p.id)),
  })),
};
---

<BaseLayout
  title={t("places.title")}
  description={t("places.description")}
  locale={locale}
  alternates={alternates}
>
  <div class="mx-auto max-w-6xl px-5 pb-8 pt-12 sm:px-8 sm:pt-16">
    <header class="max-w-prosa">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
        {SITE.name}
      </p>
      <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">
        {t("places.title")}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-piedra-suave">
        {t("places.intro")}
      </p>
    </header>

    {
      groups.map((g) => (
        <section class="mt-14">
          <h2 class="flex items-baseline gap-3 border-b border-niebla pb-3 font-display text-2xl text-tinta">
            {placeTypePlural(g.type, locale)}
            <span class="text-sm font-normal text-piedra-suave">{g.places.length}</span>
          </h2>
          <ul class="mt-6 grid gap-x-8 gap-y-4 sm:grid-cols-2 lg:grid-cols-3">
            {g.places.map((p) => (
              <li>
                <a
                  href={placeUrl(locale, p.id)}
                  class="group block border-b border-transparent pb-1 transition-colors hover:border-terracota"
                >
                  <span class="text-[15px] font-medium text-piedra transition-colors group-hover:text-terracota">
                    {p.data.name}
                  </span>
                  <span class="mt-0.5 block text-xs text-piedra-suave">{p.data.area}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <JsonLd schema={[breadcrumb, itemList]} />
</BaseLayout>
