---
// Plantilla de lugar (cala, restaurante, monumento…). Datos estructurados.
import { type CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import { useTranslations, placeTypeLabel } from "../i18n/ui";
import { SITE, type Locale } from "../config/site";
import { placeUrl, homePath, placesIndexPath } from "../i18n/utils";
import { publishedPlaces, relatedPlaces } from "../lib/places";
import { abs, placeSchema, breadcrumbSchema } from "../lib/schema";
import { srcset } from "../lib/img";
import { menorcaBusUrl } from "../lib/links";
import { googleRatings, fmtScore, fmtReviews } from "../data/google-ratings";
import MenorcaBusPromo from "../components/MenorcaBusPromo.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";

interface Props {
  entry: CollectionEntry<"lugares">;
  alternates?: Partial<Record<Locale, string>>;
}
const { entry, alternates } = Astro.props;
const { data } = entry;
const locale = data.lang as Locale;
const t = useTranslations(locale);
// Cuerpo editorial opcional: si está, la ficha se renderiza como ARTÍCULO.
const ed = data.editorial;
// Valoración de Google (solo locales de la noche con dato verificado; ver google-ratings.ts).
const rating = googleRatings[data.translationKey];

const pi = data.practicalInfo;

// ── Datos del PLANIFICADOR en la ficha (KAN-54) ──────────────────────────────
// Las fichas sembradas para el motor traen datos verificados (acceso, esfuerzo,
// temporada, reserva…) que antes no se mostraban: la página quedaba en 2 líneas.
// Se humanizan los enums y se funden en la misma caja de "Información práctica".
const pl = data.planner;
const L = locale as "es" | "en" | "fr";
const CAR_ACCESS: Record<string, Record<"es" | "en" | "fr", string>> = {
  "coche-directo": { es: "En coche hasta el lugar", en: "Drive-up by car", fr: "Accès direct en voiture" },
  "coche-mas-caminata": { es: "Coche + caminata", en: "Car + a walk", fr: "Voiture + marche" },
  "solo-bus-lanzadera": { es: "Solo bus lanzadera en verano", en: "Summer shuttle bus only", fr: "Navette estivale uniquement" },
  "sin-coche-ok": { es: "Fácil sin coche", en: "Easy without a car", fr: "Facile sans voiture" },
};
const EFFORT: Record<string, Record<"es" | "en" | "fr", string>> = {
  A1: { es: "Accesible, con baño asistido en temporada", en: "Accessible, assisted bathing in season", fr: "Accessible, baignade assistée en saison" },
  A2: { es: "Fácil: apto para carrito y mayores", en: "Easy: stroller-friendly", fr: "Facile : poussette ok" },
  B: { es: "Moderado: tramo a pie o escaleras", en: "Moderate: a short walk or steps", fr: "Modéré : marche courte ou escaliers" },
  C: { es: "Exigente: sendero (15-40 min)", en: "Demanding: a 15-40 min trail", fr: "Exigeant : sentier (15-40 min)" },
  D: { es: "Duro: caminata larga sin servicios", en: "Tough: a long hike, no services", fr: "Difficile : longue marche, sans services" },
};
const fmtDur = (min: number) => {
  const h = Math.floor(min / 60);
  const m = min % 60;
  if (!h) return `~${m} min`;
  return m ? `~${h} h ${m} min` : `~${h} h`;
};
const busNote = pl?.busServed ? { es: " · con bus en temporada", en: " · seasonal bus service", fr: " · bus en saison" }[L] : "";

const rows: { label: string; value?: string }[] = [
  { label: t("place.access"), value: pi?.acceso ?? (pl?.carAccess ? `${CAR_ACCESS[pl.carAccess]?.[L] ?? pl.carAccess}${busNote}` : undefined) },
  { label: t("place.parking"), value: pi?.aparcamiento },
  { label: t("place.services"), value: pi?.servicios },
  { label: t("place.besttime"), value: pi?.mejorEpoca },
  { label: t("place.hours"), value: pi?.horario ?? pl?.seasonalHours },
  { label: t("place.effort"), value: pl?.effortLevel ? (pl.effortNote ?? EFFORT[pl.effortLevel]?.[L]) : undefined },
  { label: t("place.duration"), value: pl?.durationMin ? fmtDur(pl.durationMin) : undefined },
  { label: t("place.reserve"), value: pl?.needsReservation ? t("place.reserve.yes") : undefined },
].filter((r) => r.value);

// Aviso de cierre estival al coche (Macarella, Favàritx…): va aparte, destacado.
const shuttle = pl?.carAccessClosedSummer ? pl.shuttleInfo : undefined;
// Página del planificador por idioma (FR aún no tiene: KAN-24).
const plannerHref = L === "es" ? "/planificador" : L === "en" ? "/en/trip-planner" : null;

const mapUrl = `https://www.google.com/maps/search/?api=1&query=${data.coordinates.lat},${data.coordinates.lng}`;
const officialUrl = data.website ?? pl?.officialUrl;

// ── Malla interna: "Cerca de aquí" (13-jul-2026) ─────────────────────────────
// Las fichas eran CALLEJONES SIN SALIDA: no enlazaban a ninguna otra ficha, y
// ninguna página del sitio las enlazaba a ellas. Google apenas las indexaba
// (248 de ~500 URLs). Estos enlaces + el índice /lugares les dan camino de
// rastreo y autoridad interna. Ver lib/places.ts.
const nearby = relatedPlaces(entry, await publishedPlaces(locale), 6);

const canonical = abs(placeUrl(locale, entry.id));
const placeLd = {
  ...placeSchema({
    name: data.name,
    description: data.description,
    url: canonical,
    type: data.type,
    area: data.area,
    lat: data.coordinates.lat,
    lng: data.coordinates.lng,
    priceRange: data.priceRange,
    website: data.website,
    images: data.images,
  }),
  ...(rating
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: rating.score,
          reviewCount: rating.reviews,
          bestRating: 5,
          worstRating: 1,
        },
      }
    : {}),
};
const breadcrumb = breadcrumbSchema([
  { name: SITE.name, url: abs(homePath(locale)) },
  { name: data.name, url: canonical },
]);
---

<BaseLayout title={data.name} description={data.seo?.description ?? data.description} locale={locale} alternates={alternates}>
  <article class="mx-auto max-w-prosa px-5 pb-8 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
      {placeTypeLabel(data.type, locale)} · {data.area}
      {data.priceRange && <span class="ml-1 text-piedra-suave">· {data.priceRange}</span>}
    </p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">{data.name}</h1>
    <p class="mt-5 text-lg leading-relaxed text-piedra-suave">{ed?.lead ?? data.description}</p>

    {
      rating && (
        <p class="mt-3 flex flex-wrap items-center gap-x-1.5 text-sm text-piedra-suave">
          <span aria-hidden="true" class="text-oro-vivo">★</span>
          <span class="font-semibold text-tinta">{fmtScore(rating.score, locale)}</span>
          <span>
            · {fmtReviews(rating.reviews, locale)} {locale === "es" ? "reseñas en Google" : locale === "fr" ? "avis Google" : "Google reviews"}
          </span>
        </p>
      )
    }

    {
      ed && ed.bestFor.length > 0 && (
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-oro">{t("place.bestfor")}</span>
          {ed.bestFor.map((b) => (
            <span class="rounded-full border border-niebla bg-lino px-3 py-1 text-xs text-piedra-suave">{b}</span>
          ))}
        </div>
      )
    }

    {
      data.images && data.images.length > 0 && (
        <figure class="mt-8">
          <div class="aspect-[3/2] overflow-hidden rounded-xl">
            <img
              src={data.images[0]}
              srcset={srcset(data.images[0])}
              sizes="(min-width: 700px) 672px, 100vw"
              alt={data.imageAlt ?? data.name}
              width="1500"
              height="1000"
              class="h-full w-full object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          {data.imageCredit && (
            <figcaption class="mt-2 text-xs text-piedra-suave">
              {data.lang === "es" ? "Foto" : "Photo"}: {data.imageCredit}
            </figcaption>
          )}
        </figure>
      )
    }

    {/* Cuerpo de la ficha-artículo: secciones con criterio (.article-body =
        misma prosa que los artículos: h2, párrafos, enlaces del sistema). */}
    {
      ed && (
        <div class="article-body mt-10 [&>h2:first-child]:mt-0">
          {ed.sections.map((s) => (
            <Fragment>
              <h2>{s.heading}</h2>
              {s.body.map((p) => (
                <p>{p}</p>
              ))}
            </Fragment>
          ))}
        </div>
      )
    }

    {/* "Qué ver y hacer": los highlights verificados del planificador (solo si
        la ficha no es artículo — el cuerpo editorial ya cuenta esa historia). */}
    {
      !ed && pl?.highlights && pl.highlights.length > 0 && (
        <section class="mt-10 rounded-xl border border-niebla bg-arena/30 p-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">{t("place.what")}</h2>
          <ul class="mt-4 space-y-2.5 text-sm text-piedra">
            {pl.highlights.map((h) => (
              <li class="flex gap-2.5">
                <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-oro-vivo" />
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* "Bueno saber": apuntes prácticos verificados, en breve. */}
    {
      ed && ed.goodToKnow.length > 0 && (
        <section class="mt-10 rounded-xl border border-niebla bg-arena/30 p-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">{t("place.goodtoknow")}</h2>
          <ul class="mt-4 space-y-2.5 text-sm text-piedra">
            {ed.goodToKnow.map((g) => (
              <li class="flex gap-2.5">
                <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-oro-vivo" />
                <span>{g}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* Gesto-firma de movilidad (monetización): te llevamos con chófer →
        Menorca Bus (negocio propio; rel=sponsored técnico). Solo si transfer. */}
    {
      ed?.transfer && (
        <aside class="mt-10 overflow-hidden rounded-2xl bg-arcilla p-7 text-lino sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-champan">{t("place.transfer.eyebrow")}</p>
          <p class="mt-3 font-display text-2xl leading-snug text-crema">{t("place.transfer.title")}</p>
          <p class="mt-3 max-w-prosa text-sm leading-relaxed text-lino/85">{ed.transferText ?? t("place.transfer.text")}</p>
          <a
            href={menorcaBusUrl("noche", entry.id)}
            target="_blank"
            rel="sponsored noopener"
            data-umami-event="cta-menorcabus-noche"
            class="mt-5 inline-block rounded-md bg-crema px-5 py-2.5 text-sm font-semibold text-arcilla transition-colors hover:bg-lino"
          >
            {t("place.transfer.cta")} ↗
          </a>
          <MenorcaBusPromo locale={locale} tone="dark" class="mt-4" />
        </aside>
      )
    }

    {
      rows.length > 0 && (
        <section class="mt-10 rounded-xl border border-niebla bg-arena/30 p-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">
            {t("place.practical")}
          </h2>
          <dl class="mt-4 grid gap-x-6 gap-y-3 sm:grid-cols-2">
            {rows.map((r) => (
              <div>
                <dt class="text-xs uppercase tracking-wide text-piedra-suave">{r.label}</dt>
                <dd class="mt-0.5 text-sm text-piedra">{r.value}</dd>
              </div>
            ))}
          </dl>
          {shuttle && (
            <p class="mt-4 rounded-lg border border-terracota/40 bg-lino px-4 py-3 text-sm text-arcilla">
              🚌 {shuttle}
            </p>
          )}
          {pl?.lastVerified && (
            <p class="mt-4 border-t border-niebla pt-3 text-xs text-piedra-suave">
              {t("place.verified")} <time datetime={pl.lastVerified}>{pl.lastVerified}</time> — {t("place.verified.note")}.
            </p>
          )}
        </section>
      )
    }

    {/* Encájalo en tu viaje → planificador (malla interna; FR aún sin planner). */}
    {
      pl && plannerHref && (
        <aside class="mt-10 rounded-xl border border-oro-vivo/40 bg-crema/40 p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-oro">{t("place.planit.title")}</p>
          <p class="mt-2 text-sm leading-relaxed text-piedra">{t("place.planit.text")}</p>
          <a
            href={plannerHref}
            data-umami-event="place-to-planner"
            class="mt-4 inline-block rounded-md bg-arcilla px-5 py-2.5 text-sm font-semibold text-lino transition-colors hover:bg-tinta"
          >
            {t("place.planit.cta")} →
          </a>
        </aside>
      )
    }

    <p class="mt-8">
      <a
        href={mapUrl}
        rel="noopener"
        target="_blank"
        class="inline-block border-b border-terracota pb-0.5 text-sm font-medium text-arcilla hover:text-terracota"
      >
        {t("place.viewmap")} →
      </a>
      {
        officialUrl && (
          <a
            href={officialUrl}
            rel="noopener"
            target="_blank"
            class="ml-6 inline-block border-b border-terracota pb-0.5 text-sm font-medium text-arcilla hover:text-terracota"
          >
            {t("place.official")} →
          </a>
        )
      }
    </p>
  </article>

  {/* "Cerca de aquí": malla de enlaces entre fichas (misma zona, si no mismo
      tipo) + salida al índice. Es lo que da a Google un camino para rastrear
      las ~300 fichas, que antes eran huérfanas. Ver lib/places.ts. */}
  {
    nearby.length > 0 && (
      <section class="mx-auto max-w-prosa px-5 sm:px-8">
        <h2 class="border-t border-niebla pt-8 font-display text-2xl text-tinta">
          {t("place.nearby")}
        </h2>
        <ul class="mt-5 grid gap-x-8 gap-y-4 sm:grid-cols-2">
          {nearby.map((p) => (
            <li>
              <a
                href={placeUrl(locale, p.id)}
                class="group block border-b border-transparent pb-1 transition-colors hover:border-terracota"
              >
                <span class="text-[15px] font-medium text-piedra transition-colors group-hover:text-terracota">
                  {p.data.name}
                </span>
                <span class="mt-0.5 block text-xs text-piedra-suave">
                  {placeTypeLabel(p.data.type, locale)} · {p.data.area}
                </span>
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-6">
          <a
            href={placesIndexPath(locale)}
            class="inline-block border-b border-terracota pb-0.5 text-sm font-medium text-arcilla hover:text-terracota"
          >
            {t("place.nearby.all")} →
          </a>
        </p>
      </section>
    )
  }

  {/* Captación al pie de la ficha de lugar: páginas de entrada de tráfico
      orgánico/IA que no deben ser un callejón sin salida sin invitación a la Society. */}
  <NewsletterSignup variant="inline" />

  <JsonLd schema={[placeLd, breadcrumb]} />
</BaseLayout>
