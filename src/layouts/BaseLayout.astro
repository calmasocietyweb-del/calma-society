---
/**
 * Layout base — esqueleto común a todas las páginas.
 * Incluye el sistema de diseño (fuentes + tokens), SEO, datos estructurados
 * globales (Organization + WebSite), cabecera y pie.
 */
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "../styles/global.css";

import { SITE, getLocaleConfig, type Locale } from "../config/site";
import { currentLocale } from "../i18n/utils";
import { useTranslations } from "../i18n/ui";
import { organizationSchema, websiteSchema } from "../lib/schema";
import Seo from "../components/Seo.astro";
import JsonLd from "../components/JsonLd.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  /** URLs equivalentes por idioma (para selector + hreflang). */
  alternates?: Partial<Record<Locale, string>>;
  type?: "website" | "article";
  image?: string;
  imageAlt?: string;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
}

const {
  title,
  description = SITE.description,
  alternates,
  type = "website",
  image,
  imageAlt,
  publishedTime,
  modifiedTime,
  authorName,
} = Astro.props;

const locale = Astro.props.locale ?? currentLocale(Astro.url.pathname);
const localeConfig = getLocaleConfig(locale);
const t = useTranslations(locale);
const rssHref = locale === "es" ? "/rss.xml" : "/en/rss.xml";
---

<!doctype html>
<html lang={localeConfig.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} — RSS`} href={rssHref} />

    <Seo
      title={title}
      description={description}
      locale={locale}
      type={type}
      image={image}
      imageAlt={imageAlt}
      alternates={alternates}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      authorName={authorName}
    />

    <meta name="theme-color" content="#143c49" />
    <meta name="generator" content={Astro.generator} />

    <JsonLd schema={[organizationSchema(), websiteSchema()]} />
  </head>
  <body class="flex min-h-screen flex-col bg-lino font-sans text-piedra antialiased">
    <a
      href="#contenido"
      class="sr-only rounded-md bg-mar px-4 py-2 text-lino focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      {t("a11y.skip")}
    </a>
    <Header alternates={alternates} />
    <main id="contenido" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
