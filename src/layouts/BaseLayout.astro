---
/**
 * Layout base — esqueleto común a todas las páginas.
 * Incluye el sistema de diseño (fuentes + tokens), SEO, datos estructurados
 * globales (Organization + WebSite), cabecera y pie.
 */
// Fraunces con eje ÓPTICO (opsz): el mismo tipo afina su contraste fino/grueso
// según el tamaño → titulares grandes con corte "display" elegante y texto
// pequeño legible. La itálica real (no oblicua sintética) firma las entradillas,
// citas y la tagline del masthead. Ambos registran la familia "Fraunces Variable".
import "@fontsource-variable/fraunces/opsz.css";
import "@fontsource-variable/fraunces/opsz-italic.css";
import "@fontsource-variable/inter";
import "../styles/global.css";

import { SITE, getLocaleConfig, type Locale } from "../config/site";
import { currentLocale } from "../i18n/utils";
import { useTranslations } from "../i18n/ui";
import { organizationSchema, websiteSchema } from "../lib/schema";
import { srcset } from "../lib/img";
import Seo from "../components/Seo.astro";
import JsonLd from "../components/JsonLd.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import NewsletterPopup from "../components/NewsletterPopup.astro";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  /** URLs equivalentes por idioma (para selector + hreflang). */
  alternates?: Partial<Record<Locale, string>>;
  type?: "website" | "article";
  image?: string;
  imageAlt?: string;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
  /** Excluir de buscadores (p. ej. páginas de "gracias"). */
  noindex?: boolean;
  /**
   * Imagen LCP a PRECARGAR (la foto del hero de la página, en /uploads/*.webp).
   * Emite un `<link rel="preload" as="image">` con su `srcset`/`sizes`, para que
   * el navegador descubra y descargue la imagen del hero ANTES de procesar el CSS
   * de fuentes (que es render-blocking). Es la palanca nº1 del LCP en móvil.
   * Pásala SOLO en páginas con hero a pantalla completa; debe coincidir con la
   * imagen y el `sizes` del componente <Hero>.
   */
  heroImage?: string;
  /** `sizes` de la imagen del hero (debe coincidir con el del <Hero>, por defecto "100vw"). */
  heroImageSizes?: string;
}

const {
  title,
  description = SITE.description,
  alternates,
  type = "website",
  image,
  imageAlt,
  publishedTime,
  modifiedTime,
  authorName,
  noindex = false,
  heroImage,
  heroImageSizes = "100vw",
} = Astro.props;

const locale = Astro.props.locale ?? currentLocale(Astro.url.pathname);
const localeConfig = getLocaleConfig(locale);
const t = useTranslations(locale);
const rssHref = locale === "es" ? "/rss.xml" : `/${locale}/rss.xml`;
---

<!doctype html>
<html lang={localeConfig.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      SITE.googleSiteVerification && (
        <meta name="google-site-verification" content={SITE.googleSiteVerification} />
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-96x96.png" sizes="96x96" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} — RSS`} href={rssHref} />

    {/* Preload de la imagen LCP del hero: el navegador la descarga ya, sin esperar
        al CSS de fuentes (render-blocking). Decisivo para el LCP en móvil. */}
    {
      heroImage && (
        <link
          rel="preload"
          as="image"
          href={heroImage}
          imagesrcset={srcset(heroImage)}
          imagesizes={heroImageSizes}
          fetchpriority="high"
        />
      )
    }

    <Seo
      title={title}
      description={description}
      locale={locale}
      type={type}
      image={image}
      imageAlt={imageAlt}
      alternates={alternates}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      authorName={authorName}
      noindex={noindex}
    />

    <meta name="theme-color" content="#73402d" />
    <meta name="generator" content={Astro.generator} />

    {/* Analítica Umami (sin cookies). Solo carga si está configurada en site.ts. */}
    {
      SITE.analytics.enabled && SITE.analytics.websiteId && (
        <script
          is:inline
          defer
          src={SITE.analytics.scriptUrl}
          data-website-id={SITE.analytics.websiteId}
        />
      )
    }

    <JsonLd schema={[organizationSchema(), websiteSchema()]} />

    {/* MailerLite Universal — el formulario embebido se conecta en NewsletterSignup.
        Definimos el stub `ml` y encolamos la cuenta YA (sin red), pero la descarga de
        universal.js se DIFIERE a cuando el navegador esté ocioso o el lector interactúe
        (scroll/toque/tecla). Así no compite con la imagen LCP en el primer pintado:
        el formulario va bajo el pliegue y el popup lo gestiona MailerLite tras el scroll,
        de modo que nunca hace falta en el primer render. */}
    {
      SITE.newsletter.enabled && SITE.newsletter.accountId && (
        <script is:inline define:vars={{ mlAccount: SITE.newsletter.accountId }}>
          (function (w, d) {
            w.ml =
              w.ml ||
              function () {
                (w.ml.q = w.ml.q || []).push(arguments);
              };
            w.ml("account", mlAccount);

            var loaded = false;
            var events = ["scroll", "pointerdown", "keydown", "touchstart"];
            function load() {
              if (loaded) return;
              loaded = true;
              events.forEach(function (ev) {
                w.removeEventListener(ev, load);
              });
              var s = d.createElement("script");
              s.async = 1;
              s.src = "https://assets.mailerlite.com/js/universal.js";
              var n = d.getElementsByTagName("script")[0];
              n.parentNode.insertBefore(s, n);
            }
            events.forEach(function (ev) {
              w.addEventListener(ev, load, { passive: true });
            });
            if ("requestIdleCallback" in w) w.requestIdleCallback(load, { timeout: 2500 });
            else w.setTimeout(load, 2500);
          })(window, document);
        </script>
      )
    }
  </head>
  <body class="flex min-h-screen flex-col bg-lino font-sans text-piedra antialiased">
    <a
      href="#contenido"
      class="sr-only rounded-md bg-arcilla px-4 py-2 text-lino focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      {t("a11y.skip")}
    </a>
    <Header alternates={alternates} />
    <main id="contenido" class="flex-1">
      <slot />
    </main>
    <Footer />
    <NewsletterPopup />
  </body>
</html>
