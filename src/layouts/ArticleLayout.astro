---
// Plantilla de artículo. El cuerpo (MDX) se inyecta por <slot/>.
import { type CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import ArticleCard from "../components/ArticleCard.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import { getSection } from "../config/sections";
import { SITE, type Locale } from "../config/site";
import { useTranslations } from "../i18n/ui";
import { formatDate, placeUrl, articleUrl, authorUrl, homePath } from "../i18n/utils";
import { abs, articleSchema, breadcrumbSchema } from "../lib/schema";
import { getRelatedArticles } from "../lib/content";
import { srcset } from "../lib/img";

interface Props {
  entry: CollectionEntry<"articulos">;
  author: CollectionEntry<"autores"> | null;
  relatedPlaces?: CollectionEntry<"lugares">[];
  alternates?: Partial<Record<Locale, string>>;
}

const { entry, author, relatedPlaces = [], alternates } = Astro.props;
const { data } = entry;
const locale = data.lang as Locale;
const t = useTranslations(locale);
const section = getSection(data.section);

const canonical = abs(articleUrl(locale, entry.id));
const articleLd = articleSchema({
  title: data.title,
  description: data.excerpt,
  url: canonical,
  locale,
  datePublished: data.publishDate,
  dateModified: data.updatedDate,
  authorName: author?.data.name[locale],
  authorUrl: author ? abs(authorUrl(locale, author.id)) : undefined,
  image: data.heroImage ? abs(data.seo?.ogImage ?? data.heroImage) : undefined,
});

// Artículos relacionados (misma sección + tags) para "Sigue leyendo".
const related = await getRelatedArticles(locale, entry.id, data.section, data.tags, 3);
const sectionLabel = (key: string) => getSection(key)?.label[locale];
const breadcrumb = breadcrumbSchema([
  { name: SITE.name, url: abs(homePath(locale)) },
  ...(section ? [{ name: section.label[locale], url: abs(section.href[locale]) }] : []),
  { name: data.title, url: canonical },
]);
---

<BaseLayout
  title={data.seo?.title ?? data.title}
  description={data.seo?.description ?? data.excerpt}
  locale={locale}
  alternates={alternates}
  type="article"
  image={data.seo?.ogImage ?? data.heroImage}
  imageAlt={data.heroImageAlt}
  publishedTime={data.publishDate.toISOString()}
  modifiedTime={data.updatedDate?.toISOString()}
  authorName={author?.data.name[locale]}
>
  <article class="mx-auto max-w-prosa px-5 pb-8 pt-12 sm:px-8 sm:pt-16">
    <header>
      <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-widest">
        {
          section && (
            <a href={section.href[locale]} class="text-oro hover:text-terracota">
              {section.label[locale]}
            </a>
          )
        }
        {
          data.sponsored && (
            <span class="rounded-full bg-arena px-2 py-0.5 text-piedra-suave">
              {t("article.sponsored")}
            </span>
          )
        }
      </div>

      <h1 class="mt-4 font-display text-4xl leading-tight text-tinta sm:text-5xl">
        {data.title}
      </h1>

      <p class="mt-5 text-lg leading-relaxed text-piedra-suave">{data.excerpt}</p>

      <div class="mt-6 flex flex-wrap items-center gap-x-2 gap-y-1 border-y border-niebla py-4 text-sm text-piedra-suave">
        {
          author && (
            <span>
              {t("article.by")}{" "}
              <a href={authorUrl(locale, author.id)} class="font-medium text-piedra hover:text-terracota">
                {author.data.name[locale]}
              </a>
            </span>
          )
        }
        <span aria-hidden="true">·</span>
        <time datetime={data.publishDate.toISOString()}>{formatDate(data.publishDate, locale)}</time>
        {
          data.updatedDate && (
            <span class="text-piedra-suave">
              · {t("article.updated")} {formatDate(data.updatedDate, locale)}
            </span>
          )
        }
      </div>
    </header>

    {
      data.heroImage && (
        <figure class="mt-8">
          <div class="aspect-[3/2] overflow-hidden rounded-xl">
            <img
              src={data.heroImage}
              srcset={srcset(data.heroImage)}
              sizes="(min-width: 700px) 672px, 100vw"
              alt={data.heroImageAlt ?? data.title}
              width="1500"
              height="1000"
              class="h-full w-full object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          {data.heroImageCredit && (
            <figcaption class="mt-2 text-xs text-piedra-suave">
              {locale === "es" ? "Foto" : "Photo"}: {data.heroImageCredit}
            </figcaption>
          )}
        </figure>
      )
    }

    <div class="article-body mt-10">
      <slot />
    </div>

    {
      relatedPlaces.length > 0 && (
        <aside class="mt-14 border-t border-niebla pt-8">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">
            {t("article.related")}
          </h2>
          <ul class="mt-4 space-y-2">
            {relatedPlaces.map((p) => (
              <li>
                <a href={placeUrl(locale, p.id)} class="text-arcilla hover:text-terracota">
                  {p.data.name}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>

  {
    related.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl border-t border-niebla px-5 pt-10 sm:px-8 sm:mt-20">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">
          {t("article.keepreading")}
        </p>
        <div class="mt-8 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((a) => (
            <ArticleCard
              kicker={sectionLabel(a.data.section)}
              title={a.data.title}
              excerpt={a.data.excerpt}
              href={articleUrl(locale, a.id)}
              image={a.data.heroImage}
              imageAlt={a.data.heroImageAlt}
            />
          ))}
        </div>
      </section>
    )
  }

  {/* Invitación a la Sociedad (captación = KPI nº1). Compacta, al cierre. */}
  <NewsletterSignup variant="inline" />

  <JsonLd schema={[articleLd, breadcrumb]} />
</BaseLayout>
