---
// Vista de autor: bio + artículos firmados (E-E-A-T). Dentro de BaseLayout.
import type { CollectionEntry } from "astro:content";
import ArticleCard from "./ArticleCard.astro";
import JsonLd from "./JsonLd.astro";
import { getArticles } from "../lib/content";
import { useTranslations } from "../i18n/ui";
import { articleUrl, authorUrl, homePath } from "../i18n/utils";
import { SITE, type Locale } from "../config/site";
import { abs, personSchema, breadcrumbSchema } from "../lib/schema";

interface Props {
  entry: CollectionEntry<"autores">;
  locale: Locale;
}
const { entry, locale } = Astro.props;
const t = useTranslations(locale);
const articles = (await getArticles(locale)).filter(
  (a) => a.data.author.id === entry.id,
);
const social = entry.data.social;

const canonical = abs(authorUrl(locale, entry.id));
const personLd = personSchema({
  name: entry.data.name,
  description: entry.data.bio[locale],
  url: canonical,
  sameAs: social ? Object.values(social).filter(Boolean) : undefined,
});
const breadcrumb = breadcrumbSchema([
  { name: SITE.name, url: abs(homePath(locale)) },
  { name: entry.data.name, url: canonical },
]);
---

<section class="mx-auto max-w-prosa px-5 pt-12 sm:px-8 sm:pt-16">
  <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
    {entry.data.role[locale]}
  </p>
  <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">{entry.data.name}</h1>
  <p class="mt-5 text-lg leading-relaxed text-piedra-suave">{entry.data.bio[locale]}</p>
  {
    social?.instagram && (
      <p class="mt-4">
        <a href={social.instagram} rel="me noopener" target="_blank" class="text-sm font-medium text-mar hover:text-mar-hondo">
          Instagram →
        </a>
      </p>
    )
  }
</section>

{
  articles.length > 0 && (
    <section class="mx-auto mt-16 max-w-6xl px-5 sm:px-8">
      <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
        {t("author.articlesby")} {entry.data.name}
      </h2>
      <div class="mt-8 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((a) => (
          <ArticleCard
            title={a.data.title}
            excerpt={a.data.excerpt}
            href={articleUrl(locale, a.id)}
            image={a.data.heroImage}
            imageAlt={a.data.heroImageAlt}
          />
        ))}
      </div>
    </section>
  )
}

<JsonLd schema={[personLd, breadcrumb]} />
