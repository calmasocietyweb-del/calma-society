---
// Tarjeta de artículo (presentacional) — "Galería de Lino": imagen en retrato,
// velada hacia la paleta, SIN marco ni esquina redondeada; un filete fino la
// separa del texto. Hover de luz lento, sin zoom.
import { srcset } from "../lib/img";
interface Props {
  kicker?: string;
  title: string;
  excerpt?: string;
  href: string;
  image?: string;
  imageAlt?: string;
  /** Proporción del marco de imagen (por defecto retrato editorial 4:5). */
  aspectClass?: string;
  /** `sizes` responsivo según el ancho de columna donde se coloque la tarjeta. */
  sizes?: string;
}
const {
  kicker,
  title,
  excerpt,
  href,
  image,
  imageAlt,
  aspectClass = "aspect-[4/5]",
  sizes = "(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 100vw",
} = Astro.props;
---

<article class="group relative flex flex-col">
  <div class={`relative ${aspectClass} w-full overflow-hidden bg-arena`}>
    {
      image && (
        <img
          src={image}
          srcset={srcset(image)}
          sizes={sizes}
          alt={imageAlt ?? ""}
          width="1600"
          height="2000"
          class="img-calma h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      )
    }
    {/* Velo cálido (unifica el stock) + aclarado de luz lento en hover. */}
    <span
      class="pointer-events-none absolute inset-0 bg-arcilla/8 mix-blend-multiply"
      aria-hidden="true"
    />
    <span
      class="pointer-events-none absolute inset-0 bg-lino/0 transition-colors duration-700 ease-out group-hover:bg-lino/8"
      aria-hidden="true"
    />
  </div>

  {
    kicker && (
      <p class="mt-4 border-t border-niebla/60 pt-3 text-xs font-semibold uppercase tracking-widest text-oro">
        {kicker}
      </p>
    )
  }

  <h3 class="mt-2 font-display text-xl leading-snug text-tinta">
    <a
      href={href}
      class="transition-colors after:absolute after:inset-0 group-hover:text-terracota"
    >
      {title}
    </a>
  </h3>

  {
    excerpt && (
      <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{excerpt}</p>
    )
  }
</article>
