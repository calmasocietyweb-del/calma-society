---
// Tarjeta de artículo (presentacional). Muestra la foto si la hay; si no, un
// degradado sobrio como marcador.
import { srcset } from "../lib/img";
interface Props {
  kicker?: string;
  title: string;
  excerpt?: string;
  href: string;
  image?: string;
  imageAlt?: string;
}
const { kicker, title, excerpt, href, image, imageAlt } = Astro.props;
---

<article class="group relative flex flex-col">
  <div
    class="aspect-[4/3] w-full overflow-hidden rounded-lg border border-niebla bg-gradient-to-br from-arena to-niebla"
  >
    {
      image && (
        <img
          src={image}
          srcset={srcset(image)}
          sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 100vw"
          alt={imageAlt ?? ""}
          width="1600"
          height="1200"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>

  {
    kicker && (
      <p class="mt-4 text-xs font-semibold uppercase tracking-widest text-oro">
        {kicker}
      </p>
    )
  }

  <h3 class="mt-2 font-display text-xl leading-snug text-tinta">
    <a
      href={href}
      class="transition-colors after:absolute after:inset-0 group-hover:text-terracota"
    >
      {title}
    </a>
  </h3>

  {
    excerpt && (
      <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{excerpt}</p>
    )
  }
</article>
