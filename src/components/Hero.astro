---
// Hero editorial reutilizable.
//  - Con `image`: hero a pantalla completa con foto de fondo y texto superpuesto.
//  - Sin `image`: hero de texto sobrio.
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, subtitle, image, imageAlt } = Astro.props;
---

{
  image ? (
    <section class="relative flex min-h-[70svh] items-center justify-center overflow-hidden">
      <img
        src={image}
        alt={imageAlt ?? ""}
        class="absolute inset-0 h-full w-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-tinta/45 via-tinta/25 to-tinta/65" />
      <div class="relative z-10 mx-auto max-w-3xl px-5 py-24 text-center">
        {eyebrow && (
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-lino/90">
            {eyebrow}
          </p>
        )}
        <h1 class="mt-5 font-display text-5xl leading-[1.05] text-lino drop-shadow-sm sm:text-6xl md:text-7xl">
          {title}
        </h1>
        {subtitle && (
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-lino/90">
            {subtitle}
          </p>
        )}
      </div>
    </section>
  ) : (
    <section class="mx-auto max-w-4xl px-5 pb-12 pt-20 text-center sm:px-8 sm:pt-28">
      {eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-oro">{eyebrow}</p>
      )}
      <h1 class="mt-5 font-display text-5xl leading-[1.05] text-tinta sm:text-6xl md:text-7xl">
        {title}
      </h1>
      {subtitle && (
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-piedra-suave">
          {subtitle}
        </p>
      )}
    </section>
  )
}
