---
// Hero editorial reutilizable.
//  - Con `image`: hero a pantalla completa, foto VELADA hacia la paleta cálida
//    (Galería de Lino) y texto anclado abajo-izquierda, como pie de portada.
//  - Sin `image`: hero de texto sobrio.
import { srcset, avifSrcset } from "../lib/img";
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  /**
   * Servir además la variante AVIF (más ligera) vía <picture>. Solo activar en
   * imágenes que tengan sus `.avif` generados (hoy el hero de la home). Mejora el LCP.
   */
  avif?: boolean;
}
const { eyebrow, title, subtitle, image, imageAlt, avif = false } = Astro.props;
---

{
  image ? (
    <section class="relative flex min-h-[80svh] items-end overflow-hidden">
      <picture>
        {avif && <source type="image/avif" srcset={avifSrcset(image)} sizes="100vw" />}
        <img
          src={image}
          srcset={srcset(image)}
          sizes="100vw"
          alt={imageAlt ?? ""}
          width="1600"
          height="1000"
          class="img-calma hero-zoom absolute inset-0 h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
      {/* Velo cálido: une el tono de la foto con la paleta (sin azul). */}
      <div
        class="pointer-events-none absolute inset-0 bg-arcilla/15 mix-blend-multiply"
        aria-hidden="true"
      />
      {/* Degradado de legibilidad anclado abajo (calibrado para AA sobre la foto
          turquesa del hero, medido con sharp: lino > 4.5:1 en titular y subtítulo).
          La mitad superior del hero conserva el turquesa; el texto se asienta sobre
          el tramo oscuro de abajo. */}
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-tinta/75 via-tinta/45 to-transparent"
        aria-hidden="true"
      />
      <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-12 text-left sm:px-8 sm:pb-16">
        {eyebrow && (
          <p class="hero-enter hero-enter-1 mb-4 text-[0.7rem] font-semibold uppercase tracking-[0.34em] text-champan">
            {eyebrow}
          </p>
        )}
        {/* Filete dorado decorativo que se dibuja al cargar (gesto-firma de la marca). */}
        <span class="hero-filete mb-6 block h-px w-12 bg-champan/70" aria-hidden="true"></span>
        <h1 class="hero-enter hero-enter-2 display-xl hero-title-shadow max-w-3xl text-lino">
          {title}
        </h1>
        {subtitle && (
          <p
            class="hero-enter hero-enter-3 mt-5 max-w-xl font-display text-xl italic leading-relaxed text-lino"
            style="font-variation-settings:'opsz' 30,'wght' 380"
          >
            {subtitle}
          </p>
        )}
      </div>
    </section>
  ) : (
    <section class="mx-auto max-w-4xl px-5 pb-12 pt-20 text-center sm:px-8 sm:pt-28">
      {eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-oro">{eyebrow}</p>
      )}
      <h1 class="display-xl mt-5 text-tinta">
        {title}
      </h1>
      {subtitle && (
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-piedra-suave">
          {subtitle}
        </p>
      )}
    </section>
  )
}
