---
// SEO centralizado: título, descripción, canonical, Open Graph, Twitter y
// hreflang entre idiomas. Lo usa BaseLayout en cada página.
import { SITE, getLocaleConfig, type Locale } from "../config/site";
import { abs } from "../lib/schema";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  type?: "website" | "article";
  image?: string;
  imageAlt?: string;
  alternates?: Partial<Record<Locale, string>>;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
}
const {
  title,
  description,
  locale,
  type = "website",
  image,
  imageAlt,
  alternates,
  publishedTime,
  modifiedTime,
  authorName,
} = Astro.props;

const fullTitle = `${title} · ${SITE.name}`;
const canonical = Astro.url.href;
const ogLocale = getLocaleConfig(locale).htmlLang.replace("-", "_");
// Imagen por defecto al compartir (Open Graph/Twitter): la portada de marca.
const DEFAULT_OG_IMAGE = "/og-default.png";
const imageUrl = image
  ? image.startsWith("http")
    ? image
    : abs(image)
  : abs(DEFAULT_OG_IMAGE);
const imageAltText = imageAlt ?? `${SITE.name} · ${SITE.edition}`;

const hreflangs = alternates
  ? SITE.locales
      .filter((l) => alternates[l.code])
      .map((l) => ({ lang: l.code, href: abs(alternates[l.code]!) }))
  : [];
const xDefault = alternates?.[SITE.defaultLocale]
  ? abs(alternates[SITE.defaultLocale]!)
  : undefined;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{hreflangs.map((h) => <link rel="alternate" hreflang={h.lang} href={h.href} />)}
{xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:url" content={canonical} />
{imageUrl && <meta property="og:image" content={imageUrl} />}
{imageUrl && <meta property="og:image:alt" content={imageAltText} />}
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === "article" && authorName && (
  <meta property="article:author" content={authorName} />
)}

<meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{imageUrl && <meta name="twitter:image" content={imageUrl} />}
