  zone: zoneOf(x.lng),
  lat: x.lat,
  lng: x.lng,
  area: locale === "es" ? x.areaEs : locale === "fr" ? x.areaFr : x.areaEn,
  description: locale === "es" ? x.descEs : locale === "fr" ? x.descFr : x.descEn,
  website: x.website,
  href: x.toArticle ? articleUrl(locale, sunsetArticle) : undefined,
  note: locale === "es" ? x.noteEs : locale === "fr" ? x.noteFr : x.noteEn,
  schemaType: x.schemaType,
  rating: googleRatings[x.id],
}));

// Lista ordenada por categoría (atardecer, beach, coctelería, club); el sort es
// estable, así que dentro de cada grupo van primero los de ficha y luego los nuevos.
const catIdx = (c: Cat) => CAT_ORDER.indexOf(c);
const venues: V[] = [...fromFichas, ...fromExtra].sort((a, b) => catIdx(a.cat) - catIdx(b.cat));
/** Las categorías de un sitio, como lista separada por espacios: es lo que leen el
 *  filtro (con `~=`) y los contadores. Casi todos tienen una; El Toro, dos. */
const catsDe = (v: V) => [v.cat, v.cat2].filter(Boolean).join(" ");
const esDeCat = (v: V, cat: Cat) => v.cat === cat || v.cat2 === cat;
const catCount = (cat: Cat) => venues.filter((v) => esDeCat(v, cat)).length;
const zoneCount = (z: Zone) => venues.filter((v) => v.zone === z).length;

// ── Orden de la lista 100% CSS (sin JS) ──
// "Recomendado" agrupa por categoría (cabecera + locales); "Mejor valorados"
// ordena por nota de Google desc (los puntos naturales sin nota van al final).
// Cada tarjeta lleva su `--rec` y `--rate`; un radio decide cuál se aplica.
const RATED = [...venues].sort((a, b) => {
  const ra = a.rating?.score ?? -1;
  const rb = b.rating?.score ?? -1;
  if (rb !== ra) return rb - ra;
  return (b.rating?.reviews ?? -1) - (a.rating?.reviews ?? -1);
});
const rateRank = new Map(RATED.map((v, i) => [v.id, i + 1]));
const recCounter: Partial<Record<Cat, number>> = {};
const recOrder = new Map<string, number>();
for (const v of venues) {
  recCounter[v.cat] = (recCounter[v.cat] ?? 0) + 1;
  recOrder.set(v.id, catIdx(v.cat) * 1000 + (recCounter[v.cat] ?? 0));
}

// Combinaciones tipo×zona SIN resultados (p. ej. "Club" + "Centro"): se calculan
// en build y se emite el CSS exacto para mostrar el mensaje "sin resultados" solo
// en esos estados de los radios. 100% CSS, sin JS de cliente.
const emptyCombos: { cat: Cat; zone: Zone }[] = [];
for (const cat of CAT_ORDER) {
  for (const z of ZONES) {
    if (!venues.some((v) => esDeCat(v, cat) && v.zone === z.key)) emptyCombos.push({ cat, zone: z.key });
  }
}
const emptyCss = emptyCombos
  .map(
    (c) =>
      `.nightmap-filterable:has(#nf-${c.cat}:checked):has(#nf-zona-${c.zone}:checked) .nightmap-noresults{display:block}`,
  )
  .join("");

// ── Proyección equirectangular (idéntica a ParteCalmaMap): cos(lat) corrige el
// meridiano y la escala es uniforme → la isla mantiene su proporción real. ──
const RING = outline.ring as [number, number][];
const LAT_REF = (outline.bbox.latMin + outline.bbox.latMax) / 2;
const KX = Math.cos((LAT_REF * Math.PI) / 180);
const xsRaw = RING.map((p) => p[0] * KX);
const ysRaw = RING.map((p) => p[1]);
const minX = Math.min(...xsRaw);
const maxX = Math.max(...xsRaw);
const minY = Math.min(...ysRaw);
const maxY = Math.max(...ysRaw);
const spanX = maxX - minX;
const spanY = maxY - minY;
const DRAW_W = 860;
const PAD_TOP = 96;
const PAD_BOTTOM = 72;
const SCALE = DRAW_W / spanX;
const DRAW_H = spanY * SCALE;
const VIEW_W = 1000;
const VIEW_H = Math.round(PAD_TOP + DRAW_H + PAD_BOTTOM);
const offX = (VIEW_W - DRAW_W) / 2;
const offY = PAD_TOP;
const baseY = offY + DRAW_H;
const project = (lat: number, lng: number) => ({
  x: offX + (lng * KX - minX) * SCALE,
  y: offY + (maxY - lat) * SCALE,
});

const islandPath =
  "M " +
  RING.map((p, i) => {
    const { x, y } = project(p[1], p[0]);
    return (i ? "L " : "") + x.toFixed(1) + " " + y.toFixed(1);
  }).join(" ") +
  " Z";

// Pueblos de referencia para orientarse (faint, decorativos).
const TOWNS = [
  { es: "Ciutadella", en: "Ciutadella", fr: "Ciutadella", lat: 40.0006, lng: 3.8377 },
  { es: "Ferreries", en: "Ferreries", fr: "Ferreries", lat: 39.9786, lng: 4.0103 },
  { es: "Es Mercadal", en: "Es Mercadal", fr: "Es Mercadal", lat: 39.9908, lng: 4.0922 },
  { es: "Alaior", en: "Alaior", fr: "Alaior", lat: 39.9357, lng: 4.1389 },
  { es: "Maó", en: "Mahón", fr: "Maó", lat: 39.8885, lng: 4.2658 },
  { es: "Sant Lluís", en: "Sant Lluís", fr: "Sant Lluís", lat: 39.8475, lng: 4.2561 },
].map((t) => ({ ...t, ...project(t.lat, t.lng) }));

// Posiciones de los marcadores + des-solape determinista: varios locales caen
// casi en el mismo punto (puerto de Maó: Contrabandu/Akelarre/Vida Una; puerto
// de Ciutadella: Jazzbah/Kopas). Un pequeño empuje mutuo los separa para que se
// vean los dos; la lista de abajo es la versión canónica si aún se rozan.
const pts = venues.map((v) => {
  const { x, y } = project(v.lat, v.lng);
  return { v, x, y };
});
const MIN_SEP = 31; // separación mínima entre marcadores (iconos grandes r≈13 + anillo)
for (let pass = 0; pass < 18; pass++) {
  for (let i = 0; i < pts.length; i++) {
    for (let j = 0; j < i; j++) {
      let dx = pts[i].x - pts[j].x;
      let dy = pts[i].y - pts[j].y;
      let d = Math.hypot(dx, dy);
      if (d < MIN_SEP) {
        if (d < 0.01) {
          // Coincidentes: separa en un ángulo determinista (sin Math.random).
          const a = i * 2.3999632;
          dx = Math.cos(a);
          dy = Math.sin(a);
          d = 1;
        }
        const push = (MIN_SEP - d) / 2;
        const ux = dx / d;
        const uy = dy / d;
        pts[i].x += ux * push;
        pts[i].y += uy * push;
        pts[j].x -= ux * push;
        pts[j].y -= uy * push;
      }
    }
  }
}

// Barra de escala (≈ px por km; 1° ≈ 110,57 km).
const pxPerKm = SCALE / 110.574;
const scaleLen = 10 * pxPerKm;
const scaleX = offX;
const scaleY = baseY + 30;

// Direcciones (cómo llegar por tu cuenta): deep-link generado SOLO con las
// coordenadas verificadas de la ficha. Sin inventar nada.
const mapsUrl = (lat: number, lng: number) =>
  `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;

// Slugs del clúster de chófer de lujo (artículos ya publicados), por idioma.
const CH = {
