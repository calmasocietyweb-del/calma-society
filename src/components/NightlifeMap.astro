---
/**
 * "El mapa de la noche" — mapa de los locales de ocio nocturno de Menorca
 * (atardeceres, beach clubs, coctelerías y clubs) sobre la silueta real de la
 * isla, con la lista accesible debajo y, en CADA local, el discurso de lujo de
 * "te llevamos con chófer" enlazado a Menorca Bus (negocio propio).
 *
 * Reutiliza la MISMA proyección equirectangular que ParteCalmaMap (contorno OSM
 * de src/data/menorca-outline.json). CERO JS de cliente: SVG + lista + filtro
 * 100% CSS (mismo patrón `:has()` que el parte de calas y la agenda). La lista
 * es la versión accesible y citable por IA; el color NUNCA va solo (lleva glifo
 * y texto al lado).
 *
 * Pensado para incrustarse DENTRO del cuerpo de un artículo (.article-body): por
 * eso NO usa h2/h3/ul/ol (evita heredar la prosa); los estilos propios y el
 * filtro viven en global.css bajo `.nightmap`.
 */
import outline from "../data/menorca-outline.json";
import { getPlaces } from "../lib/content";
import { placeUrl, articleUrl } from "../i18n/utils";
import { menorcaBusUrl, partnerUrl } from "../lib/links";
import { srcset } from "../lib/img";
import type { Locale } from "../config/site";
import { googleRatings, fmtScore, fmtReviews, GOOGLE_RATINGS_AS_OF, type GoogleRating } from "../data/google-ratings";
import JsonLd from "./JsonLd.astro";
import MenorcaBusPromo from "./MenorcaBusPromo.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const isEs = locale === "es";

// ── Selección editorial: qué locales entran y en qué categoría (glifo/color) ──
// El orden define el orden de la lista (agrupada por categoría).
type Cat = "atardecer" | "amanecer" | "beach" | "cocteleria" | "club";
const VENUES: { key: string; cat: Cat }[] = [
  { key: "cova-den-xoroi", cat: "atardecer" },
  { key: "coral-menorca", cat: "atardecer" },
  { key: "artrutx-sea-club", cat: "beach" },
  { key: "isabella-beach-club", cat: "beach" },
  { key: "purobeach-menorca", cat: "beach" },
  { key: "vida-una", cat: "cocteleria" },
  // Contrabandú, RETIRADO el 13-jul-2026: figura como «cerrado temporalmente» (ficha
  // actualizada hace días, en plena temporada) y no hay forma de confirmar que siga
  // abierto. No mandamos a nadie a una puerta cerrada. Su ficha pasa a draft; si
  // reabre, se vuelve a poner aquí.
  { key: "jigger", cat: "cocteleria" },
  { key: "bb-cocktail-bar", cat: "cocteleria" },
  { key: "jazzbah", cat: "club" },
  { key: "kopas-club", cat: "club" },
  { key: "akelarre", cat: "club" },
];

const CAT_ORDER: Cat[] = ["atardecer", "amanecer", "beach", "cocteleria", "club"];
// Por categoría: color/glifo, etiqueta y la NOTA DE APARCAMIENTO (honesta) que
// justifica el transfer. Son patrones reales (acantilados que se llenan al
// atardecer, puertos sin sitio de noche), no afirmaciones absolutas por local.
const CATS: Record<
  Cat,
  { color: string; es: string; en: string; fr: string; schema: string; parkEs: string; parkEn: string; parkFr: string }
> = {
  atardecer: {
    color: "#A8895C", es: "Atardecer", en: "Sunset", fr: "Coucher de soleil", schema: "BarOrPub",
    parkEs: "En los acantilados del atardecer aparcar se complica y se llena en verano.",
    parkEn: "Parking on the sunset cliffs is tricky and fills up in summer.",
    parkFr: "Sur les falaises du coucher de soleil, se garer devient compliqué et c'est complet en été.",
  },
  amanecer: {
    color: "#D9A05B", es: "Amanecer", en: "Sunrise", fr: "Lever de soleil", schema: "TouristAttraction",
    parkEs: "Plan de madrugada: madrugar y, mejor aún, no tener que conducir de vuelta.",
    parkEn: "An early-morning plan: get up early and, better still, not have to drive back.",
    parkFr: "Un plan de petit matin : se lever tôt et, mieux encore, ne pas avoir à conduire au retour.",
  },
  beach: {
    color: "#4F7A52", es: "Beach club", en: "Beach club", fr: "Beach club", schema: "BarOrPub",
    parkEs: "Aparcamiento limitado junto a la playa en temporada alta.",
    parkEn: "Limited parking by the beach in high season.",
    parkFr: "Stationnement limité au bord de la plage en haute saison.",
  },
  cocteleria: {
    color: "#B96A4B", es: "Coctelería", en: "Cocktail bar", fr: "Bar à cocktails", schema: "BarOrPub",
    parkEs: "En el puerto, aparcar de noche es difícil.",
    parkEn: "Parking by the harbour at night is hard.",
    parkFr: "Dans le port, se garer la nuit est difficile.",
  },
  club: {
    color: "#73402D", es: "Club / fiesta", en: "Club", fr: "Club / fête", schema: "NightClub",
    parkEs: "Zona de puerto, sin aparcamiento fácil de madrugada.",
    parkEn: "Harbour area, no easy parking in the small hours.",
    parkFr: "Zone portuaire, pas de stationnement facile au petit matin.",
  },
};
const catLabel = (cat: Cat) =>
  locale === "es" ? CATS[cat].es : locale === "fr" ? CATS[cat].fr : CATS[cat].en;
const catPark = (cat: Cat) =>
  locale === "es" ? CATS[cat].parkEs : locale === "fr" ? CATS[cat].parkFr : CATS[cat].parkEn;

// ── Zona (filtro extra): tres franjas por longitud, como mentalmente se divide
// la isla (extremo Ciutadella / centro / extremo Maó). Determinista, sin datos
// nuevos por local. ──
type Zone = "oeste" | "centro" | "este";
const ZONES: { key: Zone; es: string; en: string; fr: string }[] = [
  { key: "oeste", es: "Oeste · Ciutadella", en: "West · Ciutadella", fr: "Ouest · Ciutadella" },
  { key: "centro", es: "Centro", en: "Centre", fr: "Centre" },
  { key: "este", es: "Este · Maó", en: "East · Maó", fr: "Est · Maó" },
];
const zoneOf = (lng: number): Zone => (lng <= 3.92 ? "oeste" : lng >= 4.2 ? "este" : "centro");
const zoneLabel = (z: Zone) => {
  const zz = ZONES.find((x) => x.key === z)!;
  return locale === "es" ? zz.es : locale === "fr" ? zz.fr : zz.en;
};

// Glifo blanco centrado en (0,0), ~12 px, para distinguir la categoría sin
// depender del color (accesibilidad).
const GLYPH: Record<Cat, string> = {
  // Sol sobre el horizonte con flecha BAJANDO = atardecer (puesta).
  atardecer:
    '<path d="M-4 2.4 A4 4 0 0 1 4 2.4" fill="#fff"/><path d="M-6 2.4 H6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/><path d="M0 -5.6 V-2.4 M-1.7 -4.1 L0 -2.4 L1.7 -4.1" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  // Sol sobre el horizonte con flecha SUBIENDO = amanecer (salida).
  amanecer:
    '<path d="M-4 2.4 A4 4 0 0 1 4 2.4" fill="#fff"/><path d="M-6 2.4 H6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/><path d="M0 -5.6 V-2.4 M-1.7 -3.9 L0 -5.6 L1.7 -3.9" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  beach:
    '<path d="M-5.5 -1 Q-2.75 -4 0 -1 T5.5 -1 M-5.5 2.6 Q-2.75 -0.4 0 2.6 T5.5 2.6" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>',
  cocteleria:
    '<path d="M-4.2 -3.6 L4.2 -3.6 L0 0.6 Z" fill="#fff"/><path d="M0 0.6 V4.2 M-2.8 4.2 H2.8" stroke="#fff" stroke-width="1.3" stroke-linecap="round" fill="none"/>',
  club:
    '<path d="M-0.5 -5 L4 -3.5 V-1.6 L-0.5 -3.1 Z" fill="#fff"/><path d="M-0.5 -5 V3" stroke="#fff" stroke-width="1.4" stroke-linecap="round"/><ellipse cx="-2.4" cy="3.2" rx="2.3" ry="1.9" fill="#fff"/>',
};

// ── Carga de fichas (solo `published`): el cortafuegos de aprobación se respeta
// solo con que getPlaces ya filtra por status. Eolo/Marea (draft) no aparecen. ──
const places = await getPlaces(locale);
const byKey = new Map(places.map((p) => [p.data.translationKey, p]));

// Modelo unificado de "punto del mapa": vale para los que tienen ficha publicada
// (enlazan a su ficha) y para los puntos añadidos en línea (beach clubs y
// miradores de atardecer verificados; enlazan a la guía de atardeceres).
type V = {
  id: string;
  negocio: string; // slug SIN idioma: agrupa el clic saliente por negocio (KAN-78)
  name: string;
  cat: Cat;
  cat2?: Cat; // el sitio que es dos cosas a la vez (El Toro: amanecer y atardecer)
  zone: Zone;
  lat: number;
  lng: number;
  area: string;
  description: string;
  website?: string;
  href?: string;
  note?: string; // override de la nota de aparcamiento (si no, la de su categoría)
  schemaType: string;
  rating?: GoogleRating; // valoración de Google (solo negocios; ver google-ratings.ts)
};

// 1) Locales con ficha (los 12 originales). `monumento` → atracción turística.
const fromFichas: V[] = VENUES.flatMap((def) => {
  const e = byKey.get(def.key);
  if (!e) return [];
  return [
    {
      id: e.id,
      negocio: e.id.endsWith(`-${locale}`) ? e.id.slice(0, -(locale.length + 1)) : e.id,
      name: e.data.name,
      cat: def.cat,
      zone: zoneOf(e.data.coordinates.lng),
      lat: e.data.coordinates.lat,
      lng: e.data.coordinates.lng,
      area: e.data.area,
      description: e.data.description,
      website: e.data.website,
      href: placeUrl(locale, e.id),
      schemaType: e.data.type === "monumento" ? "TouristAttraction" : CATS[def.cat].schema,
      rating: googleRatings[def.key],
    },
  ];
});

// 2) Puntos añadidos en línea — datos VERIFICADOS (investigador, jun 2026). Beach
// clubs y miradores de atardecer, sin ficha propia (de momento). Las notas de
// acceso son reales y SIN fechas exactas (las restricciones se confirman cada
// temporada con el Consell/ayuntamientos; no se promete una fecha concreta).
type Extra = {
  id: string;
  name: string;
  cat: Cat;
  /** Segunda categoría, para el sitio que de verdad es dos cosas. Hoy solo El Toro:
   *  desde sus 358 m se ve SALIR y PONERSE el sol el mismo día, y esa doble vida es
   *  justo lo que lo hace único. El punto se pinta con la categoría principal, pero
   *  aparece en los dos filtros. */
