  lat: number;
  lng: number;
  areaEs: string;
  areaEn: string;
  areaFr: string;
  descEs: string;
  descEn: string;
  descFr: string;
  schemaType: string;
  website?: string; // web oficial (locales comerciales sin ficha)
  toArticle?: boolean; // enlaza a la guía de atardeceres
  noteEs?: string;
  noteEn?: string;
  noteFr?: string;
};
