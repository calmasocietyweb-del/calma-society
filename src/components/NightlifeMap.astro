    noteEs: "Abre tarde y solo algunas noches (sobre todo viernes y sábado en temporada). Está en una cala peatonal de Es Castell, con aparcamiento limitado en el pueblo; mejor ir sin coche.",
    noteEn: "It opens late and only some nights (mainly Fri–Sat in season). It sits on a pedestrian inlet of Es Castell with limited parking in the town; better to come without a car.",
  },

  // Nota: los clubs/discoteca de la noche de Menorca son pocos y reales —Jazzbah,
  // Kopas y Akelarre (fichas), más la Cova d'en Xoroi, que de noche es club—. Se
  // descartaron candidatos por cierre permanente (Sa Clau, Space) o por ubicación
  // dudosa/identidad sin confirmar (Sakova): el moat manda sobre el "más".
];

// Enlace de los puntos en línea: a la guía de atardeceres (ES/EN).
const sunsetArticle = isEs ? "atardeceres-menorca" : "menorca-sunsets";
const fromExtra: V[] = EXTRA.map((x) => ({
  id: x.id,
  name: x.name,
  cat: x.cat,
  zone: zoneOf(x.lng),
  lat: x.lat,
  lng: x.lng,
  area: isEs ? x.areaEs : x.areaEn,
  description: isEs ? x.descEs : x.descEn,
  website: x.website,
  href: x.toArticle ? articleUrl(locale, sunsetArticle) : undefined,
  note: isEs ? x.noteEs : x.noteEn,
  schemaType: x.schemaType,
  rating: googleRatings[x.id],
}));

// Lista ordenada por categoría (atardecer, beach, coctelería, club); el sort es
// estable, así que dentro de cada grupo van primero los de ficha y luego los nuevos.
const catIdx = (c: Cat) => CAT_ORDER.indexOf(c);
const venues: V[] = [...fromFichas, ...fromExtra].sort((a, b) => catIdx(a.cat) - catIdx(b.cat));
const catCount = (cat: Cat) => venues.filter((v) => v.cat === cat).length;
const zoneCount = (z: Zone) => venues.filter((v) => v.zone === z).length;

// ── Orden de la lista 100% CSS (sin JS) ──
// "Recomendado" agrupa por categoría (cabecera + locales); "Mejor valorados"
// ordena por nota de Google desc (los puntos naturales sin nota van al final).
// Cada tarjeta lleva su `--rec` y `--rate`; un radio decide cuál se aplica.
const RATED = [...venues].sort((a, b) => {
  const ra = a.rating?.score ?? -1;
  const rb = b.rating?.score ?? -1;
  if (rb !== ra) return rb - ra;
  return (b.rating?.reviews ?? -1) - (a.rating?.reviews ?? -1);
});
const rateRank = new Map(RATED.map((v, i) => [v.id, i + 1]));
const recCounter: Partial<Record<Cat, number>> = {};
const recOrder = new Map<string, number>();
for (const v of venues) {
  recCounter[v.cat] = (recCounter[v.cat] ?? 0) + 1;
  recOrder.set(v.id, catIdx(v.cat) * 1000 + (recCounter[v.cat] ?? 0));
}

// Combinaciones tipo×zona SIN resultados (p. ej. "Club" + "Centro"): se calculan
// en build y se emite el CSS exacto para mostrar el mensaje "sin resultados" solo
// en esos estados de los radios. 100% CSS, sin JS de cliente.
const emptyCombos: { cat: Cat; zone: Zone }[] = [];
for (const cat of CAT_ORDER) {
  for (const z of ZONES) {
    if (!venues.some((v) => v.cat === cat && v.zone === z.key)) emptyCombos.push({ cat, zone: z.key });
  }
}
const emptyCss = emptyCombos
  .map(
    (c) =>
      `.nightmap-filterable:has(#nf-${c.cat}:checked):has(#nf-zona-${c.zone}:checked) .nightmap-noresults{display:block}`,
  )
  .join("");

// ── Proyección equirectangular (idéntica a ParteCalmaMap): cos(lat) corrige el
// meridiano y la escala es uniforme → la isla mantiene su proporción real. ──
const RING = outline.ring as [number, number][];
const LAT_REF = (outline.bbox.latMin + outline.bbox.latMax) / 2;
const KX = Math.cos((LAT_REF * Math.PI) / 180);
const xsRaw = RING.map((p) => p[0] * KX);
const ysRaw = RING.map((p) => p[1]);
const minX = Math.min(...xsRaw);
const maxX = Math.max(...xsRaw);
const minY = Math.min(...ysRaw);
const maxY = Math.max(...ysRaw);
const spanX = maxX - minX;
const spanY = maxY - minY;
const DRAW_W = 860;
const PAD_TOP = 96;
const PAD_BOTTOM = 72;
const SCALE = DRAW_W / spanX;
const DRAW_H = spanY * SCALE;
const VIEW_W = 1000;
const VIEW_H = Math.round(PAD_TOP + DRAW_H + PAD_BOTTOM);
const offX = (VIEW_W - DRAW_W) / 2;
const offY = PAD_TOP;
const baseY = offY + DRAW_H;
const project = (lat: number, lng: number) => ({
  x: offX + (lng * KX - minX) * SCALE,
  y: offY + (maxY - lat) * SCALE,
});

const islandPath =
  "M " +
  RING.map((p, i) => {
    const { x, y } = project(p[1], p[0]);
    return (i ? "L " : "") + x.toFixed(1) + " " + y.toFixed(1);
  }).join(" ") +
  " Z";

// Pueblos de referencia para orientarse (faint, decorativos).
const TOWNS = [
  { es: "Ciutadella", en: "Ciutadella", lat: 40.0006, lng: 3.8377 },
  { es: "Ferreries", en: "Ferreries", lat: 39.9786, lng: 4.0103 },
  { es: "Es Mercadal", en: "Es Mercadal", lat: 39.9908, lng: 4.0922 },
  { es: "Alaior", en: "Alaior", lat: 39.9357, lng: 4.1389 },
  { es: "Maó", en: "Mahón", lat: 39.8885, lng: 4.2658 },
  { es: "Sant Lluís", en: "Sant Lluís", lat: 39.8475, lng: 4.2561 },
].map((t) => ({ ...t, ...project(t.lat, t.lng) }));

// Posiciones de los marcadores + des-solape determinista: varios locales caen
// casi en el mismo punto (puerto de Maó: Contrabandu/Akelarre/Vida Una; puerto
// de Ciutadella: Jazzbah/Kopas). Un pequeño empuje mutuo los separa para que se
// vean los dos; la lista de abajo es la versión canónica si aún se rozan.
const pts = venues.map((v) => {
  const { x, y } = project(v.lat, v.lng);
  return { v, x, y };
});
const MIN_SEP = 31; // separación mínima entre marcadores (iconos grandes r≈13 + anillo)
for (let pass = 0; pass < 18; pass++) {
  for (let i = 0; i < pts.length; i++) {
    for (let j = 0; j < i; j++) {
      let dx = pts[i].x - pts[j].x;
      let dy = pts[i].y - pts[j].y;
      let d = Math.hypot(dx, dy);
      if (d < MIN_SEP) {
        if (d < 0.01) {
          // Coincidentes: separa en un ángulo determinista (sin Math.random).
          const a = i * 2.3999632;
          dx = Math.cos(a);
          dy = Math.sin(a);
          d = 1;
        }
        const push = (MIN_SEP - d) / 2;
        const ux = dx / d;
        const uy = dy / d;
        pts[i].x += ux * push;
        pts[i].y += uy * push;
        pts[j].x -= ux * push;
        pts[j].y -= uy * push;
      }
    }
  }
}

// Barra de escala (≈ px por km; 1° ≈ 110,57 km).
const pxPerKm = SCALE / 110.574;
const scaleLen = 10 * pxPerKm;
const scaleX = offX;
const scaleY = baseY + 30;

// Direcciones (cómo llegar por tu cuenta): deep-link generado SOLO con las
// coordenadas verificadas de la ficha. Sin inventar nada.
const mapsUrl = (lat: number, lng: number) =>
  `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;

// Slugs del clúster de chófer de lujo (artículos ya publicados), por idioma.
const CH = isEs
  ? {
      lujo: "moverse-con-lujo-menorca",
      velada: "una-velada-con-chofer-menorca",
      claseS: "mercedes-clase-s-menorca",
      claseV: "mercedes-clase-v-menorca",
    }
  : {
      lujo: "getting-around-menorca-in-style",
      velada: "chauffeured-dinners-menorca",
      claseS: "mercedes-s-class-menorca",
      claseV: "mercedes-v-class-menorca",
    };

// Mes de la última verificación de valoraciones (para el descargo honesto).
const ratingsMonth = new Date(`${GOOGLE_RATINGS_AS_OF}T12:00:00`).toLocaleDateString(
  isEs ? "es-ES" : "en-GB",
  { month: "long", year: "numeric" },
);

const T = isEs
  ? {
      eyebrow: "El mapa de la noche",
      intro:
        "De los acantilados del atardecer a los amaneceres del levante, pasando por beach clubs, coctelerías de puerto y los clubs con más solera: nuestra selección con criterio de la noche de Menorca, con la valoración de cada negocio en Google, dónde está cada uno —y cómo llegar sin tener que conducir—.",
      filterTitle: "Filtra por tipo de plan",
      todas: "Todos",
      mapAria:
        "Mapa de Menorca con la ubicación de los locales de ocio nocturno. El detalle está en la lista siguiente.",
      costaNorte: "COSTA NORTE",
      costaSur: "COSTA SUR",
      mapCredit: "Contorno: © OpenStreetMap",
      teLlevamos: "Te llevamos",
      teLlevamosSub: "Clase S o Clase V con chófer",
      reserva: "Reserva con Menorca Bus",
      ubicacion: "Cómo llegar",
      web: "Web oficial",
      seasonal:
        "Horarios, temporada y aforos cambian cada año y casi todo es estacional (verano). Consulta la web o el Instagram oficial de cada local antes de ir.",
      reviewsWord: "reseñas",
      onGoogle: "en Google",
      ratingsNote: `Valoraciones de Google recogidas a mano en ${ratingsMonth}; cambian con el tiempo. Los miradores, faros y calas son puntos naturales de acceso público, sin valoración de negocio.`,
      sortTitle: "Ordenar",
      sortRec: "Recomendado",
      sortRating: "Mejor valorados",
      zoneTitle: "Zona de la isla",
      zonaTodas: "Toda la isla",
      naturalTag: "Punto público",
      transferShort: "Llegar con chófer",
      resultsNone: "No hay locales con estos filtros. Prueba a quitar alguno.",
      banner: {
        eyebrow: "Llega con chófer",
        title: "Llega como manda la noche",
        lead: "La mejor decisión de la noche es no traer coche. Te recogemos en un Mercedes con chófer privado, del primer atardecer al último cóctel —y vuelves sin pensar en el volante—.",
        photoAlt: "Mercedes Clase S negro de Menorca Bus junto al mar, en la costa de Menorca.",
        benefits: [
          "Chófer privado en Mercedes Clase S, o Clase V para el grupo.",
          "Te lleva, te espera y te recoge a la hora que digas.",
          "Aparca por ti y conduce de vuelta: vosotros brindáis.",
          "Conductores locales que conocen cada cala y cada puerto.",
        ],
        cta: "Reserva con Menorca Bus",
        lujo: "Moverse con lujo",
        velada: "Velada con chófer",
        claseS: "Mercedes Clase S",
        claseV: "Mercedes Clase V",
      },
    }
  : {
      eyebrow: "The map of the night",
      intro:
        "From the sunset cliffs to the eastern sunrises, by way of beach clubs, harbour cocktail bars and the island's longest-standing clubs: our considered selection of Menorca after dark, with each venue's Google rating, where every spot is —and how to get there without having to drive—.",
      filterTitle: "Filter by kind of plan",
      todas: "All",
      mapAria:
        "Map of Menorca with the location of the nightlife venues. Full detail in the list below.",
      costaNorte: "NORTH COAST",
      costaSur: "SOUTH COAST",
      mapCredit: "Outline: © OpenStreetMap",
      teLlevamos: "We'll drive you",
      teLlevamosSub: "S-Class or V-Class with chauffeur",
      reserva: "Book with Menorca Bus",
      ubicacion: "Get directions",
      web: "Official site",
      seasonal:
        "Opening hours, season and capacity change every year, and almost everything is seasonal (summer). Check each venue's official website or Instagram before you go.",
      reviewsWord: "reviews",
      onGoogle: "on Google",
      ratingsNote: `Google ratings gathered by hand in ${ratingsMonth}; they change over time. Viewpoints, lighthouses and beaches are natural, publicly accessible spots, with no business rating.`,
      sortTitle: "Sort",
      sortRec: "Recommended",
      sortRating: "Top rated",
      zoneTitle: "Side of the island",
      zonaTodas: "Whole island",
      naturalTag: "Public spot",
      transferShort: "Arrive with a chauffeur",
      resultsNone: "No venues match these filters. Try removing one.",
      banner: {
        eyebrow: "Arrive with a chauffeur",
        title: "Arrive the way the night deserves",
        lead: "The best decision of the night is to leave the car behind. We pick you up in a Mercedes with a private chauffeur, from the first sunset to the last cocktail —and you head home without a thought for the wheel.",
        photoAlt: "Black Mercedes S-Class from Menorca Bus by the sea on the Menorcan coast.",
        benefits: [
          "A private chauffeur in a Mercedes S-Class, or a V-Class for the group.",
          "We take you, wait for you and pick you up whenever you say.",
          "We park and drive back for you: you both get to toast.",
          "Local drivers who know every cove and every harbour.",
        ],
        cta: "Book with Menorca Bus",
        lujo: "Getting around in style",
        velada: "Chauffeured evenings",
        claseS: "Mercedes S-Class",
        claseV: "Mercedes V-Class",
      },
    };

// Carrusel del panel de Menorca Bus: fotos REALES del Clase S de noche con luces
// LED (sesión nocturna de la flota; crédito Menorca Bus). Alt bilingüe.
const busSlides = [
  {
    src: "/uploads/mb-noche-exterior.webp",
    altEs: "Mercedes Clase S negro de Menorca Bus de noche, con los faros LED encendidos y la estrella proyectada en el suelo.",
    altEn: "Black Mercedes S-Class from Menorca Bus at night, LED headlights on and the star projected on the ground.",
  },
  {
    src: "/uploads/mb-noche-piloto.webp",
    altEs: "Piloto trasero LED del Mercedes Clase S encendido en la oscuridad de la noche.",
    altEn: "The Mercedes S-Class LED tail light glowing in the dark of night.",
  },
  {
    src: "/uploads/mb-noche-volante.webp",
    altEs: "Interior del Clase S de noche, con la iluminación ambiental LED y la estrella iluminada en el volante.",
    altEn: "The S-Class cabin at night, with ambient LED lighting and the lit star on the steering wheel.",
  },
  {
    src: "/uploads/mb-noche-plazas.webp",
    altEs: "Plazas traseras del Clase S en piel coñac, con la iluminación ambiental LED al anochecer.",
    altEn: "The S-Class rear seats in cognac leather, with ambient LED lighting at dusk.",
  },
];
const busAlt = (s: (typeof busSlides)[number]) => (isEs ? s.altEs : s.altEn);

// ── JSON-LD: cada local como negocio con su geo (GEO/citabilidad por IA) ──
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": venues.map((v) => ({
    "@type": v.schemaType,
    name: v.name,
    address: {
      "@type": "PostalAddress",
      addressLocality: v.area,
      addressRegion: "Menorca",
      addressCountry: "ES",
    },
    geo: { "@type": "GeoCoordinates", latitude: v.lat, longitude: v.lng },
    ...(v.website ? { url: v.website } : {}),
    ...(v.rating
      ? {
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: v.rating.score,
            reviewCount: v.rating.reviews,
            bestRating: 5,
            worstRating: 1,
          },
        }
      : {}),
  })),
};
---

<section class="nightmap my-10">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">{T.eyebrow}</p>
  <p class="mt-2 text-base leading-relaxed text-piedra-suave">{T.intro}</p>

  {/* Valor añadido / conversión: el gesto-firma "te llevamos con chófer" con la
      foto de la flota REAL de Menorca Bus y los beneficios concretos (honestos).
      Negocio propio del grupo titular → rel=sponsored técnico. */}
  <aside class="nightmap-bus my-8 overflow-hidden rounded-2xl bg-arcilla text-lino shadow-[0_18px_40px_-24px_rgba(23,21,15,0.5)]">
    <div class="grid md:grid-cols-[1.05fr_1fr]">
      {/* Carrusel (sin JS de cliente): fotos REALES del Clase S de noche con
          luces LED. Radios sr-only + `:has()` trasladan la pista; los puntos son
          labels. El grupo de radios es navegable por teclado (flechas). */}
      <div class="cs-noche relative min-h-64 overflow-hidden bg-arcilla md:min-h-full">
        {
          busSlides.map((s, i) => (
            <input
              id={`cs-noche-${i}`}
              class="cs-radio sr-only"
              type="radio"
              name="cs-noche"
              aria-label={`${i + 1}/${busSlides.length} — ${busAlt(s)}`}
              checked={i === 0}
            />
          ))
        }

        <div class="cs-track flex h-full">
          {
            busSlides.map((s) => (
              <figure class="cs-slide relative h-full w-full shrink-0">
                <img
                  src={s.src}
                  srcset={srcset(s.src)}
                  sizes="(min-width: 768px) 48vw, 100vw"
                  alt={busAlt(s)}
                  width="1600"
                  height="1067"
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-cover"
                />
                <div
                  class="absolute inset-0 bg-gradient-to-t from-arcilla/60 to-transparent md:bg-gradient-to-r md:from-transparent md:to-arcilla/30"
                  aria-hidden="true"
                />
              </figure>
            ))
          }
        </div>

        <div class="cs-dots absolute inset-x-0 bottom-3 z-10 flex justify-center gap-2">
          {busSlides.map((_, i) => <label class="cs-dot" for={`cs-noche-${i}`} aria-hidden="true" />)}
        </div>
      </div>

      {/* Contenido */}
      <div class="p-7 sm:p-9">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-champan">{T.banner.eyebrow}</p>
        <p class="mt-3 font-display text-2xl leading-snug text-crema sm:text-[1.9rem]">{T.banner.title}</p>
        <p class="mt-3 text-sm leading-relaxed text-lino/85 sm:text-base">{T.banner.lead}</p>

        <ul class="mt-5 space-y-2.5">
          {
            T.banner.benefits.map((b) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-lino/90">
                <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-champan" fill="none" aria-hidden="true">
                  <path d="M4 10.5l4 4 8-9" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{b}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a
            href={menorcaBusUrl("noche", "mapa")}
            target="_blank"
            rel="sponsored noopener"
            data-umami-event="cta-menorcabus-noche"
            class="rounded-md bg-crema px-5 py-2.5 text-sm font-semibold text-arcilla transition-colors hover:bg-lino"
          >
            {T.banner.cta} ↗
          </a>
          <a href={articleUrl(locale, CH.velada)} class="text-sm font-semibold text-champan hover:underline">
            {T.banner.velada} →
          </a>
        </div>
        <MenorcaBusPromo locale={locale} tone="dark" class="mt-4" />
        <p class="mt-5 flex flex-wrap gap-x-5 gap-y-1 border-t border-lino/15 pt-4 text-xs text-lino/70">
          <a href={articleUrl(locale, CH.lujo)} class="text-champan/90 hover:underline">{T.banner.lujo} →</a>
          <a href={articleUrl(locale, CH.claseS)} class="text-champan/90 hover:underline">{T.banner.claseS} →</a>
          <a href={articleUrl(locale, CH.claseV)} class="text-champan/90 hover:underline">{T.banner.claseV} →</a>
        </p>
      </div>
    </div>
  </aside>

  {/* `.nightmap-filterable` envuelve filtro + mapa + lista: al marcar una
      categoría, `:has()` oculta a la vez sus marcadores y sus filas. */}
  <div class="nightmap-filterable">
    {/* Barra de control: ordenar (recomendado / mejor valorados) + filtrar por
        tipo + filtrar por zona. Todo con radios sr-only + CSS (cero JS). */}
    <div class="nightmap-toolbar mt-2 grid gap-x-7 gap-y-4 rounded-2xl border border-niebla bg-arena/30 p-4 sm:grid-cols-[auto_1fr] sm:p-5">
      <fieldset class="sm:col-start-1 sm:row-start-1">
        <legend class="text-[0.7rem] font-semibold uppercase tracking-wider text-oro">{T.sortTitle}</legend>
        <div class="mt-2 inline-flex rounded-full border border-niebla bg-lino p-0.5">
          <input id="nf-sort-rec" class="nightmap-radio sr-only" type="radio" name="nf-sort" checked />
          <label for="nf-sort-rec" class="nightmap-seg cursor-pointer rounded-full px-4 py-1.5 text-sm text-piedra-suave transition-colors">{T.sortRec}</label>
          <input id="nf-sort-rating" class="nightmap-radio sr-only" type="radio" name="nf-sort" />
          <label for="nf-sort-rating" class="nightmap-seg inline-flex cursor-pointer items-center gap-1 rounded-full px-4 py-1.5 text-sm text-piedra-suave transition-colors">
            <span aria-hidden="true" class="text-oro-vivo">★</span>{T.sortRating}
          </label>
        </div>
      </fieldset>

      <fieldset class="sm:col-start-2 sm:row-start-1">
        <legend class="text-[0.7rem] font-semibold uppercase tracking-wider text-oro">{T.filterTitle}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          <input id="nf-todas" class="nightmap-radio sr-only" type="radio" name="nf-cat" checked />
          <label
            for="nf-todas"
            class="nightmap-chip cursor-pointer rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
          >
            {T.todas} ({venues.length})
          </label>
          {
            CAT_ORDER.map((cat) => (
              <Fragment>
                <input id={`nf-${cat}`} class="nightmap-radio sr-only" type="radio" name="nf-cat" />
                <label
                  for={`nf-${cat}`}
                  class="nightmap-chip inline-flex cursor-pointer items-center gap-2 rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
                >
                  <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${CATS[cat].color}`} />
                  {catLabel(cat)} ({catCount(cat)})
                </label>
              </Fragment>
            ))
          }
        </div>
      </fieldset>

      <fieldset class="sm:col-start-2 sm:row-start-2">
        <legend class="text-[0.7rem] font-semibold uppercase tracking-wider text-oro">{T.zoneTitle}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          <input id="nf-zona-todas" class="nightmap-radio sr-only" type="radio" name="nf-zona" checked />
          <label
            for="nf-zona-todas"
            class="nightmap-chip cursor-pointer rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
          >
            {T.zonaTodas}
          </label>
          {
            ZONES.map((z) => (
              <Fragment>
                <input id={`nf-zona-${z.key}`} class="nightmap-radio sr-only" type="radio" name="nf-zona" />
                <label
                  for={`nf-zona-${z.key}`}
                  class="nightmap-chip cursor-pointer rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
                >
                  {zoneLabel(z.key)} ({zoneCount(z.key)})
                </label>
              </Fragment>
            ))
          }
        </div>
      </fieldset>
    </div>

    {/* Mapa SVG (contorno real de Menorca, OSM). La lista debajo es canónica. */}
    <figure class="nightmap-figure mt-6 overflow-hidden rounded-2xl border border-niebla">
      <svg viewBox={`0 0 ${VIEW_W} ${VIEW_H}`} role="img" aria-label={T.mapAria} class="h-auto w-full">
        <defs>
          {/* Mar al atardecer: degradado cálido dorado (≠ el azul del parte de calas). */}
          <linearGradient id="night-mar" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#f3e5cd" />
            <stop offset="0.55" stop-color="#eedabd" />
            <stop offset="1" stop-color="#e4cda8" />
          </linearGradient>
          {/* Resplandor del sol poniente, desde lo alto del cielo. */}
          <radialGradient id="night-sol" cx="0.5" cy="0.02" r="0.85">
            <stop offset="0" stop-color="#fdf0cf" stop-opacity="0.95" />
            <stop offset="0.45" stop-color="#f6dfac" stop-opacity="0.4" />
            <stop offset="1" stop-color="#f6dfac" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="night-tierra" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#d8c49d" />
            <stop offset="1" stop-color="#c7b085" />
          </linearGradient>
          <filter id="night-sombra" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="6" stdDeviation="10" flood-color="#5a3a22" flood-opacity="0.22" />
          </filter>
          <filter id="night-punto" x="-80%" y="-80%" width="260%" height="260%">
            <feDropShadow dx="0" dy="1.5" stdDeviation="1.6" flood-color="#3a2414" flood-opacity="0.5" />
          </filter>
          <filter id="night-glow" x="-150%" y="-150%" width="400%" height="400%">
            <feDropShadow dx="0" dy="0" stdDeviation="5.5" flood-color="#fff3da" flood-opacity="0.95" />
          </filter>
        </defs>

        <rect x="0" y="0" width={VIEW_W} height={VIEW_H} fill="url(#night-mar)" aria-hidden="true" />
        <rect x="0" y="0" width={VIEW_W} height={VIEW_H} fill="url(#night-sol)" aria-hidden="true" />
        <path d={islandPath} fill="none" stroke="#f4e9d4" stroke-width="22" stroke-linejoin="round" opacity="0.6" aria-hidden="true" />
        <path d={islandPath} fill="none" stroke="#ecdabc" stroke-width="11" stroke-linejoin="round" opacity="0.75" aria-hidden="true" />
        <g filter="url(#night-sombra)" aria-hidden="true">
          <path d={islandPath} fill="url(#night-tierra)" stroke="#b1936a" stroke-width="1.4" stroke-linejoin="round" />
        </g>

        <text x={VIEW_W / 2} y={offY - 30} fill="#9a8458" font-size="15" text-anchor="middle" font-family="Inter Variable, sans-serif" letter-spacing="4" aria-hidden="true">{T.costaNorte}</text>
        <text x={VIEW_W / 2} y={baseY + 46} fill="#9a8458" font-size="15" text-anchor="middle" font-family="Inter Variable, sans-serif" letter-spacing="4" aria-hidden="true">{T.costaSur}</text>

        <g aria-hidden="true" font-family="Inter Variable, sans-serif">
          {
            TOWNS.map((t) => (
              <Fragment>
                <circle cx={t.x} cy={t.y} r="2.6" fill="#7c6a4c" />
                <text x={t.x} y={t.y - 8} fill="#7c6a4c" font-size="13" text-anchor="middle">{isEs ? t.es : t.en}</text>
              </Fragment>
            ))
          }
        </g>

        <g aria-hidden="true" transform="translate(940,50)" font-family="Inter Variable, sans-serif">
          <circle r="22" fill="#f7f4ee" stroke="#ded4c4" stroke-width="1" />
          <path d="M0,-17 L4,0 L-4,0 Z" fill="#b96a4b" />
          <path d="M0,17 L4,0 L-4,0 Z" fill="#a8895c" />
          <text x="0" y="-25" text-anchor="middle" font-size="13" font-weight="600" fill="#46423a">N</text>
        </g>

        <g aria-hidden="true" stroke="#6b6557" fill="#6b6557" font-family="Inter Variable, sans-serif" font-size="12">
          <line x1={scaleX} y1={scaleY} x2={scaleX + scaleLen} y2={scaleY} stroke-width="1.5" />
          <line x1={scaleX} y1={scaleY - 5} x2={scaleX} y2={scaleY + 5} stroke-width="1.5" />
          <line x1={scaleX + scaleLen / 2} y1={scaleY - 3} x2={scaleX + scaleLen / 2} y2={scaleY + 3} stroke-width="1" />
          <line x1={scaleX + scaleLen} y1={scaleY - 5} x2={scaleX + scaleLen} y2={scaleY + 5} stroke-width="1.5" />
          <text x={scaleX} y={scaleY + 18} text-anchor="middle" stroke="none">0</text>
          <text x={scaleX + scaleLen / 2} y={scaleY + 18} text-anchor="middle" stroke="none">5</text>
          <text x={scaleX + scaleLen} y={scaleY + 18} text-anchor="middle" stroke="none">10 km</text>
        </g>

        {/* Marcadores por local: punto de color + glifo de categoría + nombre al
            señalar (hover/foco). Enlazan a su ficha de la lista. */}
        {
          pts.map((p) => (
            <a class="night-pin" href={`#night-${p.v.id}`} data-cat={p.v.cat} data-zone={p.v.zone}>
              <title>{p.v.name} — {catLabel(p.v.cat)}</title>
              <circle class="night-pin-circle" cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r="13" fill={CATS[p.v.cat].color} stroke="#fff8ec" stroke-width="3" filter="url(#night-punto)" />
              <g class="night-pin-glyph" transform={`translate(${p.x.toFixed(1)},${p.y.toFixed(1)}) scale(1.3)`} aria-hidden="true" set:html={GLYPH[p.v.cat]} />
              <text class="night-nombre" x={p.x.toFixed(1)} y={(p.y - 20).toFixed(1)} text-anchor="middle" font-size="14">{p.v.name}</text>
            </a>
          ))
        }
      </svg>
      <figcaption class="border-t border-niebla bg-lino px-4 py-2 text-[0.7rem] text-piedra-suave">{T.mapCredit}</figcaption>
    </figure>

    {/* Lista accesible (canónica). Orden y filtros 100% CSS vía `--rec`/`--rate`
        y los radios. Cada ficha: nombre + nota Google + plan "llegar con chófer"
        (Menorca Bus) + cómo llegar + web. */}
    <div class="nightmap-list mt-6 grid gap-3 md:grid-cols-2" role="list">
      {
        venues.map((v) => (
          <article
            id={`night-${v.id}`}
            data-cat={v.cat}
            data-zone={v.zone}
            role="listitem"
            style={`--rec:${recOrder.get(v.id)};--rate:${rateRank.get(v.id)}`}
            class="nightmap-card flex scroll-mt-28 flex-col rounded-xl border border-niebla bg-lino p-4 transition-colors sm:p-5"
          >
            <div class="flex items-start justify-between gap-x-3">
              <div class="min-w-0">
                <p class="font-display text-lg text-tinta sm:text-xl">
                  {v.href ? (
                    <a class="underline decoration-niebla underline-offset-4 hover:decoration-terracota" href={v.href}>{v.name}</a>
                  ) : (
                    v.name
                  )}
                </p>
                <span class="mt-1 inline-flex items-center gap-1.5 text-[0.68rem] font-semibold uppercase tracking-wider text-oro">
                  <span class="inline-block h-2 w-2 rounded-full" style={`background:${CATS[v.cat].color}`} />
                  {catLabel(v.cat)}
                </span>
              </div>
              {v.rating ? (
                <span
                  class="inline-flex shrink-0 items-baseline gap-1 rounded-full border border-niebla bg-arena/40 px-2.5 py-1"
                  title={`${fmtScore(v.rating.score, locale)} · ${fmtReviews(v.rating.reviews, locale)} ${T.reviewsWord} ${T.onGoogle}`}
                >
                  <span aria-hidden="true" class="text-oro-vivo">★</span>
                  <span class="text-sm font-semibold text-tinta">{fmtScore(v.rating.score, locale)}</span>
                  <span class="text-xs text-piedra-suave">{fmtReviews(v.rating.reviews, locale)}</span>
                </span>
              ) : (
                <span class="shrink-0 rounded-full border border-niebla px-2.5 py-1 text-[0.68rem] font-medium text-piedra-suave">
                  {T.naturalTag}
                </span>
              )}
            </div>

            <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{v.area} · {v.description}</p>

            <p class="mt-3 border-t border-niebla/60 pt-3 text-sm text-piedra-suave">
              <span>{v.note ?? catPark(v.cat)}</span>{" "}
              <a
                class="whitespace-nowrap font-semibold text-arcilla underline decoration-arcilla/40 underline-offset-2 hover:text-terracota hover:decoration-terracota"
                href={menorcaBusUrl("noche", v.id)}
                target="_blank"
                rel="sponsored noopener"
                data-umami-event="cta-menorcabus-noche"
              >
                {T.transferShort} ↗
              </a>
            </p>

            <p class="mt-2 text-xs text-piedra-suave/80">
              <a class="underline decoration-niebla underline-offset-2 hover:text-arcilla" href={mapsUrl(v.lat, v.lng)} target="_blank" rel="noopener">{T.ubicacion} ↗</a>
              {v.website && (
                <Fragment>
                  {" · "}
                  <a class="underline decoration-niebla underline-offset-2 hover:text-arcilla" href={v.website} target="_blank" rel="noopener">{T.web} ↗</a>
                </Fragment>
              )}
            </p>
          </article>
        ))
      }
    </div>

    <p class="nightmap-noresults mt-6 rounded-xl border border-dashed border-niebla bg-arena/20 px-4 py-8 text-center text-sm text-piedra-suave">
      {T.resultsNone}
    </p>

    <p class="mt-5 text-xs leading-relaxed text-piedra-suave">{T.seasonal}</p>
    <p class="mt-2 text-xs leading-relaxed text-piedra-suave">{T.ratingsNote}</p>
  </div>

  {/* CSS dinámico: muestra "sin resultados" SOLO en las combinaciones tipo×zona
      que quedan vacías (calculadas en build). Cero JS. */}
  {emptyCss && <style is:inline set:html={emptyCss} />}

  <JsonLd schema={jsonLd} />
</section>
