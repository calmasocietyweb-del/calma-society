              width="1600"
              height="1067"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-arcilla/60 to-transparent md:bg-gradient-to-r md:from-transparent md:to-arcilla/30"
              aria-hidden="true"
            />
          </figure>
        </div>

        <div class="cs-dots absolute inset-x-0 bottom-3 z-10 flex justify-center gap-2">
          {busSlides.map((_, i) => <label class="cs-dot" for={`cs-noche-${i}`} aria-hidden="true" />)}
        </div>
      </div>

      {/* Contenido */}
      <div class="p-7 sm:p-9">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-champan">{T.banner.eyebrow}</p>
        <p class="mt-3 font-display text-2xl leading-snug text-crema sm:text-[1.9rem]">{T.banner.title}</p>
        <p class="mt-3 text-sm leading-relaxed text-lino/85 sm:text-base">{T.banner.lead}</p>

        <ul class="mt-5 space-y-2.5">
          {
            T.banner.benefits.map((b) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-lino/90">
                <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-champan" fill="none" aria-hidden="true">
                  <path d="M4 10.5l4 4 8-9" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{b}</span>
              </li>
            ))
          }
