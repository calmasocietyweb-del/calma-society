---
// Captación de suscriptores — el KPI nº1 (CLAUDE.md §3.1).
// Modos según la config de MailerLite (SITE.newsletter):
//   - "custom":   nuestro formulario premium POST a la URL `action`.
//   - "embedded": el formulario de MailerLite renderizado (`formId`).
//   - "popup":    nuestro botón abre el formulario emergente (`popupFormId`).
//   - "preview":  aún sin conectar.
import { SITE } from "../config/site";
import { useTranslations } from "../i18n/ui";
import { currentLocale } from "../i18n/utils";

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const inputId = "newsletter-email";
const { action, formId, popupFormId, emailField } = SITE.newsletter;
const mode = action
  ? "custom"
  : formId
    ? "embedded"
    : popupFormId
      ? "popup"
      : "preview";
---

<section class="bg-mar-hondo text-lino">
  <div class="mx-auto max-w-3xl px-5 py-16 text-center sm:px-8 sm:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Newsletter</p>
    <h2 class="mt-3 font-display text-3xl text-lino sm:text-4xl">
      {t("newsletter.title")}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-lino/80">
      {t("newsletter.text")}
    </p>

    {
      mode === "embedded" ? (
        <div class="ml-embedded mx-auto mt-8 max-w-md" data-form={formId} />
      ) : mode === "popup" ? (
        <button
          type="button"
          class="mx-auto mt-8 block rounded-md bg-oro px-8 py-3.5 text-sm font-semibold text-mar-hondo transition-colors hover:bg-lino"
          onclick={`ml('show', '${popupFormId}', true)`}
        >
          {t("newsletter.cta")}
        </button>
      ) : (
        <form
          action={mode === "custom" ? action : undefined}
          method="post"
          target="_blank"
          class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row"
        >
          <label for={inputId} class="sr-only">{t("newsletter.placeholder")}</label>
          <input
            id={inputId}
            type="email"
            name={emailField}
            required
            autocomplete="email"
            placeholder={t("newsletter.placeholder")}
            class="w-full rounded-md border border-lino/20 bg-lino/10 px-4 py-3 text-sm text-lino placeholder:text-lino/50 focus-visible:outline-oro"
          />
          <button
            type="submit"
            disabled={mode === "preview"}
            class="shrink-0 rounded-md bg-oro px-6 py-3 text-sm font-semibold text-mar-hondo transition-colors hover:bg-lino disabled:cursor-not-allowed disabled:opacity-60"
          >
            {t("newsletter.cta")}
          </button>
        </form>
      )
    }

    <p class="mt-4 text-xs text-lino/60">{t("newsletter.privacy")}</p>
    {
      mode === "preview" && (
        <p class="mt-2 text-xs text-lino/40">
          (Conexión con MailerLite pendiente del código del formulario.)
        </p>
      )
    }
  </div>
</section>
