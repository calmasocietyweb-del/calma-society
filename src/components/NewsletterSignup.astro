---
// Captación de suscriptores — el KPI nº1 (CLAUDE.md §3.1).
// Dos caminos según SITE.newsletter:
//   1) MailerLite (enabled:true): custom / embedded / popup / preview.
//   2) Captación de fundadores (enabled:false + capture.enabled): nuestro
//      formulario premium recoge correos por Formspree con consentimiento RGPD,
//      sin enviar campañas. Ver SocietyCaptureForm.astro.
// Variantes: "section" = banda completa (home, página propia); "inline" =
// tarjeta compacta para el final del artículo.
// El `formId` y el copy son opcionales: la landing del imán "Las calas con menos
// gente" pasa su propio formulario (grupo `calas-en-calma`) y su propio texto,
// reutilizando toda esta fontanería (embebido + red de seguridad + medición).
import { SITE } from "../config/site";
import { useTranslations } from "../i18n/ui";
import { currentLocale } from "../i18n/utils";
import SocietyCaptureForm from "./SocietyCaptureForm.astro";
import SubscribeForm from "./SubscribeForm.astro";

interface Props {
  variant?: "section" | "inline";
  /** formId de un formulario embebido concreto (p. ej. el del imán). Vacío → el general. */
  formId?: string;
  /** Copy opcional que sobrescribe el del diccionario (eyebrow/title/text/cta). */
  eyebrow?: string;
  title?: string;
  text?: string;
  cta?: string;
  /**
   * Variante "inline": origen del alta (→ /api/suscribir) y nombre del evento
   * Umami del envío, para DISTINGUIR la captación por colocación (p. ej. la
   * portada de Agenda usa `agenda` / `newsletter-submit-agenda`). Por defecto,
   * fin de artículo.
   */
  origen?: string;
  umamiEvent?: string;
}
const {
  variant = "section",
  formId: formIdProp,
  eyebrow,
  title,
  text,
  cta,
  origen = "articulo",
  umamiEvent = "newsletter-submit-inline",
} = Astro.props;

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const inputId = "newsletter-email";
const { action, formId: formIdDefault, popupFormId, emailField, enabled, capture } =
  SITE.newsletter;
const formId = formIdProp || formIdDefault;

// Copy efectivo: props > diccionario (la landing del imán habla de "la guía").
const copy = {
  eyebrow: eyebrow ?? t("newsletter.eyebrow"),
  title: title ?? t("newsletter.title"),
  text: text ?? t("newsletter.text"),
  cta: cta ?? t("newsletter.cta"),
};

// Modo captación de fundadores: MailerLite en pausa pero recogemos correos.
const captureMode = !enabled && capture.enabled && capture.endpoint.length > 0;
const show = enabled || captureMode;

// Modo MailerLite (solo cuando enabled).
const mlMode = action
  ? "custom"
  : formId
    ? "embedded"
    : popupFormId
      ? "popup"
      : "preview";
---

{
  show && variant === "inline" && (
    <aside class="mx-auto mt-16 max-w-prosa px-5 sm:mt-20 sm:px-8">
      <div class="rounded-2xl border border-niebla bg-arena/50 px-6 py-10 text-center sm:px-10">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
          {copy.eyebrow}
        </p>
        <h2 class="mt-3 font-display text-2xl text-tinta sm:text-3xl">
          {copy.title}
        </h2>
        <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-piedra-suave">
          {copy.text}
        </p>
        <SubscribeForm origen={origen} tone="light" idSuffix="-inline" umamiEvent={umamiEvent} />
      </div>
    </aside>
  )
}

{
  show && variant === "section" && (
    <section class="bg-arcilla text-lino">
      <div class="mx-auto max-w-3xl px-5 py-16 text-center sm:px-8 sm:py-20">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-champan">
          {copy.eyebrow}
        </p>
        <h2 class="mt-3 font-display text-3xl text-lino sm:text-4xl">
          {copy.title}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-lino/80">
          {copy.text}
        </p>

        {captureMode ? (
          <SocietyCaptureForm locale={locale} tone="dark" umamiEvent="newsletter-submit" />
        ) : mlMode === "embedded" ? (
          <div class="mx-auto mt-8 max-w-md">
            {/* Captación principal: formulario embebido de MailerLite (su lista). */}
            <div class="ml-embedded" data-form={formId} />
            {/* Red de seguridad: si MailerLite no carga (sin JS o bloqueado por un
                ad-blocker), se revela este formulario nativo. Sus correos van a
                Formspree → importar a MailerLite. Oculto por defecto: solo aparece
                cuando hace falta, sin parpadeo en el caso normal. */}
            <div class="ml-fallback" hidden>
              <p class="mb-1 text-xs text-lino/60">{copy.text}</p>
              <SocietyCaptureForm locale={locale} tone="dark" idSuffix="-mlfb" umamiEvent="newsletter-submit-fallback" />
            </div>
            <noscript>
              <style>{`.ml-fallback{display:block!important}`}</style>
            </noscript>
            <script is:inline>{`
              // Revela el respaldo nativo solo si MailerLite no rellenó su formulario
              // (ad-blocker/CSP/red). Si ML aparece después, vuelve a ocultarlo.
              document.querySelectorAll('.ml-embedded').forEach(function (box) {
                var fb = box.parentElement && box.parentElement.querySelector('.ml-fallback');
                if (!fb) return;
                if (box.children.length > 0) { fb.hidden = true; return; }
                var t = setTimeout(function () { if (box.children.length === 0) fb.hidden = false; }, 3000);
                new MutationObserver(function (_m, obs) {
                  if (box.children.length > 0) { fb.hidden = true; clearTimeout(t); obs.disconnect(); }
                }).observe(box, { childList: true });
              });
            `}</script>
          </div>
        ) : mlMode === "popup" ? (
          <button
            type="button"
            class="press mx-auto mt-8 block rounded-md bg-oro-vivo px-8 py-3.5 text-sm font-semibold text-tinta hover:bg-lino"
            onclick={`ml('show', '${popupFormId}', true)`}
            data-umami-event="newsletter-popup-open"
          >
            {copy.cta}
          </button>
        ) : (
          <form
            action={mlMode === "custom" ? action : undefined}
            method="post"
            target="_blank"
            class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row"
          >
            <label for={inputId} class="sr-only">
              {t("newsletter.placeholder")}
            </label>
            <input
              id={inputId}
              type="email"
              name={emailField}
              required
              autocomplete="email"
              placeholder={t("newsletter.placeholder")}
              class="w-full rounded-md border border-lino/20 bg-lino/10 px-4 py-3 text-sm text-lino placeholder:text-lino/50 transition-colors duration-150 ease-calma focus:border-champan/40 focus:bg-lino/[0.16] focus-visible:outline-champan"
            />
            <button
              type="submit"
              disabled={mlMode === "preview"}
              class="press shrink-0 rounded-md bg-oro-vivo px-6 py-3 text-sm font-semibold text-tinta hover:bg-lino disabled:cursor-not-allowed disabled:opacity-60"
              data-umami-event={mlMode === "custom" ? "newsletter-submit" : undefined}
            >
              {copy.cta}
            </button>
          </form>
        )}

        <p class="mt-4 text-xs text-lino/60">{t("newsletter.privacy")}</p>
        {mlMode === "preview" && !captureMode && (
          <p class="mt-2 text-xs text-lino/40">
            (Conexión con MailerLite pendiente del código del formulario.)
          </p>
        )}
      </div>
    </section>
  )
}
