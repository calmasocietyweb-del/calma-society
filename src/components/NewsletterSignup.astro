---
// Captación de suscriptores — el KPI nº1 (CLAUDE.md §3.1).
// El envío real se conecta en la Fase 5 (MailerLite/Buttondown); de momento
// el formulario es presentacional (action="#").
import { useTranslations } from "../i18n/ui";
import { currentLocale } from "../i18n/utils";

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const inputId = "newsletter-email";
---

<section class="bg-mar-hondo text-lino">
  <div class="mx-auto max-w-3xl px-5 py-16 text-center sm:px-8 sm:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
      Newsletter
    </p>
    <h2 class="mt-3 font-display text-3xl text-lino sm:text-4xl">
      {t("newsletter.title")}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-lino/80">
      {t("newsletter.text")}
    </p>

    <form
      action="#"
      method="post"
      class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row"
    >
      <label for={inputId} class="sr-only">{t("newsletter.placeholder")}</label>
      <input
        id={inputId}
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder={t("newsletter.placeholder")}
        class="w-full rounded-md border border-lino/20 bg-lino/10 px-4 py-3 text-sm text-lino placeholder:text-lino/50 focus-visible:outline-oro"
      />
      <button
        type="submit"
        class="shrink-0 rounded-md bg-oro px-6 py-3 text-sm font-semibold text-mar-hondo transition-colors hover:bg-lino"
      >
        {t("newsletter.cta")}
      </button>
    </form>

    <p class="mt-4 text-xs text-lino/60">{t("newsletter.privacy")}</p>
  </div>
</section>
