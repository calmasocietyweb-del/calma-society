---
/**
 * Calendario de escalas de cruceros en Maó (Menorca) 2026.
 * Lee src/data/cruceros-menorca-2026.json (calendario consolidado y verificado,
 * ver investigación en .tmp_research / NEGOCIO). HONESTIDAD ante todo:
 *   - Es una previsión PARCIAL (~55% de la temporada) y ORIENTATIVA, no el calendario
 *     oficial. Marzo-abril = confirmadas por consignatarios; resto = agregadores.
 *   - Cada escala muestra su nivel de fiabilidad; los pasajeros son CAPACIDAD nominal.
 *   - Descargo visible + enlace a la fuente oficial (Ports de Balears).
 * Bilingüe por prop `lang`. Tabla accesible (thead/th scope) y responsive.
 */
import cruceros from "../data/cruceros-menorca-2026.json";
import { barcosConPagina, type Call } from "../lib/cruises";

interface Props {
  lang?: "es" | "en";
}
const { lang = "es" } = Astro.props;
const isEs = lang === "es";

/* Los barcos que TIENEN página propia (repiten escala y tienen horas): desde la tabla
   se entra en la suya, donde se le dice al crucerista cuánto tiempo tiene de verdad y
   qué le da tiempo a hacer. Los demás se quedan en texto: no hay nada útil que contarles. */
const conPagina = new Map(
  barcosConPagina((cruceros as { calls: Call[] }).calls).map((b) => [b.ship, b.slug]),
);
const paginaDe = (ship: string) => {
  const slug = conPagina.get(ship);
  return slug ? (isEs ? `/crucero/${slug}` : `/en/cruise/${slug}`) : null;
};

// Conteo dinámico: el descargo se actualiza solo en cada refresco del calendario.
const nCalls = (cruceros as { totalListed?: number }).totalListed ?? cruceros.calls.length;
const seasonEst = cruceros.seasonEstimate;

const MONTHS: Record<string, string[]> = {
  es: ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"],
  en: ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"],
};
const DOW: Record<string, string[]> = {
  es: ["dom", "lun", "mar", "mié", "jue", "vie", "sáb"],
  en: ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
};
const CONF: Record<string, { label: Record<string, string>; color: string }> = {
  alta: { label: { es: "Confirmada", en: "Confirmed" }, color: "#4f7a52" },
  media: { label: { es: "Prevista", en: "Scheduled" }, color: "#c08a2b" },
  baja: { label: { es: "Por confirmar", en: "Unconfirmed" }, color: "#8a8170" },
};

const T = isEs
  ? {
      thFecha: "Fecha",
      thBarco: "Barco",
      thNaviera: "Naviera",
      thPax: "Capacidad",
      thEstado: "Fiabilidad",
      caption: "Escalas de cruceros previstas en el puerto de Maó en 2026.",
      disclaimer:
        `Calendario en actualización continua: recoge ${nCalls} de las ~${seasonEst} escalas previstas para 2026. Las próximas semanas se contrastan con el registro de atraques de la Autoridad Portuaria; las escalas más lejanas proceden de agregadores internacionales y pueden cambiar. Cuando una naviera no publica sus horas, lo decimos en vez de estimarlas. No es el calendario oficial.`,
      legendTitle: "Fiabilidad:",
      overnight: "pernocta",
      overnightNote: "Pernocta: el barco duerme en el puerto y zarpa al día siguiente. Es la escala con más tiempo real en tierra.",
      paxNote: "“Capacidad” es el máximo del barco, no el pasaje real embarcado. Las horas, cuando constan, son orientativas.",
      ciutadella:
        "Ciutadella apenas recibe cruceros en 2026: unas 2 escalas del pequeño National Geographic Orion (Lindblad), sin fecha confirmada. El resto del tráfico atraca en Maó.",
      official: "Consulta el calendario oficial y actualizado en Ports de Balears",
    }
  : {
      thFecha: "Date",
      thBarco: "Ship",
      thNaviera: "Line",
      thPax: "Capacity",
      thEstado: "Reliability",
      caption: "Cruise calls scheduled at the port of Maó in 2026.",
      disclaimer:
        `Calendar under continuous update: it lists ${nCalls} of the ~${seasonEst} calls expected for 2026. The coming weeks are cross-checked against the Port Authority's berthing record; calls further out come from international aggregators and may change. When a cruise line does not publish its times, we say so instead of estimating them. This is not the official schedule.`,
      legendTitle: "Reliability:",
      overnight: "overnight",
      overnightNote: "Overnight: the ship sleeps in port and sails the next day. It is the call with the most real time ashore.",
      paxNote: "“Capacity” is the ship's maximum, not actual passengers aboard. Times, where given, are indicative.",
      ciutadella:
        "Ciutadella barely receives cruise ships in 2026: around 2 calls of the small National Geographic Orion (Lindblad), with no confirmed date. All other traffic docks in Maó.",
      official: "Check the official, up-to-date schedule at Ports de Balears",
    };

// Agrupa las escalas por mes, conservando el orden.
// La escala tal y como vive en el JSON: la del motor de cálculo + su fuente.
type CalendarCall = Call & { source: string };
const groups: { key: string; label: string; items: (CalendarCall & { d: number; dow: string; hours: string; overnight: boolean })[] }[] = [];
let hayPernocta = false;
for (const c of cruceros.calls as CalendarCall[]) {
  const [y, m, d] = c.date.split("-").map(Number);
  const key = `${y}-${m}`;
  let g = groups.find((gr) => gr.key === key);
  if (!g) {
    g = { key, label: MONTHS[lang][m - 1], items: [] };
    groups.push(g);
  }
  const dow = DOW[lang][new Date(Date.UTC(y, m - 1, d, 12)).getUTCDay()];
  // El barco duerme en el puerto: la zarpa es de OTRO día y hay que decirlo, o el lector
  // leería «08:00–17:00» y creería que tiene nueve horas cuando tiene más de treinta.
  const overnight = Boolean(c.departureDate && c.departureDate !== c.date);
  if (overnight) hayPernocta = true;
  // Si no hay horas, no se dibuja una flecha vacía: la etiqueta «pernocta» ya lo dice todo.
  const hours = overnight
    ? c.arrival && c.departure
      ? `${c.arrival} → ${c.departure} (+1)`
      : c.arrival || ""
    : c.arrival && c.departure
      ? `${c.arrival}–${c.departure}`
      : c.arrival || "";
  g.items.push({ ...c, d, dow, hours, overnight });
}
const fmtPax = (n: number | null) => (n == null ? "—" : "≈ " + n.toLocaleString(isEs ? "es-ES" : "en-US"));
const officialUrl = cruceros.officialSource;
const colCount = 5;
---

<div class="my-10">
  {/* Descargo honesto, siempre visible antes del calendario. */}
  <p class="flex gap-3 rounded-xl border border-terracota/40 bg-arena/60 px-4 py-3 text-sm leading-relaxed text-piedra">
    <svg class="mt-0.5 h-4 w-4 shrink-0 text-terracota" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="4" r="2"></circle>
      <path d="M12 6v15M8 9h8M3 15a9 9 0 0 0 18 0"></path>
    </svg>
    <span>{T.disclaimer}</span>
  </p>

  {/* Leyenda de fiabilidad. */}
  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-xs text-piedra-suave">
    <span class="font-semibold uppercase tracking-wider text-oro">{T.legendTitle}</span>
    {(["alta", "media", "baja"] as const).map((k) => (
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${CONF[k].color}`}></span>
        {CONF[k].label[lang]}
      </span>
    ))}
  </div>

  {/* Tabla del calendario (responsive: scroll horizontal en móvil). */}
  <div class="mt-4 overflow-x-auto rounded-xl border border-niebla">
    <table class="w-full min-w-[34rem] border-collapse text-sm">
      <caption class="sr-only">{T.caption}</caption>
      <thead>
        <tr class="bg-arena text-left text-xs font-semibold uppercase tracking-wider text-piedra">
          <th scope="col" class="px-3 py-2.5">{T.thFecha}</th>
          <th scope="col" class="px-3 py-2.5">{T.thBarco}</th>
          <th scope="col" class="px-3 py-2.5">{T.thNaviera}</th>
          <th scope="col" class="px-3 py-2.5 text-right">{T.thPax}</th>
          <th scope="col" class="px-3 py-2.5">{T.thEstado}</th>
        </tr>
      </thead>
      {groups.map((g) => (
        <tbody>
          <tr>
            <th scope="colgroup" colspan={colCount} class="border-t border-niebla bg-lino px-3 py-2 text-left font-display text-base text-tinta">
              {g.label}
            </th>
          </tr>
          {g.items.map((c) => (
            <tr class="border-t border-niebla/70 align-baseline">
              <td class="whitespace-nowrap px-3 py-2.5 text-piedra">
                <span class="font-semibold text-tinta">{c.dow} {c.d}</span>
                {c.hours && <span class="block text-xs text-piedra-suave">{c.hours}</span>}
              </td>
              <td class="px-3 py-2.5 font-medium text-tinta" title={c.source}>
                {paginaDe(c.ship) ? (
                  <a
                    href={paginaDe(c.ship)}
                    class="underline decoration-niebla underline-offset-4 hover:text-arcilla hover:decoration-terracota"
                    data-umami-event="crucero-barco"
                  >
                    {c.ship}
                  </a>
                ) : (
                  c.ship
                )}
                {c.overnight && (
                  <span class="ml-2 inline-block rounded-full border border-oro-vivo/50 px-2 py-0.5 align-middle text-[0.65rem] font-normal uppercase tracking-wider text-oro">
                    {T.overnight}
                  </span>
                )}
              </td>
              <td class="px-3 py-2.5 text-piedra-suave">{c.line}</td>
              <td class="whitespace-nowrap px-3 py-2.5 text-right text-piedra-suave">{fmtPax(c.pax)}</td>
              <td class="whitespace-nowrap px-3 py-2.5">
                <span class="inline-flex items-center gap-1.5 text-piedra">
                  <span class="inline-block h-2.5 w-2.5 shrink-0 rounded-full" style={`background:${CONF[c.confidence]?.color || "#8a8170"}`}></span>
                  {CONF[c.confidence]?.label[lang] || c.confidence}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      ))}
    </table>
  </div>

  {hayPernocta && <p class="mt-2 text-xs leading-relaxed text-piedra-suave">{T.overnightNote}</p>}
  <p class="mt-2 text-xs leading-relaxed text-piedra-suave">{T.paxNote}</p>
  <p class="mt-2 text-xs leading-relaxed text-piedra-suave">{T.ciutadella}</p>
  <p class="mt-3 text-sm">
    <a class="font-medium text-arcilla underline underline-offset-2 hover:text-terracota" href={officialUrl} target="_blank" rel="noopener">{T.official} ↗</a>
  </p>
</div>
