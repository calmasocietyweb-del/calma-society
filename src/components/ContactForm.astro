---
// Formulario de contacto. Envía a SITE.forms.contact (p. ej. Formspree), sin
// backend propio. Si no está configurado, muestra el correo directo.
import { SITE } from "../config/site";
import { useTranslations } from "../i18n/ui";
import { currentLocale } from "../i18n/utils";

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const action = SITE.forms.contact;
const connected = action.length > 0;
const privacyHref = locale === "es" ? "/privacidad" : "/en/privacy";

const field =
  "mt-1 w-full rounded-md border border-niebla bg-white/60 px-4 py-3 text-sm text-piedra focus-visible:outline-mar";
---

{
  connected && (
    <form action={action} method="POST" class="space-y-5">
      <div>
        <label for="name" class="text-sm font-medium text-piedra">{t("contact.name")}</label>
        <input id="name" type="text" name="name" required autocomplete="name" class={field} />
      </div>
      <div>
        <label for="email" class="text-sm font-medium text-piedra">{t("contact.email")}</label>
        <input id="email" type="email" name="email" required autocomplete="email" class={field} />
      </div>
      <div>
        <label for="message" class="text-sm font-medium text-piedra">{t("contact.message")}</label>
        <textarea id="message" name="message" rows="5" required class={field} />
      </div>
      <input type="hidden" name="_subject" value="Calma Society — mensaje de contacto" />
      <div class="flex items-start gap-2.5">
        <input
          id="consent"
          type="checkbox"
          name="consent"
          value="acepto"
          required
          class="mt-1 h-4 w-4 shrink-0 accent-mar"
        />
        <label for="consent" class="text-sm leading-relaxed text-piedra-suave">
          {t("contact.consent")}{" "}
          <a href={privacyHref} class="font-medium text-mar underline hover:text-mar-hondo">
            {t("contact.consentLink")}
          </a>.
        </label>
      </div>
      <button
        type="submit"
        class="rounded-md bg-mar px-6 py-3 text-sm font-semibold text-lino transition-colors hover:bg-mar-hondo"
      >
        {t("contact.send")}
      </button>
    </form>
  )
}

<p class:list={["text-sm text-piedra-suave", connected && "mt-8"]}>
  {t("contact.directemail")}{" "}
  <a href={`mailto:${SITE.email}`} class="font-medium text-mar hover:text-mar-hondo">
    {SITE.email}
  </a>
</p>
