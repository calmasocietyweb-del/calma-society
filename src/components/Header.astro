---
// Cabecera: MASTHEAD de revista — utilidad fina + marca centrada con tagline
// (la "introducción elegante") + navegación de secciones. Menú móvil con
// <details> nativo: accesible y sin JavaScript de cliente.
import { SITE, type Locale } from "../config/site";
import { SECTIONS } from "../config/sections";
import { useTranslations } from "../i18n/ui";
import { currentLocale, homePath } from "../i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import Logo from "./Logo.astro";

interface Props {
  alternates?: Partial<Record<Locale, string>>;
}
const { alternates } = Astro.props;

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const home = homePath(locale);

// Páginas fijas (about/newsletter/contacto) por idioma.
const PAGES: Record<Locale, { about: string; newsletter: string; contact: string }> = {
  es: { about: "/quienes-somos", newsletter: "/newsletter", contact: "/contacto" },
  en: { about: "/en/about", newsletter: "/en/newsletter", contact: "/en/contact" },
  fr: { about: "/fr/qui-sommes-nous", newsletter: "/fr/newsletter", contact: "/fr/contact" },
};
const pages = PAGES[locale];

// Herramientas interactivas por idioma. En FR (despliegue por mercados) solo van
// las traducidas: Mar en calma + Atardeceres (el Planificador se añadirá después).
const TOOLS: Record<Locale, { href: string; label: string }[]> = {
  es: [
    { href: "/donde-el-mar-esta-en-calma", label: "Mar en calma" },
    { href: "/planificador", label: "Planificador" },
    { href: "/atardeceres-y-copas", label: "Atardeceres y copas" },
  ],
  en: [
    { href: "/en/where-the-sea-is-calm", label: "Calm sea" },
    { href: "/en/trip-planner", label: "Planner" },
    { href: "/en/sunsets-and-drinks", label: "Sunsets & drinks" },
  ],
  // FR (despliegue por mercados): Mer calme + Couchers ya traducidos. El
  // Planificateur queda fuera del despliegue FR hasta tener su pipeline de datos.
  fr: [
    { href: "/fr/ou-la-mer-est-calme", label: "Mer calme" },
    { href: "/fr/couchers-et-cocktails", label: "Couchers & cocktails" },
  ],
};
const tools = TOOLS[locale];
---

<header class="sticky top-0 z-50 border-b border-niebla bg-lino/95 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    {/* NIVEL 1 — utilidad fina (solo desktop): edición · La Sociedad + idioma, con filete dorado */}
    <div class="hidden items-center justify-between border-b border-oro-vivo/25 py-1.5 lg:flex">
      <span class="text-[0.62rem] uppercase tracking-[0.26em] text-oro">{SITE.edition}</span>
      <div class="flex items-center gap-5">
        {
          SITE.newsletter.enabled && (
            <a
              href={pages.newsletter}
              class="text-[0.62rem] uppercase tracking-[0.22em] text-arcilla transition-colors hover:text-terracota"
            >
              {t("nav.newsletter")}
            </a>
          )
        }
        <LanguageSwitcher alternates={alternates} />
      </div>
    </div>

    {/* NIVEL 2 — MASTHEAD: marca + introducción. Desktop centrado con filetes; móvil compacto. */}
    <div class="py-4 lg:py-6">
      <div class="flex items-center justify-between gap-4 lg:justify-center lg:gap-6">
        <span aria-hidden="true" class="hidden h-px max-w-[9rem] flex-1 bg-niebla lg:block"></span>

        <a href={home} class="flex items-center" aria-label={`${SITE.name} — ${t("nav.home")}`}>
          <Logo large />
        </a>

        <span aria-hidden="true" class="hidden h-px max-w-[9rem] flex-1 bg-niebla lg:block"></span>

        {/* Controles móvil: idioma + menú (ocultos en desktop) */}
        <div class="flex items-center gap-4 lg:hidden">
          <LanguageSwitcher alternates={alternates} />
          <details class="group relative">
            <summary
              class="flex cursor-pointer list-none items-center text-piedra [&::-webkit-details-marker]:hidden"
            >
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
              </svg>
              <span class="sr-only">{t("nav.menu")}</span>
            </summary>
            <nav
              aria-label="Principal (móvil)"
              class="absolute right-0 z-20 mt-3 w-60 rounded-lg border border-niebla bg-lino p-2 shadow-lg shadow-tinta/5"
            >
              {
                SECTIONS.map((s) => (
                  <a href={s.href[locale]} class="block rounded-md px-3 py-2 text-sm text-piedra transition-colors hover:bg-arena hover:text-terracota">
                    {s.label[locale]}
                  </a>
                ))
              }
              <hr class="my-2 border-niebla" />
              {
                tools.map((tool) => (
                  <a href={tool.href} class="block rounded-md px-3 py-2 text-sm font-medium text-arcilla transition-colors hover:bg-arena hover:text-terracota">
                    {tool.label}
                  </a>
                ))
              }
              <a href={pages.about} class="block rounded-md px-3 py-2 text-sm text-piedra transition-colors hover:bg-arena hover:text-terracota">
                {t("nav.about")}
              </a>
              <a href={pages.contact} class="block rounded-md px-3 py-2 text-sm text-piedra transition-colors hover:bg-arena hover:text-terracota">
                {t("nav.contact")}
              </a>
              {
                SITE.newsletter.enabled && (
                  <a href={pages.newsletter} class="block rounded-md px-3 py-2 text-sm font-medium text-arcilla transition-colors hover:bg-arena">
                    {t("nav.newsletter")}
                  </a>
                )
              }
            </nav>
          </details>
        </div>
      </div>

      {/* INTRODUCCIÓN elegante: tagline en itálica de Fraunces. Visible en móvil y desktop. */}
      <p
        class="mt-2.5 font-display text-[0.9rem] italic leading-snug text-piedra-suave lg:text-center lg:text-base"
        style="font-variation-settings:'opsz' 30,'wght' 380"
      >
        {t("brand.tagline")}
      </p>
    </div>

    {/* NIVEL 3 — navegación (solo desktop). Dos filas para que nunca se descuadre:
        arriba las SECCIONES editoriales; debajo, las HERRAMIENTAS interactivas
        (color arcilla, con filetes y algo menores) — visibles, sin competir con
        las secciones. `whitespace-nowrap` evita que una etiqueta se parta en dos
        líneas; `flex-wrap` es la red de seguridad en anchos justos. */}
    <nav
      aria-label="Principal"
      class="hidden flex-col items-center gap-y-2.5 border-t border-niebla py-3 lg:flex"
    >
      <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-1.5 text-[0.8rem]">
        {
          SECTIONS.map((s) => (
            <a
              href={s.href[locale]}
              class="whitespace-nowrap uppercase tracking-[0.12em] text-piedra transition-colors hover:text-terracota"
            >
              {s.label[locale]}
            </a>
          ))
        }
      </div>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-[0.72rem]">
        {
          tools.map((tool, i) => (
            <Fragment>
              {i > 0 && <span aria-hidden="true" class="h-3 w-px bg-niebla" />}
              <a
                href={tool.href}
                class="whitespace-nowrap uppercase tracking-[0.16em] text-arcilla transition-colors hover:text-terracota"
              >
                {tool.label}
              </a>
            </Fragment>
          ))
        }
      </div>
    </nav>
  </div>
</header>
