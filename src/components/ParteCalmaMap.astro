---
/**
 * "Dónde el mar está en calma" — widget del parte diario por cala.
 * Lee src/data/parte-calma.json (lo genera scripts/parte-calma.mjs con AEMET).
 *
 * El mapa usa la línea de costa REAL de Menorca (OpenStreetMap, ver
 * scripts/fetch-menorca-outline.mjs → src/data/menorca-outline.json) proyectada
 * con la MISMA transformación que los marcadores; cada cala se FIJA sobre la
 * costa (marcador de playa siempre pegado a la orilla). Cero JS de cliente: SVG +
 * lista + filtro 100% estáticos; la lista es la versión accesible y citable por IA;
 * el color NUNCA es el único indicador (siempre con su texto al lado).
 */
import parte from "../data/parte-calma.json";
import outline from "../data/menorca-outline.json";
import timeline from "../data/parte-timeline.json";
import { placeUrl } from "../i18n/utils";
import type { Locale } from "../config/site";
import { abs } from "../lib/schema";
import JsonLd from "./JsonLd.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
// Selector trilingüe para los pocos textos sueltos fuera del diccionario `T`.
const tri = (es: string, en: string, fr: string): string =>
  locale === "fr" ? fr : locale === "en" ? en : es;

const MEDUSAPP = "https://www.medusapp.net/";
// Empuje de medusas: APAGADO hasta cerrar pendientes legales (atribución exacta de
// AEMET, atribución Open-Meteo y permiso de deep-link de MedusApp por escrito) y
// recalibrar el modelo tras una temporada. Poner true para activarlo. Ver doc §legal.
const MEDUSAS_ENABLED = false;

// ---- Proyección equirectangular con corrección de meridiano (cos lat) y escala
// UNIFORME → mantiene la proporción real de la isla. La costa (RING) define la
// extensión; los marcadores usan la MISMA proyección. ----
const RING: [number, number][] = outline.ring as [number, number][];
// Recuadro que cubre la malla de relieve (mismo que en scripts/relieve-menorca.mjs).
const RELIEVE_BBOX = { latMin: 39.74, latMax: 40.13, lngMin: 3.71, lngMax: 4.42 };
// Icono de aviso, de línea (nada de emojis — estética de marca).
const UI_ICON_AVISO = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.5 21 19.5H3z"/><path d="M12 10v3.6"/><path d="M12 16.6h.01"/></svg>`;
const LAT_REF = (outline.bbox.latMin + outline.bbox.latMax) / 2;
const KX = Math.cos((LAT_REF * Math.PI) / 180);
const xsRaw = RING.map((p) => p[0] * KX);
const ysRaw = RING.map((p) => p[1]);
const minX = Math.min(...xsRaw);
const maxX = Math.max(...xsRaw);
const minY = Math.min(...ysRaw);
const maxY = Math.max(...ysRaw);
const spanX = maxX - minX;
const spanY = maxY - minY;
const DRAW_W = 860;
const PAD_TOP = 96;
const PAD_BOTTOM = 72;
const SCALE = DRAW_W / spanX;
const DRAW_H = spanY * SCALE;
const VIEW_W = 1000;
const VIEW_H = Math.round(PAD_TOP + DRAW_H + PAD_BOTTOM);
const offX = (VIEW_W - DRAW_W) / 2;
const offY = PAD_TOP;
const baseY = offY + DRAW_H;
const project = (lat: number, lng: number) => ({
  x: offX + (lng * KX - minX) * SCALE,
  y: offY + (maxY - lat) * SCALE,
});

/* Dónde cae la imagen del relieve dentro del dibujo. La malla (GEBCO 2020, altitud y
   profundidad REALES, ≈450 m de paso) cubre la isla y su mar alrededor; se coloca por
   sus cuatro esquinas, proyectadas igual que la costa. Ver scripts/relieve-menorca.mjs. */
const relieveNO = project(RELIEVE_BBOX.latMax, RELIEVE_BBOX.lngMin);
const relieveSE = project(RELIEVE_BBOX.latMin, RELIEVE_BBOX.lngMax);
const RELIEVE = {
  x: +relieveNO.x.toFixed(1),
  y: +relieveNO.y.toFixed(1),
  w: +(relieveSE.x - relieveNO.x).toFixed(1),
  h: +(relieveSE.y - relieveNO.y).toFixed(1),
};

// Silueta real (un único path con los ~600 vértices de la costa).
const islandPath =
  "M " +
  RING.map((p, i) => {
    const { x, y } = project(p[1], p[0]);
    return (i ? "L " : "") + x.toFixed(1) + " " + y.toFixed(1);
  }).join(" ") +
  " Z";

// El anillo de la costa en el plano del dibujo, con la longitud de arco acumulada:
// permite hablar de "el punto que está a X unidades de recorrido por la orilla".
const ringXY = RING.map((p) => project(p[1], p[0]));
const arc: number[] = [0];
for (let i = 1; i < ringXY.length; i++) {
  arc.push(arc[i - 1] + Math.hypot(ringXY[i].x - ringXY[i - 1].x, ringXY[i].y - ringXY[i - 1].y));
}
const PERIMETRO = arc[arc.length - 1];
// ¿En qué sentido gira el anillo? Decide cuál de las dos normales apunta al mar.
const ringHorario =
  ringXY.reduce((a, p, i) => {
    const q = ringXY[(i + 1) % ringXY.length];
    return a + (p.x * q.y - q.x * p.y);
  }, 0) > 0;

// Hacia dónde da al mar cada punto de la costa. Se promedia en una ventana de ±8
// vértices: si no, un entrante o un saliente sueltos despeinan la orientación.
const enAnillo = (i: number) => ((i % ringXY.length) + ringXY.length) % ringXY.length;
const normales = ringXY.map((_, i) => {
  let sx = 0, sy = 0;
  for (let k = -8; k <= 8; k++) {
    const a = ringXY[enAnillo(i + k - 1)], b = ringXY[enAnillo(i + k + 1)];
    const tx = b.x - a.x, ty = b.y - a.y;                 // tangente
    const nx = ringHorario ? ty : -ty;                     // normal exterior
    const ny = ringHorario ? -tx : tx;
    const len = Math.hypot(nx, ny) || 1;
    sx += nx / len; sy += ny / len;
  }
  const len = Math.hypot(sx, sy) || 1;
  return { x: sx / len, y: sy / len };
});
// La misma orientación, en rumbo geográfico (N=0°, E=90°): la usa el cálculo del abrigo.
const bearings: number[] = normales.map((n) => {
  const deg = (Math.atan2(n.x, -n.y) * 180) / Math.PI;
  return deg < 0 ? deg + 360 : deg;
});

// Fija una cala a la orilla: devuelve su posición sobre la costa medida como
// RECORRIDO por la línea de agua (s), no como par de coordenadas sueltas.
const snapS = (lat: number, lng: number) => {
  const px = lng * KX, py = lat;
  let bestS = 0, bestD = Infinity;
  for (let i = 0; i < RING.length - 1; i++) {
    const ax = RING[i][0] * KX, ay = RING[i][1];
    const bx = RING[i + 1][0] * KX, by = RING[i + 1][1];
    const dx = bx - ax, dy = by - ay;
    const len2 = dx * dx + dy * dy;
    let t = len2 ? ((px - ax) * dx + (py - ay) * dy) / len2 : 0;
    t = Math.max(0, Math.min(1, t));
    const cx = ax + t * dx, cy = ay + t * dy;
    const d = (px - cx) ** 2 + (py - cy) ** 2;
    if (d < bestD) { bestD = d; bestS = arc[i] + t * (arc[i + 1] - arc[i]); }
  }
  return bestS;
};
// Del recorrido (s) de vuelta a un punto del dibujo.
const idxDeArco = (s: number) => {
  const t = ((s % PERIMETRO) + PERIMETRO) % PERIMETRO;
  let lo = 1, hi = arc.length - 1;
  while (lo < hi) { const m = (lo + hi) >> 1; if (arc[m] < t) lo = m + 1; else hi = m; }
  return { i: lo, f: (t - arc[lo - 1]) / ((arc[lo] - arc[lo - 1]) || 1) };
};
const puntoEnArco = (s: number) => {
  const { i, f } = idxDeArco(s);
  return {
    x: ringXY[i - 1].x + f * (ringXY[i].x - ringXY[i - 1].x),
    y: ringXY[i - 1].y + f * (ringXY[i].y - ringXY[i - 1].y),
  };
};

/* ── LOS PUNTOS NO SE PISAN ──────────────────────────────────────────────────
   Hay calas que en la realidad están pegadas: Binibèquer y Binibèquer Nou distan
   unos cientos de metros, y en un mapa de la isla entera caen a 1 px una de otra.
   No hay punto lo bastante pequeño ni zoom razonable que las separe: es la escala.
   Y deslizarlas por la orilla tampoco basta, porque dos calas a los dos lados de un
   cabo quedan lejos POR LA COSTA pero pegadas EN LÍNEA RECTA.

   Así que se separan de verdad, con dos grados de libertad:
     · se deslizan a lo largo de la orilla (s), que es lo que menos falsea;
     · y solo si eso no basta, el punto se aparta HACIA DENTRO DE LA ISLA (h), con un
       hilo finísimo que lo ata a su sitio en la costa.
   Hacia dentro, y NUNCA hacia el mar: un punto flotando en el agua se lee como un error
   (feedback de Cristian) y encima obliga a moverlo más. Apartándolo tierra adentro no
   queda ninguno en el agua, ninguno tapa a otro, y se mueven menos.
   Es el recurso clásico de la cartografía de infografía (point displacement): se cede
   algo de exactitud posicional a cambio de que las 75 calas se vean y se puedan tocar.
   La ubicación exacta sigue estando en Google Maps, desde la ficha de cada cala. */
// Afinado en banco de pruebas: NINGÚN punto tapa a otro (el más apretado queda a 12,3 u
// y el punto mide 10), NINGUNO cae en el mar, se mueven 171 m de media (máx. 1,1 km) y
// solo 13 de 75 se apartan de la orilla.
const SEPARACION = 13;   // lo que debe haber entre centros (el punto mide 10)
const TIERRA_MAX = 30;   // lo más que un punto puede meterse tierra adentro (≈1,6 km)
const MUELLE = 0.02;     // tira de cada punto hacia su sitio real (miente lo menos posible)
const PASO = 0.04;
const ITERACIONES = 5000;

const normalEnArco = (s: number) => normales[idxDeArco(s).i];
const sFinal = parte.calas.map((c) => snapS(c.lat, c.lng));
const sOriginal = [...sFinal];
const hFinal = parte.calas.map(() => 0);
const posDe = (i: number) => {
  const p = puntoEnArco(sFinal[i]);
  const n = normalEnArco(sFinal[i]);
  return { x: p.x + n.x * hFinal[i], y: p.y + n.y * hFinal[i] };
};

for (let paso = 0; paso < ITERACIONES; paso++) {
  const pos = parte.calas.map((_, i) => posDe(i));
  const ds = parte.calas.map(() => 0);
  const dh = parte.calas.map(() => 0);
  let choques = 0;
  for (let i = 0; i < pos.length; i++) {
    for (let j = i + 1; j < pos.length; j++) {
      const vx = pos[i].x - pos[j].x, vy = pos[i].y - pos[j].y;
      const d = Math.hypot(vx, vy) || 0.001;
      if (d >= SEPARACION) continue;
      choques++;
      const fuerza = SEPARACION - d;
      const ex = (vx / d) * fuerza, ey = (vy / d) * fuerza;
      // El empuje se descompone en "por la costa" (tangente) y "hacia el mar" (normal).
      for (const [k, signo] of [[i, 1], [j, -1]] as [number, number][]) {
        const n = normalEnArco(sFinal[k]);
        ds[k] += signo * (ex * -n.y + ey * n.x);
        dh[k] += signo * (ex * n.x + ey * n.y);
      }
    }
  }
  if (!choques && paso > 5) break;
  for (let i = 0; i < pos.length; i++) {
    ds[i] -= (sFinal[i] - sOriginal[i]) * MUELLE; // muelle: vuelve a su sitio si puede
    dh[i] -= hFinal[i] * MUELLE;
    sFinal[i] += ds[i] * PASO;
    // h negativo = tierra adentro. Nunca positivo: ningún punto acaba flotando en el mar.
    hFinal[i] = Math.max(-TIERRA_MAX, Math.min(0, hFinal[i] + dh[i] * PASO));
  }
}

const markers = parte.calas.map((c, i) => {
  const anclaje = puntoEnArco(sFinal[i]); // su sitio en la orilla
  const p = posDe(i);                     // donde se dibuja el punto
  return { ...c, ...p, ax: anclaje.x, ay: anclaje.y, despegado: Math.abs(hFinal[i]) > 4 };
});

// Pueblos de referencia para orientarse (no son calas). Faint, decorativos.
const TOWNS = [
  { es: "Ciutadella", en: "Ciutadella", fr: "Ciutadella", lat: 40.0006, lng: 3.8377 },
  { es: "Ferreries", en: "Ferreries", fr: "Ferreries", lat: 39.9786, lng: 4.0103 },
  { es: "Es Migjorn Gran", en: "Es Migjorn Gran", fr: "Es Migjorn Gran", lat: 39.9476, lng: 4.0314 },
  { es: "Es Mercadal", en: "Es Mercadal", fr: "Es Mercadal", lat: 39.9908, lng: 4.0922 },
  { es: "Alaior", en: "Alaior", fr: "Alaior", lat: 39.9357, lng: 4.1389 },
  { es: "Maó", en: "Mahón", fr: "Maó", lat: 39.8885, lng: 4.2658 },
  { es: "Es Castell", en: "Es Castell", fr: "Es Castell", lat: 39.8794, lng: 4.2914 },
  { es: "Sant Lluís", en: "Sant Lluís", fr: "Sant Lluís", lat: 39.8475, lng: 4.2561 },
].map((t) => ({ ...t, ...project(t.lat, t.lng) }));

// Barra de escala (≈ px por km en la proyección; 1° ≈ 110,57 km).
const pxPerKm = SCALE / 110.574;
const SCALE_KM = 10;
const scaleLen = SCALE_KM * pxPerKm;
const scaleX = offX;
const scaleY = baseY + 30;

// Colores "semáforo elegante": verde salvia / ámbar cálido / rojo terracota.
// Solo como punto/filete de acento; el texto va siempre en color oscuro.
const FILL: Record<string, string> = { alto: "#4f7a52", medio: "#c08a2b", bajo: "#a8483a", "sin-dato": "#b3aa99" };

/* ────────────────────────────────────────────────────────────────────────────
   MODO ZONAS (prototipo, 13-jul) — el LITORAL pintado por tramos.
   Con 75 calas, los puntos se amontonan y se solapan. Pero el abrigo no es cosa
   de puntos: depende de HACIA DÓNDE MIRA la costa. Así que se colorea la propia
   orilla, tramo a tramo, con la misma fórmula del parte:
     - de cada tramo se saca su normal (hacia dónde da al mar), suavizada para que
       no la despeinen los recovecos de la costa;
     - se le aplica el viento de hoy de la cala más próxima (AEMET, por municipio);
     - abrigo = 1 - onshore(viento, orientación) · (velocidad / 38), igual que en
       `scripts/parte-calma.mjs`.
   Cero JS: se calcula al construir la web.
   ──────────────────────────────────────────────────────────────────────────── */
const MODO_MAPA: "puntos" | "zonas" = "zonas"; // "zonas" = litoral pintado + puntos encima

// La cala más cercana a cada vértice: de ella sale el municipio (AEMET da el viento
// por municipio, así que la cala vecina es la fuente honesta más próxima). Se mide
// contra su ANCLAJE en la orilla (ax, ay), no contra el punto ya repartido.
const calaCercana = (x: number, y: number) => {
  let best = markers[0], bestD = Infinity;
  for (const m of markers) {
    const d = (m.ax - x) ** 2 + (m.ay - y) ** 2;
    if (d < bestD) { bestD = d; best = m; }
  }
  return best;
};
const vecinaDeVertice = ringXY.map((p) => calaCercana(p.x, p.y).id);

// Recuento por estado para los chips del filtro (y para desactivar los vacíos).
const BANDS = ["alto", "medio", "bajo"] as const;
const total = parte.calas.length;

// ---- Línea temporal de previsión (multi-día por franjas, src/data/parte-timeline.json).
// El cliente recalcula la banda de cada cala al mover la barra; el servidor renderiza
// el PRIMER frame. Misma fórmula de abrigo que el parte diario. ----
const tl: any = timeline;
const DIR_DEG: Record<string, number> = {
  N: 0, NNE: 22.5, NE: 45, ENE: 67.5, E: 90, ESE: 112.5, SE: 135, SSE: 157.5,
  S: 180, SSO: 202.5, SO: 225, OSO: 247.5, O: 270, ONO: 292.5, NO: 315, NNO: 337.5,
};
const VIENTOS: [number, string][] = [
  [22.5, "Tramuntana (N)"], [67.5, "Gregal (NE)"], [112.5, "Llevant (E)"], [157.5, "Xaloc (SE)"],
  [202.5, "Migjorn (S)"], [247.5, "Llebeig (SO)"], [292.5, "Ponent (O)"], [337.5, "Mestral (NO)"], [361, "Tramuntana (N)"],
];
const degDe = (d: string) => (!d || d === "C" ? null : DIR_DEG[d] ?? null);
const nombreViento = (deg: number) => (VIENTOS.find(([m]) => deg < m) ?? VIENTOS[0])[1];
const ABRIGO_VMAX = tl.abrigoVmax || 38;
const bandaDe = (op: number, d: string | null, v: number) => {
  if (d == null) return "sin-dato"; // sin dato de viento → NUNCA "calma" falsa
  const deg = degDe(d);
  const onshore = deg == null ? 0 : (1 + Math.cos(((deg - op) * Math.PI) / 180)) / 2;
  const score = 1 - onshore * Math.min(v / ABRIGO_VMAX, 1);
  return score >= 0.66 ? "alto" : score >= 0.4 ? "medio" : "bajo";
};
const calaMeta: Record<string, any> = Object.fromEntries((tl.calas || []).map((c: any) => [c.id, c]));
// Día de hoy (UTC en build; el cliente lo reafina a hora de Menorca). El parte solo
// mira hacia DELANTE: descartamos los frames de días YA pasados para que HOY sea
// siempre la primera posición de la barra (mañana lo será el día siguiente). Si todo
// el dato fuese pasado (robot caído varios días), conservamos lo que haya + aviso stale.
const buildToday = new Date().toISOString().slice(0, 10);
const ALL_FRAMES: any[] = Array.isArray(tl.frames) ? tl.frames : [];
const futuras = ALL_FRAMES.filter((f) => f.fecha >= buildToday);
const FRAMES: any[] = futuras.length ? futuras : ALL_FRAMES;
const F0: any = FRAMES[0] || { day: "", period: "", rep: { name: "—", deg: 0, kmh: 0 }, winds: {} };
const hayTimeline = FRAMES.length > 1 && (tl.calas || []).length > 0;
const calaEnFrame = (id: string, frame: any) => {
  const m = calaMeta[id];
  const w = m ? frame.winds[m.ine] : null;
  if (!m || !w || w.d == null) return { band: "sin-dato", windName: tri("Sin previsión", "No forecast", "Sans prévision"), windKmh: 0 };
  const deg = degDe(w.d);
  return { band: bandaDe(m.op, w.d, w.v), windName: deg == null ? tri("Calma", "Calm", "Calme") : nombreViento(deg), windKmh: w.v };
};
// Banda inicial (render del servidor): del primer frame si hay previsión; si no,
// del parte diario canónico (parte-calma.json). Nunca "alto" por ausencia de dato.
const F0cala: Record<string, { band: string; windName: string; windKmh: number }> = Object.fromEntries(
  parte.calas.map((c) => [c.id, hayTimeline
    ? calaEnFrame(c.id, F0)
    : { band: c.abrigo.band, windName: c.abrigo.viento.nombre, windKmh: c.abrigo.viento.kmh }])
);
const counts: Record<string, number> = { alto: 0, medio: 0, bajo: 0 };
for (const c of parte.calas) { const b = F0cala[c.id].band; if (b === "alto" || b === "medio" || b === "bajo") counts[b]++; }

// MODO ZONAS: la banda de cada TRAMO de costa, con la MISMA fórmula que las calas
// (`bandaDe`) — solo cambia la entrada: en vez de la orientación de una cala, la
// orientación del tramo; el viento es el de su municipio (el de la cala vecina).
const ESCALON: Record<string, number> = { bajo: 0, medio: 1, alto: 2 };
const bandaVertice: string[] = ringXY.map((_, i) => {
  const vecina = calaMeta[vecinaDeVertice[i]];
  const w = vecina ? F0.winds?.[vecina.ine] : null;
  if (!vecina || !w || w.d == null) {
    const c = parte.calas.find((x) => x.id === vecinaDeVertice[i]) as any;
    return c ? c.abrigo.band : "sin-dato"; // sin previsión → el parte diario, nunca calma falsa
  }
  const banda = bandaDe(bearings[i], w.d, w.v);
  // SALVAGUARDA DE VERACIDAD. En un puerto natural (Maó, Fornells, Addaia) la costa
  // exterior mira a un lado y la cala, metida en la ría, al contrario: el tramo diría
  // "oleaje" donde la cala está en calma. Cuando el tramo contradice de plano a la cala
  // que tiene al lado, NO afirmamos nada: el tramo va en neutro y manda su punto.
  const bandaCala = bandaDe(vecina.op, w.d, w.v);
  const dif = Math.abs((ESCALON[banda] ?? 0) - (ESCALON[bandaCala] ?? 0));
  return dif >= 2 ? "sin-dato" : banda;
});
/* Lo que el cliente necesita para rehacer la costa pintada al mover la barra de días:
   un vértice de cada dos (basta para un trazo grueso), su rumbo y la cala vecina —de la
   que salen el municipio (para el viento) y su propia orientación (para la salvaguarda
   de los puertos). Va redondeado para que ocupe poco. */
const PASO_ZONA = 2;
const idxCala: Record<string, number> = Object.fromEntries((tl.calas || []).map((c: any, i: number) => [c.id, i]));
const ZONAS_CLIENTE = {
  pts: ringXY.filter((_, i) => i % PASO_ZONA === 0).map((p) => [+p.x.toFixed(1), +p.y.toFixed(1)]),
  bear: bearings.filter((_, i) => i % PASO_ZONA === 0).map((b) => Math.round(b)),
  cala: vecinaDeVertice.filter((_, i) => i % PASO_ZONA === 0).map((id) => idxCala[id] ?? -1),
};

// Tramos consecutivos del mismo color, en un solo trazo cada uno.
const tramos: { band: string; d: string }[] = [];
if (MODO_MAPA === "zonas") {
  let ini = 0;
  for (let i = 1; i <= ringXY.length; i++) {
    if (i === ringXY.length || bandaVertice[i] !== bandaVertice[ini]) {
      // Se solapan en un vértice para que no queden costuras entre tramos.
      const pts = ringXY.slice(ini, Math.min(i + 1, ringXY.length));
      if (pts.length > 1) {
        tramos.push({
          band: bandaVertice[ini],
          d: "M " + pts.map((p) => `${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(" L "),
        });
      }
      ini = i;
    }
  }
}
const dayFechas: string[] = [...new Set(FRAMES.map((f) => f.fecha))];

// Obsolescencia detectada YA en el servidor (cubre a quien navega sin JS): si el
// generador degradó (stale) o la fecha del dato es anterior al día de build.
const isStaleServer = !!parte.stale || !!tl.stale || (typeof parte.forecastDate === "string" && parte.forecastDate < buildToday);

const repName = F0.rep.name;
const repKmh = F0.rep.kmh;
const repDeg = F0.rep.deg;
// Cielo inicial: el del primer frame; si AEMET ya vació la franja en curso, cae al
// primer frame que sí tenga cielo (así el indicador no desaparece). El cliente ajusta
// al frame actual al cargar. La temperatura sí es la del primer frame (casi siempre hay).
const anySkyFrame: any = FRAMES.find((f) => f.sky) || null;
const F0sky: string | null = (F0.sky ?? (anySkyFrame ? anySkyFrame.sky : null)) ?? null;
const F0temp: number | null = F0.temp ?? null;

