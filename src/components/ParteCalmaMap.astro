// Etiqueta de día RELATIVA y LOCALIZADA derivada de la FECHA ABSOLUTA del frame.
// El valor `day` del JSON ("Hoy"/"Mañana") se CONGELA al generarse y CADUCA: tras la
// medianoche —o si el robot diario aún no ha corrido— "Hoy" señalaría a ayer. Por eso
// el día se recalcula aquí (primer pintado / sin JS) y, ya correcto, en el cliente con
// la fecha real de Menorca. De paso, traduce el día/periodo en la página EN (el JSON
// solo trae español).
const DOW_LABELS: Record<string, string[]> = {
  es: ["dom", "lun", "mar", "mié", "jue", "vie", "sáb"],
  en: ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
  fr: ["dim", "lun", "mar", "mer", "jeu", "ven", "sam"],
};
const REL_LABELS = {
  es: { hoy: "Hoy", manana: "Mañana" },
  en: { hoy: "Today", manana: "Tomorrow" },
  fr: { hoy: "Aujourd'hui", manana: "Demain" },
}[locale];
const MONTH_LABELS: Record<string, string[]> = {
  es: ["ene", "feb", "mar", "abr", "may", "jun", "jul", "ago", "sep", "oct", "nov", "dic"],
  en: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"],
  fr: ["janv.", "févr.", "mars", "avr.", "mai", "juin", "juil.", "août", "sept.", "oct.", "nov.", "déc."],
};
const PERIOD_LABELS = ({
  es: { "Mañana": "Mañana", "Tarde": "Tarde", "Todo el día": "Todo el día" },
  en: { "Mañana": "Morning", "Tarde": "Afternoon", "Todo el día": "All day" },
  fr: { "Mañana": "Matin", "Tarde": "Après-midi", "Todo el día": "Toute la journée" },
}[locale] ?? {}) as Record<string, string>;
const dowLoc = DOW_LABELS[locale];
const monLoc = MONTH_LABELS[locale];
const addDaysYmd = (ymd: string, n: number) =>
  new Date(Date.parse(ymd + "T00:00:00Z") + n * 86400000).toISOString().slice(0, 10);
const tomorrowServer = addDaysYmd(buildToday, 1);
const dayLabelOf = (f: string) =>
  f === buildToday ? REL_LABELS.hoy : f === tomorrowServer ? REL_LABELS.manana : dowLoc[new Date(f + "T12:00:00Z").getUTCDay()];
// Fecha corta del día que se está mirando: "23 jun" / "23 Jun".
const dateLabelOf = (f: string) => { const [, mm, dd] = f.split("-"); return Number(dd) + " " + monLoc[Number(mm) - 1]; };
const periodLabelOf = (p: string) => PERIOD_LABELS[p] ?? p;

// ---- Cielo + temperatura: etiquetas e iconos por categoría (sol/poco/nubes/lluvia/
// tormenta). Mismos datos para el primer pintado (servidor) y para el cliente al
// deslizar la barra. Paleta cálida de marca (sin azul): sol/rayos en oro, nubes en
// gris cálido, gotas en terracota. ----
const SKY_LABELS = ({
  es: { sol: "Despejado", poco: "Poco nuboso", nubes: "Nuboso", lluvia: "Lluvia", tormenta: "Tormenta" },
  en: { sol: "Clear", poco: "Partly cloudy", nubes: "Cloudy", lluvia: "Rain", tormenta: "Storm" },
  fr: { sol: "Dégagé", poco: "Peu nuageux", nubes: "Nuageux", lluvia: "Pluie", tormenta: "Orage" },
}[locale] ?? {}) as Record<string, string>;
const sunIcon =
  '<g fill="none" stroke="#A8895C" stroke-width="2" stroke-linecap="round"><line x1="16" y1="2.5" x2="16" y2="6"/><line x1="16" y1="26" x2="16" y2="29.5"/><line x1="2.5" y1="16" x2="6" y2="16"/><line x1="26" y1="16" x2="29.5" y2="16"/><line x1="6.7" y1="6.7" x2="9.2" y2="9.2"/><line x1="22.8" y1="22.8" x2="25.3" y2="25.3"/><line x1="6.7" y1="25.3" x2="9.2" y2="22.8"/><line x1="22.8" y1="9.2" x2="25.3" y2="6.7"/></g><circle cx="16" cy="16" r="6.5" fill="#A8895C"/>';
const cloud = (f: string) =>
  `<g fill="${f}"><circle cx="11.5" cy="20" r="5.5"/><circle cx="19" cy="17.5" r="7"/><circle cx="24.5" cy="21" r="5"/><rect x="9" y="20.5" width="17" height="6.5" rx="3.25"/></g>`;
const SKY_ICON: Record<string, string> = {
  sol: sunIcon,
  poco:
    '<circle cx="11" cy="11" r="4.6" fill="#A8895C"/><g fill="none" stroke="#A8895C" stroke-width="1.6" stroke-linecap="round"><line x1="11" y1="3" x2="11" y2="5"/><line x1="3" y1="11" x2="5" y2="11"/><line x1="5.4" y1="5.4" x2="6.8" y2="6.8"/><line x1="16.6" y1="5.4" x2="15.2" y2="6.8"/></g>' +
    cloud("#CFC6B6"),
  nubes: cloud("#9C9484"),
  lluvia:
    cloud("#9C9484") +
    '<g fill="none" stroke="#B96A4B" stroke-width="2" stroke-linecap="round"><line x1="13" y1="28" x2="11.6" y2="31"/><line x1="18" y1="28" x2="16.6" y2="31"/><line x1="23" y1="28" x2="21.6" y2="31"/></g>',
  tormenta:
    cloud("#7C7464") +
    '<path d="M18 27 l-4 6 h3.4 l-2.6 5.5" fill="none" stroke="#A8895C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
};
const skyIconOf = (s: string | null) => (s && SKY_ICON[s]) || "";
const skyLabelOf = (s: string | null) => (s && SKY_LABELS[s]) || "";

// ---- JSON-LD: una Beach por cala con el estado del mar de hoy (observationDate honesto) ----
const graph = [
  ...parte.calas.map((c) => ({
    "@type": "Beach",
    name: c.name,
    address: { "@type": "PostalAddress", addressLocality: c.area, addressRegion: "Menorca", addressCountry: "ES" },
    geo: { "@type": "GeoCoordinates", latitude: c.lat, longitude: c.lng },
    additionalProperty: {
      "@type": "PropertyValue",
      name: tri("Estado del mar previsto", "Forecast sea state", "État de la mer prévu"),
      value: T.abrigo[F0cala[c.id].band],
      observationDate: parte.forecastDate,
    },
  })),
];
const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---

<section class="mx-auto max-w-6xl px-5 pb-16 sm:px-8">
  {/* Meta: validez y fuente. Sin fecha fija del parte: el día se ve (y se elige) en la
      línea temporal; una fecha congelada aquí inducía a error al quedar obsoleta. */}
  <p class="text-sm text-piedra-suave">
    {parte.validityNote}{" "}
    <span class="text-piedra-suave">· {tri("Datos", "Data", "Données")}: {parte.sources.join(", ")}</span>
  </p>
  {parte.stale && (
    <p class="mt-2 rounded-md border border-niebla bg-arena px-4 py-2 text-sm text-piedra">{T.stale}</p>
  )}
  {/* Aviso de datos obsoletos (oculto; el JS lo muestra si la previsión no es de hoy
      o si el generador degradó: red de seguridad si el robot diario se parase). */}
  <p id="calma-stale" class={`mt-2 flex items-start gap-2 rounded-md border border-terracota/50 bg-arena px-4 py-2 text-sm text-arcilla${isStaleServer ? "" : " hidden"}`}>
    <span class="mt-0.5 shrink-0" aria-hidden="true" set:html={UI_ICON_AVISO} />
    <span>{T.staleAviso}</span>
  </p>

  {/* `.calma-filterable` envuelve filtro + mapa + lista: al marcar un estado, `:has()`
      oculta a la vez los puntos del mapa y las filas de la lista de los otros estados. */}
  <div class="calma-filterable">
    {/* Buscador de calas por nombre (JS progresivo: sin él se ven todas). */}
    <div class="mt-6">
      <input
        type="search"
        id="calma-buscar"
        placeholder={T.buscar}
        aria-label={T.buscar}
        autocomplete="off"
        class="w-full max-w-sm rounded-full border border-niebla bg-lino px-4 py-2 text-sm text-piedra placeholder:text-piedra-suave focus:border-arcilla focus:outline-none"
      />
    </div>
    {/* Filtro 100% CSS (mismo patrón que la Agenda). Los chips son también la leyenda
        de color: cada uno muestra su punto y el nº de calas; los vacíos van en gris. */}
    <fieldset class="mt-4">
      <legend class="text-xs font-semibold uppercase tracking-wider text-oro">{T.filterTitle}</legend>
      <div class="mt-2 flex flex-wrap gap-2">
        <input id="calma-todas" class="calma-radio sr-only" type="radio" name="calma-filtro" checked />
        <label
          for="calma-todas"
          class="calma-chip cursor-pointer rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
        >
          {T.todas} ({total})
        </label>
        {BANDS.map((b) => (
          <Fragment>
            <input
              id={`calma-${b}`}
              class="calma-radio sr-only"
              type="radio"
              name="calma-filtro"
              disabled={counts[b] === 0}
            />
            <label
              for={`calma-${b}`}
              class="calma-chip inline-flex cursor-pointer items-center gap-2 rounded-full border border-niebla bg-lino px-3.5 py-1.5 text-sm text-piedra transition-colors hover:border-arcilla"
            >
              <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${FILL[b]}`}></span>
              {T.abrigo[b]} <span id={`calma-count-${b}`}>({counts[b]})</span>
            </label>
          </Fragment>
        ))}
      </div>
    </fieldset>

    {/* Línea temporal de previsión: al deslizar, el JS recalcula mar + viento. */}
    {hayTimeline && (
      <div class="mt-6">
        <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
          <span class="text-xs font-semibold uppercase tracking-wider text-oro">{T.timelineTitle}</span>
          <span id="calma-frame-label" class="font-display text-lg text-tinta">{dayLabelOf(F0.fecha)}, {dateLabelOf(F0.fecha)} · {periodLabelOf(F0.period)}</span>
        </div>
        <input
          type="range"
          id="calma-tiempo"
          min="0"
          max={FRAMES.length - 1}
          value="0"
          step="1"
          class="mt-2 w-full accent-arcilla"
          aria-label={T.timelineTitle}
        />
        <div id="calma-day-row" class="mt-1 flex justify-between text-[0.7rem] text-piedra-suave">
          {dayFechas.map((fc) => <span class="calma-day" data-fecha={fc}>{dayLabelOf(fc)}</span>)}
        </div>
      </div>
    )}

    {/* Datos para el cliente (línea temporal): frames + meta de calas. No se ejecuta.
        `zonas` deja que la COSTA PINTADA se rehaga con el día que se elija en la barra:
        sin esto, los puntos cambiarían de color y la orilla se quedaría con la de hoy —
        el mapa se contradiría. Va comprimido: un vértice de cada dos, coordenadas con un
        decimal, el rumbo redondeado y el índice de la cala vecina. */}
    <script type="application/json" id="calma-tl-data" set:html={JSON.stringify({
      frames: FRAMES,
      calas: tl.calas,
      zonas: ZONAS_CLIENTE,
      vmax: ABRIGO_VMAX,
      fill: FILL,
      bandLabel: T.abrigo,
      subLabel: T.subAbrigo,
      dirDeg: DIR_DEG,
      vientos: VIENTOS,
      calma: tri("Calma", "Calm", "Calme"),
      viento: T.viento,
      dow: dowLoc,
      months: monLoc,
      rel: REL_LABELS,
      periodo: PERIOD_LABELS,
      skyIcon: SKY_ICON,
      skyLabel: SKY_LABELS,
      stale: !!tl.stale,
    }).replace(/</g, "\\u003c")} />

    {/* Indicador general (encima del mapa): viento + cielo y temperatura. Ambos cambian
        con la barra de tiempo. La flecha del viento apunta hacia donde sopla. El detalle
        por cala está en la lista; cielo/temperatura son de la isla (como AEMET por municipio). */}
    <div class="mt-5 flex flex-wrap items-center justify-between gap-x-6 gap-y-4 rounded-2xl border border-niebla bg-arena/40 px-5 py-4">
      <div class="flex items-center gap-4">
        <svg width="70" height="70" viewBox="0 0 68 68" role="img" aria-label={`${T.windTitle}: ${repName}, ${repKmh} km/h`} class="shrink-0">
          <circle cx="34" cy="34" r="30" fill="#f7f4ee" stroke="#ded4c4" stroke-width="1.5" />
          <g aria-hidden="true" fill="#8a6a3a" font-family="Inter Variable, sans-serif" font-size="9" font-weight="600">
            <text x="34" y="13" text-anchor="middle">N</text>
            <text x="34" y="62" text-anchor="middle">S</text>
            <text x="61" y="37" text-anchor="middle">E</text>
            <text x="7" y="37" text-anchor="middle">O</text>
          </g>
          <g id="calma-wind-dial" transform={`translate(34,34) rotate(${repDeg})`}>
            <line x1="0" y1="-15" x2="0" y2="12" stroke="#b96a4b" stroke-width="2.5" />
            <path d="M0,20 L7.5,7 L-7.5,7 Z" fill="#b96a4b" />
          </g>
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-oro">{T.windTitle}</p>
          <p class="font-display text-2xl leading-tight text-tinta" id="calma-wind-name">{repName}</p>
          <p class="text-sm text-piedra-suave"><span id="calma-wind-kmh">{repKmh}</span> km/h</p>
        </div>
      </div>

      {hayTimeline && F0sky && (
        <div class="flex items-center gap-3">
          <svg id="calma-sky-icon" width="56" height="56" viewBox="0 0 32 32" role="img" aria-label={`${T.skyTitle}: ${skyLabelOf(F0sky)}${F0temp != null ? `, ${F0temp}°` : ""}`} class="shrink-0" set:html={skyIconOf(F0sky)} />
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-oro">{T.skyTitle}</p>
            <p class="font-display text-2xl leading-tight text-tinta"><span id="calma-temp">{F0temp ?? "—"}</span>°</p>
            <p class="text-sm text-piedra-suave" id="calma-sky-label">{skyLabelOf(F0sky)}</p>
          </div>
        </div>
      )}
    </div>

    {/* Mapa SVG (contorno real de Menorca, OSM). La LISTA debajo es la versión canónica.
        En móvil el mapa entero encoge a un tercio y los puntos quedan diminutos: por eso
        el marco es una VENTANA por la que se arrastra el mapa, y el botón de abajo lo
        AMPLÍA. Todo con CSS (un checkbox), sin JS: el mapa sigue siendo estático. */}
    <div class="mt-5 flex flex-col gap-5 lg:flex-row lg:items-start">
    <figure class="calma-mapa min-w-0 flex-1 scroll-mt-20 overflow-hidden rounded-2xl border border-niebla">
      <input type="checkbox" id="calma-zoom" class="sr-only" />
      <div class="calma-viewport">
      <svg viewBox={`0 0 ${VIEW_W} ${VIEW_H}`} role="img" aria-label={T.mapAria} class="h-auto w-full">
        <defs>
          {/* Mar: azul mediterráneo desaturado (matices, no chillón) */}
          <linearGradient id="calma-mar" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#d7e6e6" />
            <stop offset="1" stop-color="#bdd4d6" />
          </linearGradient>
          {/* Tierra: verde sage cálido y suave */}
          <linearGradient id="calma-tierra" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#dee4cc" />
            <stop offset="1" stop-color="#ccd6b4" />
          </linearGradient>
          {/* La silueta real recorta el relieve de la tierra. */}
          <clipPath id="calma-isla">
            <path d={islandPath} />
          </clipPath>
          <filter id="calma-sombra" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="5" stdDeviation="9" flood-color="#33493b" flood-opacity="0.20" />
          </filter>
          {/* Sombra fina bajo cada punto para que destaque sobre mar y tierra */}
          <filter id="calma-punto" x="-60%" y="-60%" width="220%" height="220%">
            <feDropShadow dx="0" dy="1" stdDeviation="1.3" flood-color="#16241c" flood-opacity="0.45" />
          </filter>
        </defs>

        {/* Mar: relieve REAL del fondo (GEBCO). El azul se ahonda con la profundidad y
            se adivinan la plataforma costera y el talud. Debajo, el degradado de siempre
            por si la imagen no cargara. */}
        <rect x="0" y="0" width={VIEW_W} height={VIEW_H} fill="url(#calma-mar)" aria-hidden="true" />
        <image
          href="/uploads/menorca-relieve-mar.webp"
          x={RELIEVE.x} y={RELIEVE.y} width={RELIEVE.w} height={RELIEVE.h}
          preserveAspectRatio="none" opacity="0.5" aria-hidden="true"
        />

        {/* Agua somera: anillo más claro junto a la costa (matiz nautical) */}
        <path d={islandPath} fill="none" stroke="#e8f1f1" stroke-width="18" stroke-linejoin="round" opacity="0.4" aria-hidden="true" />
        <path d={islandPath} fill="none" stroke="#d4e5e5" stroke-width="9" stroke-linejoin="round" opacity="0.55" aria-hidden="true" />

        {/* Isla: la silueta real de OSM, rellena con el relieve REAL de la tierra
            (recortado por esa misma silueta, para que la costa caiga en su sitio). */}
        <g filter="url(#calma-sombra)" aria-hidden="true">
          <path d={islandPath} fill="url(#calma-tierra)" stroke="#9fb189" stroke-width="1.4" stroke-linejoin="round" />
          <image
            href="/uploads/menorca-relieve-tierra.webp"
            x={RELIEVE.x} y={RELIEVE.y} width={RELIEVE.w} height={RELIEVE.h}
            preserveAspectRatio="none" opacity="0.72" clip-path="url(#calma-isla)"
          />
          <path d={islandPath} fill="none" stroke="#9fb189" stroke-width="1.4" stroke-linejoin="round" />
        </g>

        {/* Orientación de costas */}
        <text x={VIEW_W / 2} y={offY - 30} fill="#5f7a72" font-size="15" text-anchor="middle" font-family="Inter Variable, sans-serif" letter-spacing="4" aria-hidden="true">{T.costaNorte}</text>
        <text x={VIEW_W / 2} y={baseY + 46} fill="#5f7a72" font-size="15" text-anchor="middle" font-family="Inter Variable, sans-serif" letter-spacing="4" aria-hidden="true">{T.costaSur}</text>

        {/* Pueblos de referencia (orientación, no son calas) */}
        <g aria-hidden="true" font-family="Inter Variable, sans-serif">
          {TOWNS.map((t) => (
            <Fragment>
              <circle cx={t.x} cy={t.y} r="2.6" fill="#4f5f4a" />
              <text x={t.x} y={t.y - 8} fill="#4f5f4a" font-size="13" text-anchor="middle">{t[locale]}</text>
            </Fragment>
          ))}
        </g>

        {/* Rosa de los vientos */}
        <g aria-hidden="true" transform="translate(940,50)" font-family="Inter Variable, sans-serif">
          <circle r="22" fill="#f7f4ee" stroke="#ded4c4" stroke-width="1" />
          <path d="M0,-17 L4,0 L-4,0 Z" fill="#b96a4b" />
          <path d="M0,17 L4,0 L-4,0 Z" fill="#a8895c" />
          <text x="0" y="-25" text-anchor="middle" font-size="13" font-weight="600" fill="#46423a">N</text>
        </g>

        {/* Barra de escala */}
        <g aria-hidden="true" stroke="#6b6557" fill="#6b6557" font-family="Inter Variable, sans-serif" font-size="12">
          <line x1={scaleX} y1={scaleY} x2={scaleX + scaleLen} y2={scaleY} stroke-width="1.5" />
          <line x1={scaleX} y1={scaleY - 5} x2={scaleX} y2={scaleY + 5} stroke-width="1.5" />
          <line x1={scaleX + scaleLen / 2} y1={scaleY - 3} x2={scaleX + scaleLen / 2} y2={scaleY + 3} stroke-width="1" />
          <line x1={scaleX + scaleLen} y1={scaleY - 5} x2={scaleX + scaleLen} y2={scaleY + 5} stroke-width="1.5" />
          <text x={scaleX} y={scaleY + 18} text-anchor="middle" stroke="none">0</text>
          <text x={scaleX + scaleLen / 2} y={scaleY + 18} text-anchor="middle" stroke="none">5</text>
          <text x={scaleX + scaleLen} y={scaleY + 18} text-anchor="middle" stroke="none">10 km</text>
        </g>

        {/* Marcadores por cala (fijados a la costa). El nombre aparece al señalar
            (hover/foco). Enlazan a su fila de la lista. */}
        {/* ZONAS: el litoral pintado por tramos, según hacia dónde mira la costa. */}
        {MODO_MAPA === "zonas" && (
          <g class="calma-zonas" fill="none" stroke-width="9" stroke-linecap="round" stroke-linejoin="round">
            {tramos.map((t) => <path d={t.d} stroke={FILL[t.band]} />)}
          </g>
        )}

        {markers.map((c) => {
          const b0 = F0cala[c.id].band;
          return (
            <a href={`#cala-${c.id}`} data-calma={b0} data-nombre={c.name}>
              <title>{c.name} — {T.abrigo[b0]}</title>
              {/* Si el punto tuvo que despegarse para no pisar a su vecina, un hilo
                  finísimo lo ata a su sitio real en la orilla. */}
              {c.despegado && (
                <line class="cala-hilo" x1={c.ax} y1={c.ay} x2={c.x} y2={c.y} stroke={FILL[b0]} stroke-width="1.2" opacity="0.55" />
              )}
              {/* Diana invisible: el punto se ve fino, pero el dedo acierta. */}
              <circle class="cala-diana" cx={c.x} cy={c.y} r="13" fill="transparent" />
              <circle class="cala-punto" cx={c.x} cy={c.y} r="5" fill={FILL[b0]} stroke="#ffffff" stroke-width="2" filter="url(#calma-punto)" />
              <text class="cala-nombre" x={c.x} y={c.y - 11} text-anchor="middle" font-size="13">{c.name}</text>
            </a>
          );
        })}
      </svg>
      </div>
      {/* Ampliar / reducir: solo donde hace falta (móvil y tablet). El estado vive
          en el checkbox → sin JS, y el teclado lo maneja igual que cualquier control. */}
      <div class="calma-zoom-bar">
        <p class="text-[0.7rem] text-piedra-suave">{T.zoomHint}</p>
        <label for="calma-zoom" class="calma-zoom-btn">
          <span class="cz-in">{T.zoomIn}</span>
          <span class="cz-out">{T.zoomOut}</span>
        </label>
      </div>
      <figcaption class="border-t border-niebla bg-lino px-4 py-2 text-[0.7rem] text-piedra-suave">{T.mapCredit}</figcaption>
    </figure>

    {/* Leyenda: al lado del mapa en pantalla ancha, debajo en el móvil. */}
    <aside class="calma-leyenda rounded-2xl border border-niebla bg-arena/40 p-5 lg:w-64 lg:shrink-0">
      <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">{T.legendTitle}</h3>
      <ul class="mt-4 space-y-2.5">
        {BANDS.map((b) => (
          <li class="flex items-start gap-2.5">
            <span class="mt-1 h-3 w-3 shrink-0 rounded-full" style={`background:${FILL[b]}`} aria-hidden="true"></span>
            <span class="min-w-0 text-sm leading-tight text-piedra">
              <span class="block font-medium text-tinta">{T.abrigo[b]}</span>
              <span class="text-xs text-piedra-suave">{T.subAbrigo[b]}</span>
            </span>
          </li>
        ))}
        <li class="flex items-start gap-2.5">
          <span class="mt-1 h-3 w-3 shrink-0 rounded-full" style={`background:${FILL["sin-dato"]}`} aria-hidden="true"></span>
          <span class="min-w-0 text-sm leading-tight">
            <span class="block font-medium text-tinta">{T.legendGris}</span>
            <span class="text-xs text-piedra-suave">{T.abrigo["sin-dato"]}</span>
          </span>
        </li>
      </ul>
      <div class="mt-4 space-y-2 border-t border-niebla pt-4 text-xs leading-relaxed text-piedra-suave">
        <p>{T.legendCosta}</p>
        <p>{T.legendPuntos}</p>
        <p>{T.legendHilo}</p>
        <p>{T.legendNeutro}</p>
      </div>
    </aside>
    </div>

    {/* Lista accesible — versión canónica del parte (la que cita la IA).
        Pulsar una fila resalta esa cala en el mapa (lo gestiona el JS de abajo). */}
    {/* La lista, en rejilla: los mismos datos de siempre, pero en dos o tres columnas.
        De 75 fichas apiladas a 25 filas. Cada ficha sigue siendo un <li> con su id,
        su color y sus datos (es la versión canónica del parte, la que cita la IA). */}
    <ol class="calma-lista mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {parte.calas.map((c) => {
        const f0 = F0cala[c.id];
        const b0 = f0.band;
        return (
        <li
          id={`cala-${c.id}`}
          data-calma={b0}
          data-nombre={c.name}
          class="cursor-pointer rounded-xl border border-niebla bg-lino p-3.5 transition-colors hover:border-arcilla"
          style={`border-left:4px solid ${FILL[b0]}`}
        >
          <h3 class="font-display text-base leading-tight text-tinta">
            {c.lugarSlug ? (
              <a class="underline decoration-niebla underline-offset-4 hover:decoration-terracota" href={placeUrl(locale, `${c.lugarSlug}-${locale}`)} data-umami-event="calma-cala-ficha">{c.name}</a>
            ) : c.name}
          </h3>
          <p class="mt-1 flex items-center gap-1.5 text-xs font-semibold text-tinta">
            <span class="cala-dot inline-block h-2.5 w-2.5 shrink-0 rounded-full" style={`background:${FILL[b0]}`}></span>
            <span class="cala-band">{T.abrigo[b0]}</span>
          </p>
          <p class="mt-1 text-xs leading-snug text-piedra-suave">
            {c.area} · <span class="cala-sub">{T.subAbrigo[b0]}</span><br />
            {T.viento}: <span class="cala-wind">{f0.windName} {f0.windKmh} km/h</span>
          </p>
          <button type="button" class="cala-ver mt-1.5 text-xs font-medium text-arcilla underline underline-offset-2 hover:text-terracota" data-umami-event="calma-ver-mapa">{T.verEnMapa} ↑</button>
          {MEDUSAS_ENABLED && c.medusas && (
            <details class="mt-3 border-t border-niebla pt-3">
              <summary class="cursor-pointer text-sm text-piedra-suave hover:text-piedra" data-umami-event="calma-condiciones">{T.waterCond} →</summary>
              <div class="mt-2 rounded-md bg-arena/50 p-3">
                <p class="text-[0.7rem] font-semibold uppercase tracking-wider text-oro">{T.medusasSublabel}</p>
                <p class="mt-1 text-sm text-piedra">
                  {c.medusas.band === "sin-dato" ? (
                    T.medusasNoData
                  ) : (
                    <Fragment><strong class="text-tinta">{T.medusasBand[c.medusas.band]}.</strong> {T.medusasCopy[c.medusas.band]}</Fragment>
                  )}
                </p>
                <p class="mt-2 text-xs leading-relaxed text-piedra-suave">{T.medusasDisclaimer}</p>
                <p class="mt-2 text-sm">
                  <a class="font-medium text-arcilla underline underline-offset-2 hover:text-terracota" href={MEDUSAPP} target="_blank" rel="noopener" data-umami-event="calma-medusas-app">{T.medusasCTA} →</a>
                </p>
              </div>
            </details>
          )}
          {/* Aviso de seguridad, comprimido a una etiqueta para que la lista no se
              alargue. El texto entero sigue en el HTML (title + solo-lectores): lo lee
              el lector de pantalla, lo cita la IA, y se ve al posar el ratón. */}
          {!c.tieneVigilancia && (
            <p class="cala-aviso mt-2" title={T.noLifeguard}>
              <span aria-hidden="true" set:html={UI_ICON_AVISO} />
              <span>{T.noLifeguardShort}</span>
              <span class="sr-only">{T.noLifeguard}</span>
            </p>
          )}
        </li>
        );
      })}
    </ol>
  </div>

  {/* Descargo + nota de método */}
  <div class="mt-10 rounded-xl border border-niebla bg-arena/60 p-5">
    <h2 class="font-display text-lg text-tinta">{T.disclaimerTitle}</h2>
    <p class="mt-2 text-sm leading-relaxed text-piedra">{T.disclaimer}</p>
    <p class="mt-3 text-sm">
      <a class="font-medium text-arcilla underline underline-offset-2 hover:text-terracota" href={T.methodologyHref} data-umami-event="calma-metodologia">{T.methodology} →</a>
    </p>
  </div>

  <JsonLd schema={jsonLd} />
</section>

<script>
  // Buscador de calas: filtra a la vez la lista y los marcadores del mapa por nombre.
  // Único JS de cliente de esta página; sin él, se ven todas (degradación elegante).
  const inp = document.getElementById("calma-buscar") as HTMLInputElement | null;
  if (inp) {
    const sinAcentos = new RegExp("[\\u0300-\\u036f]", "g");
    const norm = (s: string | null) => (s || "").normalize("NFD").replace(sinAcentos, "").toLowerCase();
    const els = Array.from(document.querySelectorAll("[data-nombre]"));
    inp.addEventListener("input", () => {
      const q = norm(inp.value.trim());
      for (const el of els) {
        const hit = !q || norm(el.getAttribute("data-nombre")).includes(q);
        el.classList.toggle("cala-no-coincide", !hit);
      }
    });
  }

  // "Ver en el mapa": pulsar una fila (o su botón) resalta esa cala en el mapa y
  // sube hasta él. Los enlaces internos (nombre → ficha) siguen navegando normal.
  const lista = document.querySelector(".calma-lista");
  const mapa = document.querySelector(".calma-mapa");
  if (lista) {
    lista.addEventListener("click", (e) => {
      const target = e.target as HTMLElement | null;
      if (!target || target.closest("a")) return;
      const li = target.closest("li[id^='cala-']");
      if (!li) return;
      const id = li.id.slice(5);
      for (const a of document.querySelectorAll("a.cala-activa")) a.classList.remove("cala-activa");
      const mk = document.querySelector('a[href="#cala-' + id + '"]');
      if (mk) mk.classList.add("cala-activa");
      if (mapa) mapa.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  }

  // Línea temporal: al deslizar la barra, recalcula el mar de cada cala (misma
  // fórmula que el parte), la lista, el viento general y los contadores del filtro.
  const dataEl = document.getElementById("calma-tl-data");
  if (dataEl) {
    // Tipado laxo a propósito: D es el JSON del parte (estructura del build).
    const D: any = JSON.parse(dataEl.textContent || "{}");
    const frames: any[] = D.frames || [];
    const degDe = (d: string | null | undefined) => (!d || d === "C" ? null : (D.dirDeg[d] ?? null));
    const nombreV = (deg: number) => { for (const [m, n] of D.vientos) if (deg < m) return n; return D.vientos[0][1]; };
    const banda = (op: number, d: string | null | undefined, v: number) => {
      const deg = degDe(d);
      const on = deg == null ? 0 : (1 + Math.cos(((deg - op) * Math.PI) / 180)) / 2;
      const s = 1 - on * Math.min(v / D.vmax, 1);
      return s >= 0.66 ? "alto" : s >= 0.4 ? "medio" : "bajo";
    };
    /* La COSTA PINTADA se rehace con el día que se elija: misma fórmula que las calas
       (solo cambia la entrada: la orientación del tramo en vez de la de la cala) y la
       misma salvaguarda —si el tramo contradice de plano a la cala que tiene al lado
       (puertos, rías), va en neutro y manda el punto. */
    const zonasG = document.querySelector(".calma-zonas");
    const ESC: Record<string, number> = { bajo: 0, medio: 1, alto: 2 };
    const pintarZonas = (fr: any) => {
      const Z = D.zonas;
      if (!zonasG || !Z) return;
      const bandas = Z.pts.map((_: any, i: number) => {
        const c = D.calas[Z.cala[i]];
        const w = c ? fr.winds[c.ine] : null;
        if (!c || !w || w.d == null) return "sin-dato";
        const b = banda(Z.bear[i], w.d, w.v);
        const bCala = banda(c.op, w.d, w.v);
        return Math.abs((ESC[b] ?? 0) - (ESC[bCala] ?? 0)) >= 2 ? "sin-dato" : b;
      });
      let html = "", ini = 0;
      for (let i = 1; i <= bandas.length; i++) {
        if (i === bandas.length || bandas[i] !== bandas[ini]) {
          const pts = Z.pts.slice(ini, Math.min(i + 1, Z.pts.length));
          if (pts.length > 1) {
            const d = "M " + pts.map((p: number[]) => p[0] + " " + p[1]).join(" L ");
            html += '<path d="' + d + '" stroke="' + D.fill[bandas[ini]] + '"></path>';
          }
          ini = i;
        }
      }
      zonasG.innerHTML = html;
    };

    const windName = document.getElementById("calma-wind-name");
    const windKmh = document.getElementById("calma-wind-kmh");
    const windDial = document.getElementById("calma-wind-dial");
    const frameLabel = document.getElementById("calma-frame-label");
    const skyIcon = document.getElementById("calma-sky-icon");
    const skyLabel = document.getElementById("calma-sky-label");
    const tempEl = document.getElementById("calma-temp");

    // "Ahora" en hora de Menorca (Europe/Madrid), no la del visitante europeo.
    const madrid = (dt: Date) => {
      const p = new Intl.DateTimeFormat("en-GB", { timeZone: "Europe/Madrid", year: "numeric", month: "2-digit", day: "2-digit", hour: "2-digit", hourCycle: "h23" }).formatToParts(dt);
      const g = (t: string) => (p.find((x) => x.type === t) || ({} as Intl.DateTimeFormatPart)).value;
      return { date: g("year") + "-" + g("month") + "-" + g("day"), hour: g("hour") };
    };
    const mNow = madrid(new Date());
    const tomM = new Date(Date.parse(mNow.date + "T00:00:00Z") + 86400000).toISOString().slice(0, 10);
    // Día RELATIVO recalculado con la fecha REAL de Menorca (no la congelada en el JSON):
    // corrige el desfase cuando el dato es de ayer o se cruza la medianoche.
    const dayLabelC = (f: string) => (f === mNow.date ? D.rel.hoy : f === tomM ? D.rel.manana : (D.dow || [])[new Date(f + "T12:00:00Z").getUTCDay()] || f);
    const dateLabelC = (f: string) => { const a = f.split("-"); return Number(a[2]) + " " + ((D.months || [])[Number(a[1]) - 1] || ""); };
    const periodLabelC = (p: string) => (D.periodo && D.periodo[p]) || p;
    // Solo hacia delante: descarta los frames de días YA pasados (hora de Menorca), por si
    // se abre la página un día después del último parte generado. Así HOY es siempre la
    // primera posición de la barra. Si todo fuese pasado, conserva lo que haya.
    const fut = frames.filter((f: any) => f.fecha >= mNow.date);
    const visFrames = fut.length ? fut : frames;
    // Reconstruye la fila de días bajo la barra con los días visibles y su fecha real.
    const dayRow = document.getElementById("calma-day-row");
    if (dayRow) {
      const fechas = [...new Set<string>(visFrames.map((f: any) => f.fecha))];
      dayRow.replaceChildren(...fechas.map((f) => {
        const sp = document.createElement("span");
        sp.className = "calma-day";
        sp.dataset.fecha = f;
        sp.textContent = dayLabelC(f);
        return sp;
      }));
    }

    const applyFrame = (fr: any) => {
      const counts: Record<string, number> = { alto: 0, medio: 0, bajo: 0 };
      for (const c of D.calas) {
        const w = fr.winds[c.ine];
        const sinDato = !w || w.d == null; // sin dato del municipio → NUNCA calma falsa
        const band = sinDato ? "sin-dato" : banda(c.op, w.d, w.v);
        if (band === "alto" || band === "medio" || band === "bajo") counts[band]++;
        const deg = sinDato ? null : degDe(w.d);
        const li = document.getElementById("cala-" + c.id);
        if (li) {
          li.dataset.calma = band;
          li.style.borderLeftColor = D.fill[band];
          const dot = li.querySelector<HTMLElement>(".cala-dot"); if (dot) dot.style.background = D.fill[band];
          const bl = li.querySelector(".cala-band"); if (bl) bl.textContent = D.bandLabel[band];
          const sb = li.querySelector(".cala-sub"); if (sb) sb.textContent = D.subLabel[band];
          const wd = li.querySelector(".cala-wind"); if (wd) wd.textContent = sinDato ? D.bandLabel["sin-dato"] : ((deg == null ? D.calma : nombreV(deg)) + " " + w.v + " km/h");
        }
        const mk = document.querySelector<HTMLElement>('a[href="#cala-' + c.id + '"]');
        if (mk) {
          mk.dataset.calma = band;
          // OJO: el primer <circle> del marcador es la diana invisible. Hay que pintar
          // el punto de verdad (y su hilo a la orilla, si lo tiene).
          const ci = mk.querySelector(".cala-punto"); if (ci) ci.setAttribute("fill", D.fill[band]);
          const hl = mk.querySelector(".cala-hilo"); if (hl) hl.setAttribute("stroke", D.fill[band]);
        }
      }
      pintarZonas(fr); // la costa pintada también cambia con el día elegido
      if (windName) windName.textContent = fr.rep.name;
      if (windKmh) windKmh.textContent = fr.rep.kmh;
      if (windDial) windDial.setAttribute("transform", "translate(34,34) rotate(" + fr.rep.deg + ")");
      // Cielo + temperatura (general de la isla) para este frame. Si falta el dato de
      // cielo, conserva el último icono y solo refresca la temperatura.
      if (tempEl) tempEl.textContent = fr.temp != null ? fr.temp : "—";
      if (fr.sky && D.skyIcon && D.skyIcon[fr.sky]) {
        if (skyIcon) skyIcon.innerHTML = D.skyIcon[fr.sky];
        if (skyLabel) skyLabel.textContent = (D.skyLabel && D.skyLabel[fr.sky]) || "";
      }
      for (const b of ["alto", "medio", "bajo"]) {
        const cs = document.getElementById("calma-count-" + b); if (cs) cs.textContent = "(" + counts[b] + ")";
        const r = document.getElementById("calma-" + b) as HTMLInputElement | null;
        if (r) { r.disabled = counts[b] === 0; if (counts[b] === 0 && r.checked) { r.checked = false; const t = document.getElementById("calma-todas") as HTMLInputElement | null; if (t) t.checked = true; } }
      }
      if (frameLabel) frameLabel.textContent = dayLabelC(fr.fecha) + ", " + dateLabelC(fr.fecha) + " · " + periodLabelC(fr.period);
      // Resalta en la fila de días el rótulo del frame seleccionado ("el día de la barra").
      if (dayRow) for (const sp of dayRow.querySelectorAll<HTMLElement>(".calma-day")) sp.classList.toggle("calma-day-activa", sp.dataset.fecha === fr.fecha);
    };

    if (visFrames.length) {
      // Sitúa la barra en el frame de "ahora" dentro de los días visibles (= HOY o después).
      const nowKey = mNow.date + "-" + mNow.hour;
      let idx = 0;
      for (let i = 0; i < visFrames.length; i++) {
        const fk = visFrames[i].fecha + "-" + String(visFrames[i].startHour).padStart(2, "0");
        if (fk <= nowKey) idx = i;
      }
      const slider = document.getElementById("calma-tiempo") as HTMLInputElement | null;
      if (slider) {
        slider.max = String(visFrames.length - 1);
        slider.value = String(idx);
        // Medición: un único evento la primera vez que el visitante mueve la línea de
        // días (señal de "está usando de verdad la herramienta", sin spam por cada input).
        let diaTrackeado = false;
        slider.addEventListener("input", () => {
          applyFrame(visFrames[+slider.value]);
          if (!diaTrackeado) {
            diaTrackeado = true;
            (window as any).umami?.track?.("calma-dia");
          }
        });
      }
      applyFrame(visFrames[idx]);

      // Aviso de datos obsoletos: si la previsión degradó o el dato ya no alcanza a hoy
      // (el primer frame del parte quedó por detrás del día actual en hora de Menorca).
      const staleEl = document.getElementById("calma-stale");
      if (staleEl && (D.stale || (frames[0] && frames[0].fecha < mNow.date))) staleEl.classList.remove("hidden");
    }
  }
</script>
