---
/**
 * Logo de Calma Society: sol cálido sobre olas serenas (calma · sol · mar).
 * Marca + texto. Usa `markOnly` para mostrar solo el símbolo.
 */
import { SITE } from "../config/site";

interface Props {
  class?: string;
  markOnly?: boolean;
}
const { class: className, markOnly = false } = Astro.props;
---

<span class:list={["inline-flex items-center gap-2.5", className]}>
  <svg
    class="h-8 w-8 shrink-0"
    viewBox="0 0 64 64"
    fill="none"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="logoOro" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#d9c293"></stop>
        <stop offset="1" stop-color="#a8895c"></stop>
      </linearGradient>
    </defs>
    <!-- Sol con rayos (oro) -->
    <g stroke="#a8895c" stroke-width="1.1" stroke-linecap="round">
      <line x1="43" y1="26" x2="48.5" y2="26"></line>
      <line x1="41.53" y1="20.5" x2="47.16" y2="17.25"></line>
      <line x1="37.5" y1="16.47" x2="40" y2="12.14"></line>
      <line x1="32" y1="15" x2="32" y2="8"></line>
      <line x1="26.5" y1="16.47" x2="23.75" y2="11.71"></line>
      <line x1="22.47" y1="20.5" x2="17.28" y2="17.5"></line>
      <line x1="21" y1="26" x2="15.5" y2="26"></line>
      <line x1="22.47" y1="31.5" x2="18.58" y2="33.75"></line>
      <line x1="26.5" y1="35.53" x2="24.5" y2="38.99"></line>
      <line x1="37.5" y1="35.53" x2="39.75" y2="39.42"></line>
      <line x1="41.53" y1="31.5" x2="46.72" y2="34.5"></line>
    </g>
    <circle cx="32" cy="26" r="9.5" fill="url(#logoOro)"></circle>
    <!-- Olas (terracota, reflejo del sol) -->
    <path d="M12 45 Q22 41 32 45 Q42 41 52 45" stroke="#c2724e" stroke-width="2.8" stroke-linecap="round"></path>
    <path d="M12 50 Q22 46 32 50 Q42 46 52 50" stroke="#9a5238" stroke-width="2.8" stroke-linecap="round"></path>
  </svg>
  {
    !markOnly && (
      <span class="font-display text-xl leading-none tracking-tight text-tinta sm:text-2xl">
        {SITE.name}
      </span>
    )
  }
</span>
