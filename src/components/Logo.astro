---
/**
 * Logo de Calma Society: sol cálido sobre olas serenas (calma · sol · mar).
 * Marca + texto. Usa `markOnly` para mostrar solo el símbolo.
 */
import { SITE } from "../config/site";

interface Props {
  class?: string;
  markOnly?: boolean;
}
const { class: className, markOnly = false } = Astro.props;
---

<span class:list={["inline-flex items-center gap-2.5", className]}>
  <svg
    class="h-7 w-7 shrink-0"
    viewBox="0 0 40 40"
    fill="none"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Sol -->
    <circle cx="20" cy="15" r="7" fill="#a8895c" />
    <!-- Olas -->
    <path
      d="M5 27 q5 -2.6 10 0 t10 0 t10 0"
      stroke="#1e5566"
      stroke-width="2.2"
      stroke-linecap="round"
    />
    <path
      d="M5 32.5 q5 -2.6 10 0 t10 0 t10 0"
      stroke="#1e5566"
      stroke-width="2.2"
      stroke-linecap="round"
    />
  </svg>
  {
    !markOnly && (
      <span class="font-display text-xl leading-none tracking-tight text-tinta sm:text-2xl">
        {SITE.name}
      </span>
    )
  }
</span>
