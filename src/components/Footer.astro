---
// Pie de página: marca, secciones, enlaces "más", redes y avisos legales.
import { SITE, type Locale } from "../config/site";
import { menorcaBusUrl } from "../lib/links";
import { SECTIONS } from "../config/sections";
import { useTranslations } from "../i18n/ui";
import { currentLocale, placesIndexPath } from "../i18n/utils";
import Logo from "./Logo.astro";

const locale = currentLocale(Astro.url.pathname);
const t = useTranslations(locale);
const year = new Date().getFullYear();
const igUrl = SITE.social.instagram;

// Enlaces del pie por idioma (mismas claves para los 3 locales).
const FOOTER: Record<
  Locale,
  {
    about: string;
    newsletter: string;
    contact: string;
    calma: string;
    calmaLabel: string;
    transfers: string;
    legal: { label: string; href: string }[];
  }
> = {
  es: {
    about: "/quienes-somos", newsletter: "/newsletter", contact: "/contacto",
    calma: "/donde-el-mar-esta-en-calma", calmaLabel: "Dónde el mar está en calma",
    transfers: "Transfers y excursiones ↗",
    legal: [
      { label: "Aviso legal", href: "/aviso-legal" },
      { label: "Privacidad", href: "/privacidad" },
      { label: "Cookies", href: "/cookies" },
    ],
  },
  en: {
    about: "/en/about", newsletter: "/en/newsletter", contact: "/en/contact",
    calma: "/en/where-the-sea-is-calm", calmaLabel: "Where the sea is calm",
    transfers: "Transfers & excursions ↗",
    legal: [
      { label: "Legal notice", href: "/en/legal-notice" },
      { label: "Privacy", href: "/en/privacy" },
      { label: "Cookies", href: "/en/cookies" },
    ],
  },
  fr: {
    about: "/fr/qui-sommes-nous", newsletter: "/fr/newsletter", contact: "/fr/contact",
    calma: "/fr/ou-la-mer-est-calme", calmaLabel: "Où la mer est calme",
    transfers: "Transferts & excursions ↗",
    legal: [
      { label: "Mentions légales", href: "/fr/mentions-legales" },
      { label: "Confidentialité", href: "/fr/confidentialite" },
      { label: "Cookies", href: "/fr/cookies" },
    ],
  },
};
const f = FOOTER[locale];
const legalLinks = f.legal;
---

<footer class="mt-24 border-t border-niebla bg-arena/40">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <div class="lg:col-span-2">
        <Logo />
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-piedra-suave">
          {t("footer.about")}
        </p>
      </div>

      <!-- Secciones -->
      <nav aria-label={t("footer.sections")}>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">
          {t("footer.sections")}
        </h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            SECTIONS.map((s) => (
              <li>
                <a href={s.href[locale]} class="text-piedra transition-colors hover:text-terracota">
                  {s.label[locale]}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Más + Redes -->
      <div class="space-y-8">
        <nav aria-label={t("footer.more")}>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">
            {t("footer.more")}
          </h2>
          <ul class="mt-4 space-y-2 text-sm">
            {/* Índice de lugares: desde el pie es alcanzable en TODA la web, que
                es lo que rescata a las ~300 fichas de ser huérfanas (lib/places.ts). */}
            <li>
              <a href={placesIndexPath(locale)} class="text-piedra transition-colors hover:text-terracota">
                {t("places.all")}
              </a>
            </li>
            {
              f.calma && (
                <li>
                  <a href={f.calma} class="text-piedra transition-colors hover:text-terracota">
                    {f.calmaLabel}
                  </a>
                </li>
              )
            }
            <li>
              <a href={f.about} class="text-piedra transition-colors hover:text-terracota">
                {t("nav.about")}
              </a>
            </li>
            {
              SITE.newsletter.enabled && (
                <li>
                  <a href={f.newsletter} class="text-piedra transition-colors hover:text-terracota">
                    {t("nav.newsletter")}
                  </a>
                </li>
              )
            }
            <li>
              <a href={f.contact} class="text-piedra transition-colors hover:text-terracota">
                {t("nav.contact")}
              </a>
            </li>
            <li>
              <a
                href={menorcaBusUrl("footer")}
                rel="sponsored noopener"
                target="_blank"
                data-umami-event="footer-menorcabus"
                class="text-piedra transition-colors hover:text-terracota"
              >
                {f.transfers}
              </a>
            </li>
          </ul>
        </nav>

        {
          igUrl && (
            <div>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-oro">
                {t("footer.follow")}
              </h2>
              <ul class="mt-4 space-y-2 text-sm">
                <li>
                  <a href={igUrl} rel="me noopener" target="_blank" class="text-piedra transition-colors hover:text-terracota">
                    Instagram
                  </a>
                </li>
              </ul>
            </div>
          )
        }
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-3 border-t border-niebla pt-6 text-xs text-piedra-suave sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {SITE.name} · {SITE.company.legalName}. {t("footer.rights")}</p>
      <nav aria-label="Legal" class="flex flex-wrap gap-x-4 gap-y-1">
        {
          legalLinks.map((l) => (
            <a href={l.href} class="transition-colors hover:text-terracota">
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
