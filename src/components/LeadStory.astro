---
// Historia destacada (lead) — el ancla visual de la portada (Galería de Lino).
// Imagen en retrato editorial, velada hacia la paleta y SIN marco: el "marco"
// es el aire de lino que la rodea. Hover de luz lento, sin zoom.
import { srcset } from "../lib/img";
interface Props {
  kicker?: string;
  title: string;
  excerpt?: string;
  href: string;
  cta?: string;
  image?: string;
  imageAlt?: string;
}
const { kicker, title, excerpt, href, cta, image, imageAlt } = Astro.props;
---

<article class="group relative grid items-center gap-8 md:grid-cols-2 md:gap-12">
  <a href={href} class="relative block overflow-hidden" tabindex="-1" aria-hidden="true">
    {
      image ? (
        <img
          src={image}
          srcset={srcset(image)}
          sizes="(min-width: 768px) 50vw, 100vw"
          alt={imageAlt ?? ""}
          width="1600"
          height="2000"
          class="img-calma aspect-[4/5] w-full object-cover md:aspect-[5/6]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="aspect-[4/5] w-full bg-gradient-to-br from-niebla via-arena to-niebla md:aspect-[5/6]" />
      )
    }
    {/* Velo cálido (unifica el stock) + aclarado de luz lento en hover. */}
    <span
      class="pointer-events-none absolute inset-0 bg-arcilla/10 mix-blend-multiply"
      aria-hidden="true"
    />
    <span
      class="pointer-events-none absolute inset-0 bg-lino/0 transition-colors duration-700 ease-out group-hover:bg-lino/8"
      aria-hidden="true"
    />
  </a>

  <div>
    {
      kicker && (
        <p class="border-t border-oro-vivo/40 pt-6 text-xs font-semibold uppercase tracking-[0.25em] text-oro">
          {kicker}
        </p>
      )
    }
    <h2 class="mt-3 font-display text-3xl leading-tight text-tinta sm:text-4xl md:text-5xl">
      <a href={href} class="transition-colors after:absolute after:inset-0 group-hover:text-terracota">
        {title}
      </a>
    </h2>
    {
      excerpt && (
        <p class="mt-4 max-w-prosa text-base leading-relaxed text-piedra-suave sm:text-lg">
          {excerpt}
        </p>
      )
    }
    {
      cta && (
        <span class="mt-6 inline-block border-b border-terracota pb-0.5 text-sm font-medium text-arcilla">
          {cta} →
        </span>
      )
    }
  </div>
</article>
