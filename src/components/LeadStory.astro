---
// Historia destacada (lead) — el ancla visual editorial de la portada.
// Imagen grande + titular generoso. Si no hay foto, muestra un degradado sobrio.
import { srcset } from "../lib/img";
interface Props {
  kicker?: string;
  title: string;
  excerpt?: string;
  href: string;
  cta?: string;
  image?: string;
  imageAlt?: string;
}
const { kicker, title, excerpt, href, cta, image, imageAlt } = Astro.props;
---

<article class="group relative grid items-center gap-8 md:grid-cols-2 md:gap-12">
  <a href={href} class="block overflow-hidden rounded-xl" tabindex="-1" aria-hidden="true">
    {
      image ? (
        <img
          src={image}
          srcset={srcset(image)}
          sizes="(min-width: 768px) 45vw, 100vw"
          alt={imageAlt ?? ""}
          width="1600"
          height="1280"
          class="aspect-[5/4] w-full object-cover transition-transform duration-700 group-hover:scale-[1.02] md:aspect-[4/3]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="aspect-[5/4] w-full bg-gradient-to-br from-niebla via-arena to-niebla transition-transform duration-700 group-hover:scale-[1.02] md:aspect-[4/3]" />
      )
    }
  </a>

  <div>
    {
      kicker && (
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
          {kicker}
        </p>
      )
    }
    <h2 class="mt-3 font-display text-3xl leading-tight text-tinta sm:text-4xl md:text-5xl">
      <a href={href} class="transition-colors after:absolute after:inset-0 group-hover:text-mar">
        {title}
      </a>
    </h2>
    {
      excerpt && (
        <p class="mt-4 max-w-prosa text-base leading-relaxed text-piedra-suave sm:text-lg">
          {excerpt}
        </p>
      )
    }
    {
      cta && (
        <span class="mt-6 inline-block border-b border-mar pb-0.5 text-sm font-medium text-mar">
          {cta} →
        </span>
      )
    }
  </div>
</article>
