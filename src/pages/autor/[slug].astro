---
// Autor en español: /autor/[slug]
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AuthorView from "../../components/AuthorView.astro";
import { authorUrl } from "../../i18n/utils";

export async function getStaticPaths() {
  const authors = await getCollection("autores");
  return authors.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const alternates = { es: authorUrl("es", entry.id), en: authorUrl("en", entry.id) };
---

<BaseLayout title={entry.data.name} description={entry.data.bio.es} locale="es" alternates={alternates}>
  <AuthorView entry={entry} locale="es" />
</BaseLayout>
