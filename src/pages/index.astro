---
// Home en español (raíz). Contenido real de las colecciones (solo published).
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import LeadStory from "../components/LeadStory.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EventCard from "../components/EventCard.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import { SITE } from "../config/site";
import { getSection, SECTIONS } from "../config/sections";
import { useTranslations } from "../i18n/ui";
import { getArticles, getFeaturedArticle, getEvents } from "../lib/content";
import { articleUrl } from "../i18n/utils";

const locale = "es";
const t = useTranslations(locale);

const lead = await getFeaturedArticle(locale);
const rest = (await getArticles(locale))
  .filter((a) => a.id !== lead?.id)
  .slice(0, 3);
const events = (await getEvents(locale)).slice(0, 3);

const sectionLabel = (key: string) => getSection(key)?.label[locale];
---

<BaseLayout title="Inicio" locale="es">
  <Hero
    eyebrow={`${SITE.name} · ${SITE.edition}`}
    title={t("home.hero.title")}
    subtitle={t("home.hero.subtitle")}
    image="/uploads/menorca-hero.webp"
    imageAlt="Aguas turquesas y barcos en una cala de Menorca."
  />

  {
    lead && (
      <section class="mx-auto max-w-6xl px-5 pt-14 pb-4 sm:px-8 sm:pt-20">
        <LeadStory
          kicker={sectionLabel(lead.data.section)}
          title={lead.data.title}
          excerpt={lead.data.excerpt}
          href={articleUrl(locale, lead.id)}
          cta={t("home.readmore")}
          image={lead.data.heroImage}
          imageAlt={lead.data.heroImageAlt}
        />
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl px-5 sm:px-8">
        <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
          {t("home.featured")}
        </h2>
        <div class="mt-8 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((a) => (
            <ArticleCard
              kicker={sectionLabel(a.data.section)}
              title={a.data.title}
              excerpt={a.data.excerpt}
              href={articleUrl(locale, a.id)}
              image={a.data.heroImage}
              imageAlt={a.data.heroImageAlt}
            />
          ))}
        </div>
      </section>
    )
  }

  {
    events.length > 0 && (
      <section class="mx-auto mt-20 max-w-3xl px-5 sm:px-8">
        <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
          {t("home.agenda")}
        </h2>
        <div class="mt-2">
          {events.map((e) => (
            <EventCard event={e} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  <section class="mx-auto mt-24 max-w-6xl px-5 sm:px-8">
    <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
      {t("home.explore")}
    </h2>
    <p class="mt-3 text-piedra-suave">{t("home.sections.intro")}</p>
    <div class="mt-8 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        SECTIONS.map((s) => (
          <a href={s.href[locale]} class="group block border-t border-niebla pt-5">
            <h3 class="font-display text-xl text-tinta transition-colors group-hover:text-terracota">
              {s.label[locale]}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{s.intro[locale]}</p>
            <span class="mt-3 inline-block text-xs font-semibold uppercase tracking-widest text-oro transition-colors group-hover:text-terracota">
              {t("common.viewall")} →
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Cómo moverse por la isla (transfers y excursiones · Menorca Bus) -->
  <section class="mt-24">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <div class="rounded-2xl border border-niebla bg-arena/50 p-8 sm:p-12">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Cómo moverse</p>
        <h2 class="mt-3 font-display text-2xl text-tinta sm:text-3xl">Recorre la isla sin conducir</h2>
        <p class="mt-3 max-w-prosa text-piedra-suave">
          Del aeropuerto al hotel, a las calas o de excursión por faros y pueblos: transfers y
          minibús privado con conductor para vivir Menorca con calma.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/articulo/moverse-por-menorca"
            data-umami-event="home-guia-movilidad"
            class="rounded-md bg-arcilla px-5 py-2.5 text-sm font-semibold text-lino transition-colors hover:bg-tinta"
          >
            Guía de movilidad →
          </a>
          <a
            href={SITE.partners.menorcaBus.url}
            target="_blank"
            rel="noopener"
            data-umami-event="home-reserva-menorcabus"
            class="rounded-md border border-arcilla px-5 py-2.5 text-sm font-semibold text-arcilla transition-colors hover:bg-arcilla hover:text-lino"
          >
            Reserva con Menorca Bus →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-24 bg-arcilla">
    <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:px-8">
      <p class="font-display text-2xl leading-relaxed text-lino sm:text-3xl">
        {t("home.manifesto")}
      </p>
      <a
        href="/quienes-somos"
        class="mt-8 inline-block rounded-full border border-lino/40 px-6 py-2.5 text-sm font-semibold uppercase tracking-widest text-lino transition-colors hover:bg-lino hover:text-arcilla"
      >
        {t("home.manifesto.cta")}
      </a>
    </div>
  </section>

  <NewsletterSignup />
</BaseLayout>
