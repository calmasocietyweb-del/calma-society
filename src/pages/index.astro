---
// Home en español (raíz). Contenido real de las colecciones (solo published).
// Portada CURADA: lidera con calas/playas/naturaleza (Descubrir); la gastronomía
// vive en la rejilla de secciones, al final (menos rotación en portada).
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import LeadStory from "../components/LeadStory.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EventCard from "../components/EventCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import { SITE } from "../config/site";
import { menorcaBusUrl } from "../lib/links";
import MenorcaBusPromo from "../components/MenorcaBusPromo.astro";
import { getSection } from "../config/sections";
import { useTranslations } from "../i18n/ui";
import { getArticlesBySection, getFeaturedArticle, getEvents } from "../lib/content";
import { articleUrl, homePath } from "../i18n/utils";

const locale = "es";
const t = useTranslations(locale);
const lm = SITE.newsletter.leadMagnet;

// Imagen LCP del hero (única fuente): se usa en <Hero> y se PRECARGA en BaseLayout.
const heroImage = "/uploads/navegar-menorca.webp";
// Capamos el hero a 960w en móvil (va detrás de un velo → sin pérdida visible) para
// bajar el LCP; debe ir IGUAL en <Hero sizes> y en <BaseLayout heroImageSizes>.
const heroSizes = "(max-width: 768px) 300px, 100vw";

// Lead = artículo destacado (hoy, "Las mejores calas"). Banda Descubrir =
// el resto de calas/playas/naturaleza.
const lead = await getFeaturedArticle(locale);
const discover = (await getArticlesBySection(locale, "descubrir"))
  .filter((a) => a.id !== lead?.id)
  .slice(0, 5);
const events = (await getEvents(locale)).slice(0, 3);

// Orden de secciones en portada: calas/práctica primero; gastronomía al final.
const HOME_SECTION_ORDER = ["descubrir", "practica", "agenda", "cultura", "vivir", "comer-y-beber"];
const homeSections = HOME_SECTION_ORDER.map((k) => getSection(k)).filter(
  (s): s is NonNullable<ReturnType<typeof getSection>> => Boolean(s),
);

const sectionLabel = (key: string) => getSection(key)?.label[locale];

// Ritmo editorial asimétrico de la banda Descubrir: 2 piezas grandes (media
// columna; la primera más alta) + una fila de 3 medianas. Solo si hay piezas
// suficientes; si no, rejilla uniforme (fallback). Toda la lógica vive aquí,
// en el frontmatter → cero JavaScript de cliente.
const asymDiscover = discover.length >= 5;
const discoverGridClass = asymDiscover
  ? "mt-10 grid gap-x-10 gap-y-16 sm:grid-cols-6"
  : "mt-10 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3";
const discoverCard = (i: number) =>
  !asymDiscover
    ? { col: "", aspect: "aspect-[4/5]", sizes: "(min-width: 640px) 45vw, 100vw" }
    : i < 2
      ? {
          col: "sm:col-span-3",
          aspect: i === 0 ? "aspect-[3/4]" : "aspect-[4/5]",
          sizes: "(min-width: 640px) 50vw, 100vw",
        }
      : {
          col: "sm:col-span-2",
          aspect: "aspect-[4/5]",
          sizes: "(min-width: 640px) 33vw, 100vw",
        };

const description =
  "Calma Society — la revista de Menorca con mirada de lujo tranquilo: calas y playas con criterio, naturaleza, cultura y cómo vivir la isla sin prisa.";
---

<BaseLayout
  title="Inicio"
  description={description}
  locale="es"
  alternates={{ es: homePath("es"), en: homePath("en"), fr: homePath("fr") }}
  heroImage={heroImage}
  heroImageAvif
  heroImageSizes={heroSizes}
>
  <Hero
    eyebrow={`${SITE.name} · ${SITE.edition}`}
    title={t("home.hero.title")}
    subtitle={t("home.hero.subtitle")}
    image={heroImage}
    avif
    sizes={heroSizes}
    imageAlt="Velero fondeado en una cala de aguas turquesa bajo acantilados dorados en Menorca."
  />

  {
    lead && (
      <section class="reveal mx-auto max-w-6xl px-5 pt-16 pb-4 sm:px-8 sm:pt-24">
        <LeadStory
          kicker={sectionLabel(lead.data.section)}
          title={lead.data.title}
          excerpt={lead.data.excerpt}
          href={articleUrl(locale, lead.id)}
          cta={t("home.readmore")}
          image={lead.data.heroImage}
          imageAlt={lead.data.heroImageAlt}
        />
      </section>
    )
  }

  {
    discover.length > 0 && (
      <section class="mx-auto mt-20 max-w-6xl px-5 sm:mt-28 sm:px-8">
        <SectionHeading
          number="01"
          eyebrow={t("home.discover.eyebrow")}
          title={t("home.discover.title")}
          href="/descubrir"
          viewAll={t("common.viewall")}
        />
        <div class={discoverGridClass}>
          {discover.map((a, i) => {
            const c = discoverCard(i);
            return (
              <div class={c.col}>
                <ArticleCard
                  animate
                  kicker={sectionLabel(a.data.section)}
                  title={a.data.title}
                  excerpt={a.data.excerpt}
                  href={articleUrl(locale, a.id)}
                  image={a.data.heroImage}
                  imageAlt={a.data.heroImageAlt}
                  aspectClass={c.aspect}
                  sizes={c.sizes}
                />
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Imán de captación: la guía de las calas tranquilas (solo cuando está vivo) */}
  {
    lm.enabled && (
      <section class="mx-auto mt-20 max-w-6xl px-5 sm:mt-28 sm:px-8">
        <div class="reveal border border-niebla bg-arena/40 p-8 sm:p-12">
          <span class="mb-5 block h-px w-10 bg-oro-vivo/60" aria-hidden="true" />
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Guía gratuita</p>
          <h2 class="mt-3 font-display text-2xl text-tinta sm:text-3xl">
            La guía de las calas tranquilas
          </h2>
          <p class="mt-3 max-w-prosa text-piedra-suave">
            Menorca guarda calas que, a la hora justa, siguen siendo tuyas. Te contamos
            cuáles, cuándo ir y cómo llegar — y te escribimos de vez en cuando, sin ruido.
          </p>
          <div class="mt-6">
            <a
              href={lm.paths.es}
              data-umami-event="leadmagnet-home"
              class="press rounded-md bg-arcilla px-5 py-2.5 text-sm font-semibold text-lino no-underline hover:bg-tinta"
            >
              Unirme a la Sociedad <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>
    )
  }

  {/* Cómo moverse por la isla (transfers y excursiones · Menorca Bus) */}
  <section class="mt-20 sm:mt-28">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <div class="reveal border border-niebla bg-arena/40 p-8 sm:p-12">
        {/* Filete dorado corto: el gesto-firma de la marca (mismo del hero),
            en lugar de la barra lateral gruesa. */}
        <span class="mb-5 block h-px w-10 bg-oro-vivo/60" aria-hidden="true"></span>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Cómo moverse</p>
        <h2 class="mt-3 font-display text-2xl text-tinta sm:text-3xl">Recorre la isla sin coche</h2>
        <p class="mt-3 max-w-prosa text-piedra-suave">
          Del aeropuerto al hotel, a las calas o de excursión por faros y pueblos: transfers y
          minibús privado con conductor para vivir Menorca con calma.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={menorcaBusUrl("home")}
            target="_blank"
            rel="sponsored noopener"
            data-umami-event="home-reserva-menorcabus"
            class="press rounded-md bg-arcilla px-5 py-2.5 text-sm font-semibold text-lino no-underline hover:bg-tinta"
          >
            Reserva con Menorca Bus <span class="cta-arrow" aria-hidden="true">↗</span>
          </a>
          <a
            href="/articulo/moverse-por-menorca"
            data-umami-event="home-guia-movilidad"
            class="press rounded-md border border-arcilla px-5 py-2.5 text-sm font-semibold text-arcilla no-underline hover:bg-arcilla hover:text-lino"
          >
            Guía de movilidad <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <MenorcaBusPromo locale="es" tone="light" class="mt-4" />
      </div>
    </div>
  </section>

  {
    events.length > 0 && (
      <section class="mx-auto mt-20 max-w-6xl px-5 sm:mt-28 sm:px-8">
        <SectionHeading
          number="02"
          eyebrow={t("home.agenda.eyebrow")}
          title={t("home.agenda")}
          href="/agenda"
          viewAll={t("common.viewall")}
        />
        <div class="mt-10 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {events.map((e) => (
            <EventCard event={e} locale={locale} animate />
          ))}
        </div>
      </section>
    )
  }

  <section class="mx-auto mt-20 max-w-6xl px-5 sm:mt-28 sm:px-8">
    <SectionHeading number="03" eyebrow={t("home.explore.eyebrow")} title={t("home.explore")} />
    <p class="reveal mt-5 max-w-prosa text-piedra-suave">{t("home.sections.intro")}</p>
    <div class="reveal mt-10 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        homeSections.map((s) => (
          <a href={s.href[locale]} class="group block border-t border-niebla pt-5">
            <h3 class="font-display text-xl text-tinta transition-colors group-hover:text-terracota">
              {s.label[locale]}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{s.intro[locale]}</p>
            <span class="mt-3 inline-block text-xs font-semibold uppercase tracking-widest text-oro transition-colors group-hover:text-terracota">
              {t("common.viewall")} <span class="cta-arrow" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="relative mt-24 overflow-hidden bg-arcilla sm:mt-28">
    {/* Marca de agua: el símbolo de la marca (sol + olas), muy tenue, como sello
        de cabecera de una publicación de lujo. */}
    <svg
      aria-hidden="true"
      viewBox="0 0 64 64"
      fill="none"
      class="pointer-events-none absolute -right-16 top-1/2 h-[26rem] w-[26rem] -translate-y-1/2 text-champan/[0.05] sm:h-[34rem] sm:w-[34rem]"
    >
      <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round">
        <line x1="43" y1="26" x2="48.5" y2="26" /><line x1="41.53" y1="20.5" x2="47.16" y2="17.25" /><line
          x1="37.5"
          y1="16.47"
          x2="40"
          y2="12.14"
        /><line x1="32" y1="15" x2="32" y2="8" /><line x1="26.5" y1="16.47" x2="23.75" y2="11.71" /><line
          x1="22.47"
          y1="20.5"
          x2="17.28"
          y2="17.5"
        /><line x1="21" y1="26" x2="15.5" y2="26" /><line x1="22.47" y1="31.5" x2="18.58" y2="33.75" /><line
          x1="26.5"
          y1="35.53"
          x2="24.5"
          y2="38.99"
        /><line x1="37.5" y1="35.53" x2="39.75" y2="39.42" /><line x1="41.53" y1="31.5" x2="46.72" y2="34.5" />
      </g>
      <circle cx="32" cy="26" r="9.5" fill="currentColor" />
      <path d="M12 45 Q22 41 32 45 Q42 41 52 45" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" />
      <path d="M12 50 Q22 46 32 50 Q42 46 52 50" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" />
    </svg>
    <div class="reveal relative mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 sm:py-24">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-champan">{SITE.name}</p>
      <p class="mt-5 font-display text-2xl leading-relaxed text-lino sm:text-3xl">
        {t("home.manifesto")}
      </p>
      <a
        href="/quienes-somos"
        class="press mt-8 inline-block rounded-full bg-lino px-6 py-2.5 text-sm font-semibold uppercase tracking-widest text-arcilla hover:bg-arena"
      >
        {t("home.manifesto.cta")}
      </a>
    </div>
  </section>

  <NewsletterSignup />
</BaseLayout>
