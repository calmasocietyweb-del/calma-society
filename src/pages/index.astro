---
// Home en español (raíz). Contenido real de las colecciones (solo published).
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import LeadStory from "../components/LeadStory.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EventCard from "../components/EventCard.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import { SITE } from "../config/site";
import { getSection } from "../config/sections";
import { useTranslations } from "../i18n/ui";
import { getArticles, getFeaturedArticle, getEvents } from "../lib/content";
import { articleUrl } from "../i18n/utils";

const locale = "es";
const t = useTranslations(locale);

const lead = await getFeaturedArticle(locale);
const rest = (await getArticles(locale))
  .filter((a) => a.id !== lead?.id)
  .slice(0, 3);
const events = (await getEvents(locale)).slice(0, 3);

const sectionLabel = (key: string) => getSection(key)?.label[locale];
---

<BaseLayout title="Inicio" locale="es">
  <Hero
    eyebrow={`${SITE.name} · ${SITE.edition}`}
    title={t("home.hero.title")}
    subtitle={t("home.hero.subtitle")}
    image="/uploads/menorca-hero.webp"
    imageAlt="Aguas turquesas y barcos en una cala de Menorca."
  />

  {
    lead && (
      <section class="mx-auto max-w-6xl px-5 pb-4 sm:px-8">
        <LeadStory
          kicker={sectionLabel(lead.data.section)}
          title={lead.data.title}
          excerpt={lead.data.excerpt}
          href={articleUrl(locale, lead.id)}
          cta={t("home.readmore")}
          image={lead.data.heroImage}
          imageAlt={lead.data.heroImageAlt}
        />
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="mx-auto mt-16 max-w-6xl px-5 sm:px-8">
        <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
          {t("home.featured")}
        </h2>
        <div class="mt-8 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((a) => (
            <ArticleCard
              kicker={sectionLabel(a.data.section)}
              title={a.data.title}
              excerpt={a.data.excerpt}
              href={articleUrl(locale, a.id)}
              image={a.data.heroImage}
              imageAlt={a.data.heroImageAlt}
            />
          ))}
        </div>
      </section>
    )
  }

  {
    events.length > 0 && (
      <section class="mx-auto mt-20 max-w-3xl px-5 sm:px-8">
        <h2 class="border-b border-niebla pb-3 font-display text-2xl text-tinta">
          {t("home.agenda")}
        </h2>
        <div class="mt-2">
          {events.map((e) => (
            <EventCard event={e} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  <div class="mt-24">
    <NewsletterSignup />
  </div>
</BaseLayout>
