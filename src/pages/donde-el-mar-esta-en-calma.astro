---
// "Dónde el mar está en calma" (ES) — parte diario de abrigo por cala.
import BaseLayout from "../layouts/BaseLayout.astro";
import ParteCalmaMap from "../components/ParteCalmaMap.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";

const alternates = {
  es: "/donde-el-mar-esta-en-calma",
  en: "/en/where-the-sea-is-calm",
  fr: "/fr/ou-la-mer-est-calme",
};
---

<BaseLayout
  title="Dónde el mar está en calma"
  description="El parte diario de las calas de Menorca: según el viento de hoy, dónde el mar queda más sereno para bañarse con calma. Estimación editorial, no aviso de seguridad."
  locale="es"
  alternates={alternates}
>
  <div class="mx-auto max-w-prosa px-5 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Calma Society · Menorca</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">Dónde el mar está en calma</h1>
    <p class="lead mt-5">
      El parte diario de las calas de Menorca: dónde el viento de hoy deja el agua serena
      para bañarse sin prisa.
    </p>
    <p class="mt-5 text-base leading-relaxed text-piedra-suave">
      En Menorca manda el viento. Cuando sopla la <strong>Tramuntana</strong> del norte, el sur
      respira en calma; cuando aprieta el sur, conviene mirar al norte. Cruzamos la previsión
      de viento con la orientación de cada cala para estimar su <strong>abrigo</strong> de hoy.
      No medimos la seguridad del baño: la calma del mar, sí.
    </p>
    <p class="mt-4 text-base leading-relaxed text-piedra-suave">
      Cubrimos <strong>75 calas y zonas de baño</strong> de toda la isla, y puedes ver la
      previsión para <strong>hoy y los próximos días</strong>. ¿Quieres saber cómo lo
      calculamos? Lo explicamos en
      <a class="text-arcilla underline decoration-niebla underline-offset-4 hover:decoration-terracota" href="/como-calculamos-la-calma">cómo calculamos la calma</a>.
    </p>
  </div>

  <div class="mt-10">
    <ParteCalmaMap locale="es" />
  </div>

  <NewsletterSignup variant="inline" origen="herramienta" umamiEvent="newsletter-submit-herramienta" />
</BaseLayout>
