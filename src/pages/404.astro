---
// Página 404 (se sirve para cualquier ruta no encontrada).
import BaseLayout from "../layouts/BaseLayout.astro";
---

{/* `alternates` explícitos: sin ellos, el selector de idioma intercambiaba el
    prefijo sobre /404/ y producía un enlace a /en/404/, que no existe. */}
<BaseLayout title="404" description="Página no encontrada." locale="es" alternates={{ es: "/", en: "/en/" }}>
  <section class="mx-auto max-w-prosa px-5 py-28 text-center sm:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">404</p>
    <h1 class="mt-4 font-display text-4xl text-tinta sm:text-5xl">
      Esta página se perdió en alguna cala
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-piedra-suave">
      No encontramos lo que buscabas. Volvamos a tierra firme.
      <span class="block text-base text-piedra-suave">
        We couldn't find that page. Let's head back.
      </span>
    </p>
    <p class="mt-8 flex justify-center gap-6">
      <a href="/" class="border-b border-terracota pb-0.5 font-medium text-arcilla hover:text-terracota">
        Inicio →
      </a>
      <a href="/en/" class="border-b border-terracota pb-0.5 font-medium text-arcilla hover:text-terracota">
        English →
      </a>
    </p>
  </section>
</BaseLayout>
