---
/**
 * Reserva de transfer (v1, APAGADA tras SITE.bookings.enabled — spec
 * docs/superpowers/specs/2026-07-06-reservas-transfers-design.md).
 * Calca la fórmula del panel de menorcabus.com en 3 secciones-paso
 * (la web es estática: un solo envío al final, sin JS de cliente).
 * Rediseño 2026-07-07 (KAN-63): formulario en tarjeta, pasos numerados,
 * campos con más contraste, hueco de precio por tarjeta (enchufe API).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../config/site";
import { VEHICLE_CATEGORIES, EXTRAS } from "../../lib/bookings/catalog";

const enabled = SITE.bookings.enabled;
const alternates = { es: "/reservar-traslado", en: "/en/book-transfer" };

// Campos: fondo lino (cálido) dentro de la tarjeta blanca → contraste claro.
const field =
  "mt-1 w-full rounded-lg border border-niebla bg-lino px-3.5 py-2.5 text-sm text-piedra placeholder:text-piedra-suave focus:border-terracota focus:outline-none";
const labelCls = "text-sm font-medium text-piedra";

// Reaseguros de confianza (fórmula de menorcabus.com, en clave de conversión).
const seals = [
  "Gestionado por Menorca Bus",
  "Conductores profesionales",
];

// Puntos habituales para el autocompletado de origen/destino (datalist nativo).
const puntos = [
  "Aeropuerto de Menorca (MAH)",
  "Puerto de Maó",
  "Puerto de Ciutadella",
  "Maó",
  "Ciutadella",
  "Alaior",
  "Es Mercadal",
  "Es Castell",
  "Sant Lluís",
  "Ferreries",
  "Fornells",
  "Cala en Porter",
  "Son Bou",
  "Cala Galdana",
  "Punta Prima",
  "Binibeca",
  "Arenal d'en Castell",
  "Son Parc",
];
---

<BaseLayout
  title="Reserva tu traslado en Menorca"
  description="Traslado privado o compartido en Menorca: aeropuerto, puerto y hotel, puerta a puerta y con precio cerrado."
  locale="es"
  alternates={alternates}
  noindex={!enabled}
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Menorca, puerta a puerta</p>
    <h1 class="mt-2 font-display text-4xl text-tinta">Reserva tu traslado</h1>
    <p class="mt-4 max-w-prosa text-piedra-suave">
      Cuéntanos el trayecto, elige el vehículo y deja tus datos. Menorca Bus te
      confirma disponibilidad y el precio cerrado por correo.
    </p>

    <!-- Reaseguros de confianza (arriba, para enganchar) -->
    <ul class="mt-6 flex flex-wrap gap-2 text-xs text-piedra">
      {seals.map((s) => (
        <li class="rounded-full bg-arena/70 px-3 py-1">{s}</li>
      ))}
    </ul>

    <!-- Datalist compartido por origen y destino -->
    <datalist id="puntos-menorca">
      {puntos.map((p) => <option value={p} />)}
    </datalist>

    <form method="POST" action="/api/reservas" class="mt-8 space-y-8 rounded-2xl border border-niebla bg-white p-6 shadow-sm sm:p-8">
      <input type="hidden" name="locale" value="es" />
      {/* Honeypot anti-spam: oculto para humanos, tentador para robots. */}
      <p class="hidden" aria-hidden="true">
        <label>No rellenes este campo <input type="text" name="web" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- PASO 1 · El trayecto -->
      <fieldset class="space-y-4">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">1</span>
          <span class="font-display text-xl text-tinta">El trayecto</span>
        </legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="origin" class={labelCls}>Origen *</label>
            <input id="origin" type="text" name="origin" required list="puntos-menorca" placeholder="Aeropuerto (MAH), puerto, hotel…" class={field} />
          </div>
          <div>
            <label for="destination" class={labelCls}>Destino *</label>
            <input id="destination" type="text" name="destination" required list="puntos-menorca" placeholder="Zona, hotel o dirección" class={field} />
          </div>
        </div>

        <fieldset>
          <legend class={labelCls}>Trayecto</legend>
          <div class="mt-1 flex flex-wrap gap-x-6 gap-y-2">
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida" checked class="accent-terracota" />
              Solo ida
            </label>
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida-vuelta" class="accent-terracota" />
              Ida y vuelta
            </label>
          </div>
        </fieldset>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pickup-date" class={labelCls}>Fecha de salida (o de llegada del vuelo) *</label>
            <input id="pickup-date" type="date" name="pickupDate" required class={field} />
          </div>
          <div>
            <label for="pickup-time" class={labelCls}>Hora de salida (o de llegada del vuelo) *</label>
            <input id="pickup-time" type="time" name="pickupTime" required class={field} />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="return-date" class={labelCls}>Fecha de regreso <span class="text-piedra-suave">— solo ida y vuelta</span></label>
            <input id="return-date" type="date" name="returnDate" class={field} />
          </div>
          <div>
            <label for="return-time" class={labelCls}>Hora de regreso <span class="text-piedra-suave">— solo ida y vuelta</span></label>
            <input id="return-time" type="time" name="returnTime" class={field} />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-4">
          <div class="sm:col-span-1">
            <label for="flight-number" class={labelCls}>Nº de vuelo</label>
            <input id="flight-number" type="text" name="flightNumber" placeholder="VY3715" class={field} />
          </div>
          <div>
            <label for="adults" class={labelCls}>Adultos *</label>
            <input id="adults" type="number" name="adults" min="1" max="50" value="1" required class={field} />
          </div>
          <div>
            <label for="children" class={labelCls}>Niños (2-11)</label>
            <input id="children" type="number" name="children" min="0" max="50" value="0" class={field} />
          </div>
          <div>
            <label for="infants" class={labelCls}>Bebés (0-2)</label>
            <input id="infants" type="number" name="infants" min="0" max="50" value="0" class={field} />
          </div>
        </div>
      </fieldset>

      <!-- PASO 2 · El vehículo (tarjetas radio, con hueco de precio: lo dicta la API) -->
      <fieldset class="space-y-4 border-t border-niebla pt-8">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">2</span>
          <span class="font-display text-xl text-tinta">El vehículo</span>
        </legend>
        <p class="text-sm text-piedra-suave">Sin sorpresas: Menorca Bus te confirma el <strong class="font-semibold text-piedra">precio cerrado</strong> por correo antes de nada.</p>
        <div class="space-y-3">
          {VEHICLE_CATEGORIES.map((c, i) => (
            <label class="press flex cursor-pointer gap-4 rounded-xl border border-niebla bg-lino/60 p-4 has-[:checked]:border-terracota has-[:checked]:bg-arena/50 has-[:checked]:ring-1 has-[:checked]:ring-terracota">
              <input type="radio" name="vehicleCategory" value={c.id} required checked={i === 0} class="mt-1 accent-terracota" />
              <span class="flex-1">
                <span class="flex items-start justify-between gap-3">
                  <span class="flex flex-wrap items-center gap-2">
                    <span class="font-display text-lg text-tinta">{c.name.es}</span>
                    <span class="rounded-full bg-arena px-2 py-0.5 text-xs font-semibold uppercase tracking-wider text-piedra">{c.badge.es}</span>
                  </span>
                  <span class="shrink-0 whitespace-nowrap text-right text-sm">
                    {c.price ? (
                      <span class="font-semibold text-arcilla">{c.price.es}</span>
                    ) : (
                      <span class="text-piedra-suave">Precio a confirmar</span>
                    )}
                  </span>
                </span>
                <span class="mt-1 block text-sm text-piedra-suave">{c.tagline.es}</span>
                <ul class="mt-2 list-disc pl-5 text-sm text-piedra-suave">
                  {c.points.es.map((p) => <li>{p}</li>)}
                </ul>
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- PASO 3 · Tus datos -->
      <fieldset class="space-y-4 border-t border-niebla pt-8">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">3</span>
          <span class="font-display text-xl text-tinta">Tus datos</span>
        </legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class={labelCls}>Nombre y apellidos *</label>
            <input id="name" type="text" name="name" required autocomplete="name" class={field} />
          </div>
          <div>
            <label for="company" class={labelCls}>Empresa</label>
            <input id="company" type="text" name="company" autocomplete="organization" class={field} />
          </div>
          <div>
            <label for="id-document" class={labelCls}>DNI/NIF o pasaporte *</label>
            <input id="id-document" type="text" name="idDocument" required class={field} />
          </div>
          <div>
            <label for="email" class={labelCls}>Correo electrónico *</label>
            <input id="email" type="email" name="email" required autocomplete="email" class={field} />
          </div>
          <div>
            <label for="phone" class={labelCls}>Teléfono móvil *</label>
            <input id="phone" type="tel" name="phone" required autocomplete="tel" class={field} />
          </div>
          <div>
            <label for="address" class={labelCls}>Dirección *</label>
            <input id="address" type="text" name="address" required autocomplete="street-address" class={field} />
          </div>
          <div>
            <label for="postal-code" class={labelCls}>Código postal *</label>
            <input id="postal-code" type="text" name="postalCode" required autocomplete="postal-code" class={field} />
          </div>
          <div>
            <label for="city" class={labelCls}>Ciudad *</label>
            <input id="city" type="text" name="city" required autocomplete="address-level2" class={field} />
          </div>
          <div>
            <label for="country" class={labelCls}>País *</label>
            <input id="country" type="text" name="country" required autocomplete="country-name" class={field} />
          </div>
          <div>
            <label for="coupon" class={labelCls}>Cupón <span class="text-piedra-suave">— p. ej. CALMASOCIETY</span></label>
            <input id="coupon" type="text" name="coupon" class={field} />
          </div>
        </div>

        <div>
          <label for="comments" class={labelCls}>Comentarios al conductor</label>
          <textarea id="comments" name="comments" rows="3" placeholder="Equipaje, horarios, necesidades especiales…" class={field}></textarea>
        </div>

        <div>
          <p class={labelCls}>Extras (unidades)</p>
          <div class="mt-1 grid gap-3 sm:grid-cols-2">
            {EXTRAS.map((e) => (
              <label class="flex items-center justify-between rounded-lg border border-niebla bg-lino/60 px-4 py-2.5">
                <span class="text-sm text-piedra">{e.name.es}</span>
                <input type="number" name={`extra-${e.id}`} min="0" max="9" value="0" class="w-16 rounded border border-niebla bg-white px-2 py-1 text-center text-sm" />
              </label>
            ))}
          </div>
        </div>

        <label class="flex items-start gap-3 text-sm text-piedra-suave">
          <input type="checkbox" name="marketingOptin" class="mt-0.5 accent-terracota" />
          Quiero recibir novedades y ofertas de Menorca Bus.
        </label>
        <label class="flex items-start gap-3 text-sm text-piedra">
          <input type="checkbox" name="terms" required class="mt-0.5 accent-terracota" />
          Acepto los términos y condiciones del servicio. *
        </label>
      </fieldset>

      <!-- CTA + reaseguro -->
      <div class="border-t border-niebla pt-6">
        <button type="submit" class="press w-full rounded-full bg-arcilla px-8 py-3.5 font-semibold text-crema hover:bg-terracota sm:w-auto">
          Solicitar reserva
        </button>
        <p class="mt-3 text-xs text-piedra-suave">
          Menorca Bus confirma disponibilidad y el precio cerrado por correo. Cancelación gratuita hasta 24 h antes. La categoría del vehículo es orientativa y puede variar según disponibilidad manteniendo el nivel reservado.
        </p>
      </div>
    </form>
  </section>
</BaseLayout>
