---
// Home in English (under the /en prefix).
// Sample homepage to showcase the design system (Phase 1).
// Real content arrives with the content collections (Phase 2/3).
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { SITE } from "../../config/site";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("en");

// SAMPLE content (design demonstration only; not real).
const sample = [
  {
    kicker: "Eat & Drink",
    title: "Table for two: Menorca's quiet fine dining",
    excerpt:
      "Chefs working with island produce, and tables you can count on one hand.",
  },
  {
    kicker: "Discover",
    title: "The northern coves that still keep their silence",
    excerpt:
      "How to get there, when to go, and why an early start pays off on the tramuntana coast.",
  },
  {
    kicker: "Living",
    title: "A restored stone house inland",
    excerpt:
      "Traditional Menorcan architecture, reinterpreted with calm and good taste.",
  },
];
---

<BaseLayout title="Home" locale="en">
  <Hero
    eyebrow={`${SITE.name} · ${SITE.edition}`}
    title={t("home.hero.title")}
    subtitle={t("home.hero.subtitle")}
  />

  <section class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex items-baseline justify-between border-b border-niebla pb-3">
      <h2 class="font-display text-2xl text-tinta">{t("home.featured")}</h2>
      <span class="text-[0.65rem] uppercase tracking-widest text-piedra-suave/70">
        {t("home.preview")}
      </span>
    </div>

    <div class="mt-8 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        sample.map((a) => (
          <ArticleCard
            kicker={a.kicker}
            title={a.title}
            excerpt={a.excerpt}
            href="#"
          />
        ))
      }
    </div>
  </section>

  <div class="mt-24">
    <NewsletterSignup />
  </div>
</BaseLayout>
