---
// Home in English (under the /en prefix).
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/ui";
import { SITE } from "../../config/site";

const t = useTranslations("en");
---

<BaseLayout title="Home" locale="en">
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#3FA7B5]">
      {SITE.name} · {SITE.edition}
    </p>
    <h1 class="mt-4 text-4xl font-semibold text-[#1C1B18] sm:text-5xl">
      {t("site.tagline")}
    </h1>
    <p class="mt-6 text-lg text-[#4A4A42]">
      {t("home.building")}
    </p>
    <p class="mt-12 text-sm">
      <a class="text-[#1E5F74] underline underline-offset-4" href="/">
        {t("lang.switch")}
      </a>
    </p>
  </main>
</BaseLayout>
