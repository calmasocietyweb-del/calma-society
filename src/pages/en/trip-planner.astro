---
// "Plan your trip to Menorca" (EN) — itinerary planner.
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlannerView from "../../components/PlannerView.astro";

const alternates = {
  es: "/planificador",
  en: "/en/trip-planner",
};
---

<BaseLayout
  title="Plan your trip to Menorca"
  description="Your day-by-day Menorca itinerary: tell us how you travel and we propose a plan chained by proximity, unhurried and with a quiet-luxury eye. Flexible to wind and bad weather."
  locale="en"
  alternates={alternates}
>
  <div class="mx-auto max-w-3xl px-5 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Calma Society · Menorca</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">Plan your trip to Menorca</h1>
    <p class="lead mt-5">
      A day-by-day guide, chained by proximity and unhurried: the island at your pace, with a
      quiet-luxury eye.
    </p>
    <p class="mt-5 text-base leading-relaxed text-piedra-suave">
      Menorca is a <strong>fishbone</strong>: everything hangs off the Maó–Ciutadella axis and the
      coves are side branches. The mistake is to zigzag. We propose a plan that groups by area,
      gets to the coves early, leaves room for the wind and keeps a plan-B for bad weather. You
      fine-tune it; the final call is always yours.
    </p>
  </div>

  <div class="mt-8">
    <PlannerView locale="en" />
  </div>
</BaseLayout>
