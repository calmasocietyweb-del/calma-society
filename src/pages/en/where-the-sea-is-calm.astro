---
// "Where the sea is calm" (EN) — daily shelter forecast per cove.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ParteCalmaMap from "../../components/ParteCalmaMap.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";

const alternates = {
  es: "/donde-el-mar-esta-en-calma",
  en: "/en/where-the-sea-is-calm",
};
---

<BaseLayout
  title="Where the sea is calm"
  description="The daily forecast for Menorca’s coves: where today’s wind leaves the sea calmest for an unhurried swim. An editorial estimate, not a safety notice."
  locale="en"
  alternates={alternates}
>
  <div class="mx-auto max-w-prosa px-5 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Calma Society · Menorca</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">Where the sea is calm</h1>
    <p class="lead mt-5">
      The daily forecast for Menorca’s coves: where today’s wind leaves the water serene
      for an unhurried swim.
    </p>
    <p class="mt-5 text-base leading-relaxed text-piedra-suave">
      On Menorca, the wind rules. When the <strong>Tramuntana</strong> blows from the north,
      the south coast lies calm; when the south wind picks up, look north. We cross the wind
      forecast with each cove’s orientation to estimate its <strong>shelter</strong> today.
      We don’t measure how safe the swim is — only how calm the sea should be.
    </p>
    <p class="mt-4 text-base leading-relaxed text-piedra-suave">
      We cover <strong>75 coves and swimming spots</strong> across the island, with the
      forecast for <strong>today and the coming days</strong>. Want to know how we work it
      out? We explain it in
      <a class="text-arcilla underline decoration-niebla underline-offset-4 hover:decoration-terracota" href="/en/how-we-calculate-calm">how we calculate calm</a>.
    </p>
  </div>

  <div class="mt-10">
    <ParteCalmaMap locale="en" />
  </div>

  <NewsletterSignup variant="inline" />
</BaseLayout>
