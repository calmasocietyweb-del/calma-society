---
// Contact (EN)
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("en");
const alternates = { es: "/contacto", en: "/en/contact", fr: "/fr/contact" };
---

<BaseLayout
  title="Contact us"
  description="Get in touch with Calma Society: stories, pitches and collaborations."
  locale="en"
  alternates={alternates}
>
  <section class="mx-auto max-w-prosa px-5 pb-8 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Calma Society</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">{t("nav.contact")}</h1>
    <p class="mt-5 text-lg leading-relaxed text-piedra-suave">{t("contact.lead")}</p>
    <div class="mt-10">
      <ContactForm />
    </div>
  </section>
</BaseLayout>
