---
// Landing of the "Menorca's quietest coves" lead magnet (EN) — KPI #1.
// Stays noindex and unlinked until SITE.newsletter.leadMagnet.enabled is true
// (PDF designed + MailerLite automation delivering the guide).
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { SITE } from "../../config/site";

const lm = SITE.newsletter.leadMagnet;
const alternates = { es: lm.paths.es, en: lm.paths.en };

const recibes = [
  {
    title: "Quiet coves and their best hour",
    text: "When each one is at its calmest —early morning, mid-afternoon— and when it's wiser not to turn up.",
  },
  {
    title: "How to get there on foot, by bus or car-free",
    text: "The path, the real walking distance, where you can actually park, and which coves are best reached without a car.",
  },
  {
    title: "The calendar of calm, month by month",
    text: "Which shores shelter from the Tramontana wind, and which ones come into their own in each season.",
  },
  {
    title: "The practical details that matter",
    text: "Shade, facilities, whether there's a beach bar or not — the small things that make the day.",
  },
];
---

<BaseLayout
  title="Menorca's quietest coves"
  description="A free, calm guide to finding the sea without the crowds in Menorca: which coves stay quiet, at what hour, how to get there car-free, and which winds leave them sheltered."
  locale="en"
  alternates={alternates}
  noindex={!lm.enabled}
>
  <section class="mx-auto max-w-prosa px-5 pt-12 text-center sm:px-8 sm:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
      Free guide · Calma Society
    </p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">
      Menorca's quietest coves
    </h1>
    <p class="lead mx-auto mt-5 max-w-xl">
      A calm guide to finding the sea without the crowds: where, when and how to get there.
    </p>
  </section>

  <section class="mx-auto mt-14 max-w-3xl px-5 sm:mt-20 sm:px-8">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.25em] text-oro">
      What you get
    </p>
    <div class="mt-8 grid gap-x-12 gap-y-9 sm:grid-cols-2">
      {
        recibes.map((it) => (
          <div class="border-t border-niebla pt-5">
            <h2 class="font-display text-xl text-tinta">{it.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-piedra-suave">{it.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <div class="mt-16 sm:mt-24">
    <NewsletterSignup
      variant="section"
      origen="lead-magnet"
      umamiEvent="newsletter-submit-lead-magnet"
      formId={lm.formIds.en}
      eyebrow="The guide, on us"
      title="Get Menorca's quietest coves"
      text="Leave your email and we'll send you the guide. After that, a calm letter now and then — judgement, not noise."
      cta="Get the guide"
    />
  </div>

  <section class="mx-auto max-w-prosa px-5 py-14 text-center sm:px-8">
    <p class="text-sm leading-relaxed text-piedra-suave">
      Behind this guide is the Calma Society editorial team, on the island all 365 days
      of the year — with judgement and first-hand.{" "}
      <a
        class="text-arcilla underline decoration-niebla underline-offset-4 hover:decoration-terracota"
        href="/en/about"
      >
        About us &amp; our editorial standards</a
      >.
    </p>
  </section>
</BaseLayout>
