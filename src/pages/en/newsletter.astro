---
// Dedicated newsletter page (EN). Capture = KPI #1 (CLAUDE.md §3.1).
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { SITE } from "../../config/site";

const alternates = { es: "/newsletter", en: "/en/newsletter", fr: "/fr/newsletter" };
const lm = SITE.newsletter.leadMagnet;

const benefits = [
  "A curated pick of the best of Menorca — with judgement, no filler.",
  "First-hand recommendations: calm coves, fine tables, a real what's-on.",
  "Stories from the island 365 days a year, off-season included.",
];
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to Calma Society: every fortnight, the best of Menorca through a quiet-luxury lens."
  locale="en"
  alternates={alternates}
>
  <section class="mx-auto max-w-prosa px-5 pt-12 text-center sm:px-8 sm:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Newsletter</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">
      The island, in your inbox
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-piedra-suave">
      Calma Society's asset isn't noise, it's trust. Join a community that prefers
      quality over quantity.
    </p>

    <ul class="mx-auto mt-8 max-w-md space-y-3 text-left">
      {
        benefits.map((b) => (
          <li class="flex gap-3 text-sm leading-relaxed text-piedra">
            <span aria-hidden="true" class="text-oro">—</span>
            <span>{b}</span>
          </li>
        ))
      }
    </ul>
  </section>

  {
    lm.enabled && (
      <section class="mx-auto mt-10 max-w-prosa px-5 sm:px-8">
        <div class="rounded-2xl border border-niebla bg-arena/50 px-6 py-8 text-center sm:px-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
            Welcome gift
          </p>
          <h2 class="mt-2 font-display text-2xl text-tinta">
            The guide to Menorca's quietest coves
          </h2>
          <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-piedra-suave">
            Join and you'll receive it as a welcome: the hour each cove stays calm, where to
            leave the car, which winds leave them sheltered and what to expect on arrival.
          </p>
          <a
            href={lm.paths.en}
            data-umami-event="leadmagnet-newsletter"
            class="mt-5 inline-block text-sm font-semibold text-arcilla underline decoration-niebla underline-offset-4 hover:decoration-terracota"
          >
            See what's in the guide →
          </a>
        </div>
      </section>
    )
  }

  {
    SITE.newsletter.enabled || SITE.newsletter.capture.enabled ? (
      <div class="mt-14">
        <NewsletterSignup />
      </div>
    ) : (
      <p class="mx-auto mt-12 max-w-prosa px-5 text-center text-piedra-suave sm:px-8">
        We're putting it together, calmly. <strong class="text-piedra">Very soon</strong> you'll be able to subscribe.
      </p>
    )
  }
</BaseLayout>
