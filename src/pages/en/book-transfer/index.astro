---
/**
 * Transfer booking (v1, OFF behind SITE.bookings.enabled — spec
 * docs/superpowers/specs/2026-07-06-reservas-transfers-design.md).
 * Mirrors the menorcabus.com panel in 3 step-sections (the site is static:
 * one submit at the end, no client JS). Redesign 2026-07-07 (KAN-63).
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";
import { VEHICLE_CATEGORIES, EXTRAS } from "../../../lib/bookings/catalog";

const enabled = SITE.bookings.enabled;
const alternates = { es: "/reservar-traslado", en: "/en/book-transfer" };

const field =
  "mt-1 w-full rounded-lg border border-niebla bg-lino px-3.5 py-2.5 text-sm text-piedra placeholder:text-piedra-suave focus:border-terracota focus:outline-none";
const labelCls = "text-sm font-medium text-piedra";

const seals = [
  "Handled by Menorca Bus",
  "24/7 support",
  "Flexible cancellation",
  "No payment upfront",
];

const puntos = [
  "Menorca Airport (MAH)",
  "Port of Maó",
  "Port of Ciutadella",
  "Maó",
  "Ciutadella",
  "Alaior",
  "Es Mercadal",
  "Es Castell",
  "Sant Lluís",
  "Ferreries",
  "Fornells",
  "Cala en Porter",
  "Son Bou",
  "Cala Galdana",
  "Punta Prima",
  "Binibeca",
  "Arenal d'en Castell",
  "Son Parc",
];
---

<BaseLayout
  title="Book your transfer in Menorca"
  description="Private or shared transfer in Menorca: airport, harbour and hotel, door to door and at a closed price."
  locale="en"
  alternates={alternates}
  noindex={!enabled}
>
  <section class="mx-auto max-w-3xl px-5 py-12 sm:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Menorca, door to door</p>
    <h1 class="mt-2 font-display text-4xl text-tinta">Book your transfer</h1>
    <p class="mt-4 max-w-prosa text-piedra-suave">
      Tell us the journey, choose the vehicle and leave your details. Menorca Bus
      confirms availability and the closed price by email: <strong class="font-semibold text-piedra">you pay nothing now</strong>.
    </p>

    <ul class="mt-6 flex flex-wrap gap-2 text-xs text-piedra">
      {seals.map((s) => (
        <li class="rounded-full bg-arena/70 px-3 py-1">{s}</li>
      ))}
    </ul>

    <datalist id="puntos-menorca">
      {puntos.map((p) => <option value={p} />)}
    </datalist>

    <form method="POST" action="/api/reservas" class="mt-8 space-y-8 rounded-2xl border border-niebla bg-white p-6 shadow-sm sm:p-8">
      <input type="hidden" name="locale" value="en" />
      {/* Anti-spam honeypot: hidden to humans, tempting to bots. */}
      <p class="hidden" aria-hidden="true">
        <label>Do not fill in this field <input type="text" name="web" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- STEP 1 · The journey -->
      <fieldset class="space-y-4">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">1</span>
          <span class="font-display text-xl text-tinta">The journey</span>
        </legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="origin" class={labelCls}>Origin *</label>
            <input id="origin" type="text" name="origin" required list="puntos-menorca" placeholder="Airport (MAH), harbour, hotel…" class={field} />
          </div>
          <div>
            <label for="destination" class={labelCls}>Destination *</label>
            <input id="destination" type="text" name="destination" required list="puntos-menorca" placeholder="Area, hotel or address" class={field} />
          </div>
        </div>

        <fieldset>
          <legend class={labelCls}>Journey</legend>
          <div class="mt-1 flex flex-wrap gap-x-6 gap-y-2">
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida" checked class="accent-terracota" />
              One way
            </label>
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida-vuelta" class="accent-terracota" />
              Return
            </label>
          </div>
        </fieldset>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pickup-date" class={labelCls}>Departure date (or flight arrival) *</label>
            <input id="pickup-date" type="date" name="pickupDate" required class={field} />
          </div>
          <div>
            <label for="pickup-time" class={labelCls}>Departure time (or flight arrival) *</label>
            <input id="pickup-time" type="time" name="pickupTime" required class={field} />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="return-date" class={labelCls}>Return date <span class="text-piedra-suave">— return trips only</span></label>
            <input id="return-date" type="date" name="returnDate" class={field} />
          </div>
          <div>
            <label for="return-time" class={labelCls}>Return time <span class="text-piedra-suave">— return trips only</span></label>
            <input id="return-time" type="time" name="returnTime" class={field} />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-4">
          <div class="sm:col-span-1">
            <label for="flight-number" class={labelCls}>Flight no.</label>
            <input id="flight-number" type="text" name="flightNumber" placeholder="VY3715" class={field} />
          </div>
          <div>
            <label for="adults" class={labelCls}>Adults *</label>
            <input id="adults" type="number" name="adults" min="1" max="50" value="1" required class={field} />
          </div>
          <div>
            <label for="children" class={labelCls}>Children (2-11)</label>
            <input id="children" type="number" name="children" min="0" max="50" value="0" class={field} />
          </div>
          <div>
            <label for="infants" class={labelCls}>Infants (0-2)</label>
            <input id="infants" type="number" name="infants" min="0" max="50" value="0" class={field} />
          </div>
        </div>
      </fieldset>

      <!-- STEP 2 · The vehicle (radio cards, with a price slot: set by the API) -->
      <fieldset class="space-y-4 border-t border-niebla pt-8">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">2</span>
          <span class="font-display text-xl text-tinta">The vehicle</span>
        </legend>
        <p class="text-sm text-piedra-suave">No surprises: Menorca Bus confirms the <strong class="font-semibold text-piedra">closed price</strong> by email before anything.</p>
        <div class="space-y-3">
          {VEHICLE_CATEGORIES.map((c, i) => (
            <label class="press flex cursor-pointer gap-4 rounded-xl border border-niebla bg-lino/60 p-4 has-[:checked]:border-terracota has-[:checked]:bg-arena/50 has-[:checked]:ring-1 has-[:checked]:ring-terracota">
              <input type="radio" name="vehicleCategory" value={c.id} required checked={i === 0} class="mt-1 accent-terracota" />
              <span class="flex-1">
                <span class="flex items-start justify-between gap-3">
                  <span class="flex flex-wrap items-center gap-2">
                    <span class="font-display text-lg text-tinta">{c.name.en}</span>
                    <span class="rounded-full bg-arena px-2 py-0.5 text-xs font-semibold uppercase tracking-wider text-piedra">{c.badge.en}</span>
                  </span>
                  <span class="shrink-0 whitespace-nowrap text-right text-sm">
                    {c.price ? (
                      <span class="font-semibold text-arcilla">{c.price.en}</span>
                    ) : (
                      <span class="text-piedra-suave">Price to confirm</span>
                    )}
                  </span>
                </span>
                <span class="mt-1 block text-sm text-piedra-suave">{c.tagline.en}</span>
                <ul class="mt-2 list-disc pl-5 text-sm text-piedra-suave">
                  {c.points.en.map((p) => <li>{p}</li>)}
                </ul>
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- STEP 3 · Your details -->
      <fieldset class="space-y-4 border-t border-niebla pt-8">
        <legend class="mb-1 flex items-center gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-arcilla font-display text-base text-crema">3</span>
          <span class="font-display text-xl text-tinta">Your details</span>
        </legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class={labelCls}>Full name *</label>
            <input id="name" type="text" name="name" required autocomplete="name" class={field} />
          </div>
          <div>
            <label for="company" class={labelCls}>Company</label>
            <input id="company" type="text" name="company" autocomplete="organization" class={field} />
          </div>
          <div>
            <label for="id-document" class={labelCls}>ID or passport *</label>
            <input id="id-document" type="text" name="idDocument" required class={field} />
          </div>
          <div>
            <label for="email" class={labelCls}>Email *</label>
            <input id="email" type="email" name="email" required autocomplete="email" class={field} />
          </div>
          <div>
            <label for="phone" class={labelCls}>Mobile phone *</label>
            <input id="phone" type="tel" name="phone" required autocomplete="tel" class={field} />
          </div>
          <div>
            <label for="address" class={labelCls}>Address *</label>
            <input id="address" type="text" name="address" required autocomplete="street-address" class={field} />
          </div>
          <div>
            <label for="postal-code" class={labelCls}>Postcode *</label>
            <input id="postal-code" type="text" name="postalCode" required autocomplete="postal-code" class={field} />
          </div>
          <div>
            <label for="city" class={labelCls}>City *</label>
            <input id="city" type="text" name="city" required autocomplete="address-level2" class={field} />
          </div>
          <div>
            <label for="country" class={labelCls}>Country *</label>
            <input id="country" type="text" name="country" required autocomplete="country-name" class={field} />
          </div>
          <div>
            <label for="coupon" class={labelCls}>Coupon <span class="text-piedra-suave">— e.g. CALMASOCIETY</span></label>
            <input id="coupon" type="text" name="coupon" class={field} />
          </div>
        </div>

        <div>
          <label for="comments" class={labelCls}>Comments to the driver</label>
          <textarea id="comments" name="comments" rows="3" placeholder="Luggage, timings, special needs…" class={field}></textarea>
        </div>

        <div>
          <p class={labelCls}>Extras (units)</p>
          <div class="mt-1 grid gap-3 sm:grid-cols-2">
            {EXTRAS.map((e) => (
              <label class="flex items-center justify-between rounded-lg border border-niebla bg-lino/60 px-4 py-2.5">
                <span class="text-sm text-piedra">{e.name.en}</span>
                <input type="number" name={`extra-${e.id}`} min="0" max="9" value="0" class="w-16 rounded border border-niebla bg-white px-2 py-1 text-center text-sm" />
              </label>
            ))}
          </div>
        </div>

        <label class="flex items-start gap-3 text-sm text-piedra-suave">
          <input type="checkbox" name="marketingOptin" class="mt-0.5 accent-terracota" />
          I'd like to receive news and offers from Menorca Bus.
        </label>
        <label class="flex items-start gap-3 text-sm text-piedra">
          <input type="checkbox" name="terms" required class="mt-0.5 accent-terracota" />
          I accept the service terms and conditions. *
        </label>
      </fieldset>

      <!-- CTA + reassurance -->
      <div class="border-t border-niebla pt-6">
        <button type="submit" class="press w-full rounded-full bg-arcilla px-8 py-3.5 font-semibold text-crema hover:bg-terracota sm:w-auto">
          Request booking
        </button>
        <p class="mt-3 text-xs text-piedra-suave">
          This is a <strong class="font-semibold text-piedra">no-obligation request</strong>: you don't pay now. Menorca Bus confirms availability and the price by email. Free cancellation up to 24 h before. The vehicle category is indicative and may vary with availability, keeping the class you booked.
        </p>
      </div>
    </form>
  </section>
</BaseLayout>
