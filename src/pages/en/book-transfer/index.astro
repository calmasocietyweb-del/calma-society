---
/**
 * Reserva de transfer (EN, v1 APAGADA tras SITE.bookings.enabled — spec
 * docs/superpowers/specs/2026-07-06-reservas-transfers-design.md).
 * Misma estructura y mismos `name` de campo que la versión ES: 3 secciones-paso
 * de la fórmula de menorcabus.com, un solo envío, sin JS de cliente.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";
import { VEHICLE_CATEGORIES, EXTRAS } from "../../../lib/bookings/catalog";

const enabled = SITE.bookings.enabled;
const alternates = { es: "/reservar-traslado", en: "/en/book-transfer" };

// Clase común de los campos de texto (misma casa que ContactForm).
const field =
  "mt-1 w-full rounded-md border border-niebla bg-lino/60 px-4 py-3 text-sm text-piedra focus-visible:outline-terracota";
const labelCls = "text-sm font-medium text-piedra";

// Sellos de confianza (fórmula de menorcabus.com).
const seals = [
  "Bookings handled by Menorca Bus",
  "24/7 support",
  "Flexible cancellation",
  "Professional drivers",
];
---

<BaseLayout
  title="Book your transfer in Menorca"
  description="Private or shared transfers in Menorca: airport, port and hotel, door to door and with a fixed price."
  locale="en"
  alternates={alternates}
  noindex={!enabled}
>
  <section class="mx-auto max-w-prosa px-5 py-12 sm:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Menorca, door to door</p>
    <h1 class="mt-2 font-display text-4xl text-tinta">Book your transfer</h1>
    <p class="mt-4 text-piedra-suave">
      Tell us the journey, choose your vehicle and leave your details: Menorca Bus
      will confirm the booking and the fixed price by email. No waiting, on your schedule.
    </p>

    <form method="POST" action="/api/reservas" class="mt-10 space-y-12">
      <input type="hidden" name="locale" value="en" />
      {/* Honeypot anti-spam: oculto para humanos, tentador para robots. */}
      <p class="hidden" aria-hidden="true">
        <label>Leave this field empty <input type="text" name="web" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- STEP 1 · The journey -->
      <fieldset class="space-y-4">
        <legend class="font-display text-2xl text-tinta">1 · The journey</legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="origin" class={labelCls}>Pick-up point *</label>
            <input
              id="origin"
              type="text"
              name="origin"
              required
              placeholder="Menorca Airport (MAH), port, hotel…"
              class={field}
            />
          </div>
          <div>
            <label for="destination" class={labelCls}>Destination *</label>
            <input
              id="destination"
              type="text"
              name="destination"
              required
              placeholder="Area, hotel or address"
              class={field}
            />
          </div>
        </div>

        <fieldset>
          <legend class={labelCls}>Journey type</legend>
          <div class="mt-1 flex flex-wrap gap-x-6 gap-y-2">
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida" checked class="accent-terracota" />
              One way
            </label>
            <label class="flex items-center gap-2 text-sm text-piedra">
              <input type="radio" name="tripType" value="ida-vuelta" class="accent-terracota" />
              Return trip
            </label>
          </div>
        </fieldset>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pickup-date" class={labelCls}>Departure date (or flight arrival date) *</label>
            <input id="pickup-date" type="date" name="pickupDate" required class={field} />
          </div>
          <div>
            <label for="pickup-time" class={labelCls}>Departure time (or flight arrival time) *</label>
            <input id="pickup-time" type="time" name="pickupTime" required class={field} />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="return-date" class={labelCls}>Return date — return trips only</label>
            <input id="return-date" type="date" name="returnDate" class={field} />
          </div>
          <div>
            <label for="return-time" class={labelCls}>Return time — return trips only</label>
            <input id="return-time" type="time" name="returnTime" class={field} />
          </div>
        </div>

        <div>
          <label for="flight-number" class={labelCls}>Flight number (if you arrive by plane)</label>
          <input id="flight-number" type="text" name="flightNumber" placeholder="VY3715" class={field} />
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="adults" class={labelCls}>Adults *</label>
            <input id="adults" type="number" name="adults" min="1" max="50" value="1" required class={field} />
          </div>
          <div>
            <label for="children" class={labelCls}>Children (ages 2-11)</label>
            <input id="children" type="number" name="children" min="0" max="50" value="0" class={field} />
          </div>
          <div>
            <label for="infants" class={labelCls}>Infants (ages 0-2)</label>
            <input id="infants" type="number" name="infants" min="0" max="50" value="0" class={field} />
          </div>
        </div>
      </fieldset>

      <!-- STEP 2 · The vehicle (radio cards, no prices: they arrive with the API) -->
      <fieldset class="space-y-4">
        <legend class="font-display text-2xl text-tinta">2 · The vehicle</legend>
        <p class="text-sm text-piedra-suave">Fixed price: Menorca Bus confirms it when validating your booking — no surprises.</p>
        {VEHICLE_CATEGORIES.map((c, i) => (
          <label class="flex cursor-pointer gap-4 rounded-xl border border-niebla bg-white p-5 has-[:checked]:border-terracota has-[:checked]:bg-arena/40">
            <input type="radio" name="vehicleCategory" value={c.id} required checked={i === 0} class="mt-1 accent-terracota" />
            <span>
              <span class="flex items-center gap-2">
                <span class="font-display text-lg text-tinta">{c.name.en}</span>
                <span class="rounded-full bg-arena px-2 py-0.5 text-xs font-semibold uppercase tracking-wider text-piedra">{c.badge.en}</span>
              </span>
              <span class="mt-1 block text-sm text-piedra-suave">{c.tagline.en}</span>
              <ul class="mt-2 list-disc pl-5 text-sm text-piedra-suave">
                {c.points.en.map((p) => <li>{p}</li>)}
              </ul>
            </span>
          </label>
        ))}
      </fieldset>

      <!-- STEP 3 · Your details -->
      <fieldset class="space-y-4">
        <legend class="font-display text-2xl text-tinta">3 · Your details</legend>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="name" class={labelCls}>Full name *</label>
            <input id="name" type="text" name="name" required autocomplete="name" class={field} />
          </div>
          <div>
            <label for="company" class={labelCls}>Company</label>
            <input id="company" type="text" name="company" autocomplete="organization" class={field} />
          </div>
          <div>
            <label for="id-document" class={labelCls}>ID card or passport *</label>
            <input id="id-document" type="text" name="idDocument" required class={field} />
          </div>
          <div>
            <label for="email" class={labelCls}>Email *</label>
            <input id="email" type="email" name="email" required autocomplete="email" class={field} />
          </div>
          <div>
            <label for="phone" class={labelCls}>Mobile phone *</label>
            <input id="phone" type="tel" name="phone" required autocomplete="tel" class={field} />
          </div>
          <div>
            <label for="address" class={labelCls}>Address *</label>
            <input id="address" type="text" name="address" required autocomplete="street-address" class={field} />
          </div>
          <div>
            <label for="postal-code" class={labelCls}>Postcode *</label>
            <input id="postal-code" type="text" name="postalCode" required autocomplete="postal-code" class={field} />
          </div>
          <div>
            <label for="city" class={labelCls}>City *</label>
            <input id="city" type="text" name="city" required autocomplete="address-level2" class={field} />
          </div>
          <div>
            <label for="country" class={labelCls}>Country *</label>
            <input id="country" type="text" name="country" required autocomplete="country-name" class={field} />
          </div>
          <div>
            <label for="coupon" class={labelCls}>Coupon — e.g. CALMASOCIETY</label>
            <input id="coupon" type="text" name="coupon" class={field} />
          </div>
          <div>
            <label for="pickup-time-requested" class={labelCls}>Preferred pick-up time</label>
            <input id="pickup-time-requested" type="time" name="pickupTimeRequested" class={field} />
          </div>
        </div>

        <div>
          <label for="comments" class={labelCls}>Notes for the driver</label>
          <textarea
            id="comments"
            name="comments"
            rows="4"
            placeholder="Anything the driver should know: luggage, timings, special needs…"
            class={field}></textarea>
        </div>

        <p class={labelCls}>Extras (units)</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {EXTRAS.map((e) => (
            <label class="flex items-center justify-between rounded-lg border border-niebla bg-white px-4 py-3">
              <span class="text-sm text-piedra">{e.name.en}</span>
              <input type="number" name={`extra-${e.id}`} min="0" max="9" value="0" class="w-16 rounded border border-niebla px-2 py-1 text-center" />
            </label>
          ))}
        </div>

        <label class="flex items-start gap-3 text-sm text-piedra-suave">
          <input type="checkbox" name="marketingOptin" class="mt-0.5 accent-terracota" />
          I would like to receive news and offers from Menorca Bus.
        </label>
        <label class="flex items-start gap-3 text-sm text-piedra">
          <input type="checkbox" name="terms" required class="mt-0.5 accent-terracota" />
          I accept the terms and conditions of the service. *
        </label>
        <p class="text-xs text-piedra-suave">Free cancellation up to 24 hours before the scheduled time. The vehicle category is indicative: it may vary subject to availability while keeping the level you booked.</p>
      </fieldset>

      <button type="submit" class="rounded-full bg-arcilla px-8 py-3 font-semibold text-crema hover:bg-terracota">
        Request booking
      </button>
    </form>

    <!-- Trust seals -->
    <ul class="mt-12 grid gap-3 border-t border-niebla pt-8 text-center text-sm text-piedra-suave sm:grid-cols-4">
      {seals.map((s) => <li class="rounded-lg bg-arena/60 px-3 py-2">{s}</li>)}
    </ul>
  </section>
</BaseLayout>
