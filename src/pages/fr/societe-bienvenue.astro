---
// Page de bienvenue après l'adhésion à la Société (FR). Cible du `_next` de Formspree
// une fois l'e-mail capturé. Non indexée (c'est une page de confirmation).
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("fr");
const alternates = { es: "/sociedad-bienvenida", en: "/en/society-welcome", fr: "/fr/societe-bienvenue" };
---

<BaseLayout
  title={t("thanks.title")}
  description={t("thanks.text")}
  locale="fr"
  alternates={alternates}
  noindex
>
  <section class="mx-auto max-w-prosa px-5 py-24 text-center sm:px-8 sm:py-32">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">
      {t("newsletter.eyebrow")}
    </p>
    <h1 class="mt-4 font-display text-4xl text-tinta sm:text-5xl">
      {t("thanks.title")}
    </h1>
    <p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-piedra-suave">
      {t("thanks.text")}
    </p>
    <a
      href="/fr"
      class="mt-10 inline-block rounded-md bg-arcilla px-6 py-3 text-sm font-semibold text-lino transition-colors hover:bg-tinta"
    >
      {t("thanks.back")}
    </a>
  </section>
</BaseLayout>
