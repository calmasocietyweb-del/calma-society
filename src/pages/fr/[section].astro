---
// Pages de rubrique en français: /fr/decouvrir, /fr/agenda, /fr/manger-et-boire, …
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionView from "../../components/SectionView.astro";
import { SECTIONS, getSection } from "../../config/sections";

export async function getStaticPaths() {
  return SECTIONS.map((s) => ({
    params: { section: s.href.fr.replace(/^\/fr\//, "") },
    props: { key: s.key },
  }));
}

const { key } = Astro.props;
const section = getSection(key)!;
const alternates = { es: section.href.es, en: section.href.en, fr: section.href.fr };
---

<BaseLayout
  title={section.label.fr}
  description={section.seoDescription?.fr ?? section.intro.fr}
  locale="fr"
  alternates={alternates}
>
  <SectionView sectionKey={key} locale="fr" />
</BaseLayout>
