---
// "Organiza tu viaje a Menorca" (ES) — planificador de itinerarios.
// SEO: además del plan interactivo (render en cliente, invisible a crawlers),
// la página publica itinerarios ESTÁTICOS de ejemplo y FAQ (PlannerSeoContent)
// apuntando a "qué hacer en Menorca", "itinerario Menorca", "Menorca en 5 días".
import BaseLayout from "../layouts/BaseLayout.astro";
import PlannerView from "../components/PlannerView.astro";
import PlannerSeoContent from "../components/PlannerSeoContent.astro";

const alternates = {
  es: "/planificador",
  en: "/en/trip-planner",
};
---

<BaseLayout
  title="Organiza tu viaje a Menorca: itinerarios de 3, 5 y 7 días"
  description="Qué hacer en Menorca, día a día: el planificador arma tu itinerario por cercanía y sin prisas — calas, mesas con criterio y plan-B si el tiempo se tuerce."
  locale="es"
  alternates={alternates}
>
  <div class="mx-auto max-w-3xl px-5 pt-12 sm:px-8 sm:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-oro">Calma Society · Menorca</p>
    <h1 class="mt-3 font-display text-4xl text-tinta sm:text-5xl">Organiza tu viaje a Menorca</h1>
    <p class="lead mt-5">
      Una guía día a día, encadenada por cercanía y sin prisas: la isla a tu ritmo, con
      criterio de lujo tranquilo.
    </p>
    <p class="mt-5 text-base leading-relaxed text-piedra-suave">
      Menorca es una <strong>espina de pez</strong>: todo cuelga del eje Maó–Ciutadella y las
      calas son ramales. El error es zigzaguear. Te proponemos un plan que agrupa por zonas,
      madruga a las calas, deja margen para el viento y reserva un plan-B para el mal tiempo.
      Tú lo ajustas; la decisión final siempre es tuya.
    </p>
  </div>

  <div class="mt-8">
    <PlannerView locale="es" />
  </div>

  {/* Itinerarios estáticos de ejemplo + FAQ (SEO/GEO: contenido real crawleable). */}
  <PlannerSeoContent locale="es" />
</BaseLayout>
