---
/**
 * Panel de analítica a medida (Umami).
 *
 * - SSR SOLO en Vercel (panel de edición): `prerender = false` cuando hay VERCEL.
 *   En Cloudflare/local se prerenderiza ESTÁTICO con un aviso (no llama a la API
 *   ni expone secretos), para NO romper la web pública estática.
 * - Protegido con auth básica (PANEL_USER / PANEL_PASS).
 * - Lee la API de Umami con variables de entorno SECRETAS (solo en Vercel):
 *     UMAMI_API_URL  (cloud: https://api.umami.is/v1 · self-host: https://tu-umami/api)
 *     UMAMI_API_KEY  (cloud: cabecera x-umami-api-key)
 *     UMAMI_WEBSITE_ID
 *     PANEL_USER, PANEL_PASS
 */
export const prerender = !process.env.VERCEL;
import "../../styles/global.css";
import { getCollection } from "astro:content";

const onVercel = !!process.env.VERCEL;

const USER = process.env.PANEL_USER ?? "";
const PASS = process.env.PANEL_PASS ?? "";

// Auth básica (solo cuando hay servidor en Vercel y credenciales definidas).
if (onVercel && USER && PASS) {
  const auth = Astro.request.headers.get("authorization") ?? "";
  const b64 = auth.startsWith("Basic ") ? auth.slice(6) : "";
  let ok = false;
  if (b64) {
    const [u, p] = atob(b64).split(":");
    ok = u === USER && p === PASS;
  }
  if (!ok) {
    return new Response("Autenticación requerida", {
      status: 401,
      headers: { "WWW-Authenticate": 'Basic realm="Panel Calma Society"' },
    });
  }
}

const API_URL = (process.env.UMAMI_API_URL ?? "https://api.umami.is/v1").replace(/\/$/, "");
const API_KEY = process.env.UMAMI_API_KEY ?? "";
const WEBSITE_ID = process.env.UMAMI_WEBSITE_ID ?? "";

const configured = onVercel && !!API_KEY && !!WEBSITE_ID && !!USER && !!PASS;
const rangeLabel = "Últimos 30 días";

let error: string | null = null;
let stats: any = null;
let topPages: any[] = [];
let events: any[] = [];
// ── Colaboradores (KAN-78) ───────────────────────────────────────────────────
// Clics salientes por negocio: los tres eventos de salida llevan el dato
// `negocio` (data-umami-event-negocio) y se leen por la API de event-data.
const SALIDA_EVENTS = ["click-salida-web", "planner-reserva", "planner-web-oficial"];
let allPages: any[] = []; // metrics?type=url con límite alto: las fichas son long-tail
let clicsNegocio: Record<string, number> = {};
let eventDataOk = false;

if (configured) {
  try {
    const end = Date.now();
    const start = end - 30 * 24 * 60 * 60 * 1000;
    const headers = { "x-umami-api-key": API_KEY, accept: "application/json" };
    const qs = `startAt=${start}&endAt=${end}`;
    const base = `${API_URL}/websites/${WEBSITE_ID}`;
    const [s, urls, ev, urlsAll] = await Promise.all([
      fetch(`${base}/stats?${qs}`, { headers }).then((r) => r.json()),
      fetch(`${base}/metrics?type=url&${qs}&limit=50`, { headers }).then((r) => r.json()),
      fetch(`${base}/metrics?type=event&${qs}&limit=100`, { headers }).then((r) => r.json()),
      fetch(`${base}/metrics?type=url&${qs}&limit=500`, { headers }).then((r) => r.json()),
    ]);
    stats = s;
    topPages = Array.isArray(urls) ? urls : [];
    events = Array.isArray(ev) ? ev : [];
    allPages = Array.isArray(urlsAll) ? urlsAll : [];

    // Valores de la propiedad `negocio` de cada evento de salida. Si el plan de
    // Umami no expone event-data, el bloque lo avisa y el total sigue visible
    // en «Clics en enlaces» (por nombre de evento).
    const vals = await Promise.all(
      SALIDA_EVENTS.map((name) =>
        fetch(`${base}/event-data/values?${qs}&eventName=${encodeURIComponent(name)}&propertyName=negocio`, { headers })
          .then((r) => (r.ok ? r.json() : null))
          .catch(() => null),
      ),
    );
    for (const lista of vals) {
      if (!Array.isArray(lista)) continue;
      eventDataOk = true;
      for (const row of lista) {
        const slug = String(row.value ?? row.x ?? "");
        const n = Number(row.total ?? row.y) || 0;
        if (slug) clicsNegocio[slug] = (clicsNegocio[slug] ?? 0) + n;
      }
    }
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const num = (v: any) => (v && typeof v === "object" ? (v.value ?? 0) : (v ?? 0));

// Herramientas interactivas: agrupamos VISITAS (por ruta, sumando idiomas) y sus
// EVENTOS clave, para ver de un vistazo si la gente las USA, no solo si las abre.
// Los nombres de evento coinciden con los data-umami-event puestos en cada componente.
const TOOLS: { label: string; paths: string[]; events: [string, string][] }[] = [
  {
    label: "Planificador de viajes",
    paths: ["/planificador", "/en/trip-planner"],
    events: [
      ["planner-ruta-dia", "Ver ruta del día"],
      ["planner-pdf", "Descargar PDF"],
      ["planner-email", "Enviar por email"],
      ["planner-copylink", "Copiar enlace"],
      ["planner-gmaps", "Abrir en Maps"],
      ["planner-reserva", "Clic a reservar"],
      ["planner-menorcabus", "Clic a Menorca Bus"],
      ["planner-mar-en-calma", "Saltar a Mar en calma"],
      ["planner-web-oficial", "Web oficial"],
    ],
  },
  {
    label: "Dónde el mar está en calma",
    paths: ["/donde-el-mar-esta-en-calma", "/en/where-the-sea-is-calm", "/fr/ou-la-mer-est-calme"],
    events: [
      ["calma-dia", "Mover la línea de días"],
      ["calma-cala-ficha", "Abrir ficha de cala"],
      ["calma-ver-mapa", "Ver cala en el mapa"],
      ["calma-metodologia", "Abrir metodología"],
      ["calma-condiciones", "Abrir posibilidad de medusas (ficha)"],
      ["calma-medusa", "Clic en una medusa del mapa"],
    ],
  },
  {
    label: "Atardeceres y copas",
    paths: ["/atardeceres-y-copas", "/en/sunsets-and-drinks", "/fr/couchers-et-cocktails"],
    events: [
      ["sunset-pin", "Clic en un punto del mapa"],
      ["sunset-punto", "Abrir un lugar"],
      ["sunset-maps", "Abrir en Maps"],
      ["cta-menorcabus-noche", "Clic a Menorca Bus"],
    ],
  },
];

const cleanPath = (u: any) => String(u ?? "").split("?")[0].split("#")[0].replace(/\/+$/, "") || "/";
const pageviewsFor = (paths: string[]) =>
  topPages.filter((p) => paths.includes(cleanPath(p.x))).reduce((n, p) => n + (Number(p.y) || 0), 0);
const eventCount = (name: string) => {
  const e = events.find((ev) => ev.x === name);
  return e ? Number(e.y) || 0 : 0;
};
const toolRows = TOOLS.map((t) => {
  const evs = t.events.map(([name, label]) => ({ name, label, count: eventCount(name) }));
  return {
    label: t.label,
    visitas: pageviewsFor(t.paths),
    interacciones: evs.reduce((n, e) => n + e.count, 0),
    evs,
  };
});

// ── Filas de «Colaboradores» ─────────────────────────────────────────────────
// Universo: fichas ES publicadas con web enlazada (lo que puede recibir un clic
// saliente). Los locales del mapa de copas sin ficha propia aparecen con su id
// en cuanto registran el primer clic. Visitas = suma de la ficha en ES+EN+FR.
const negociosRoster = configured
  ? await getCollection("lugares", (e) => e.data.lang === "es" && e.data.status === "published" && !!e.data.website)
  : [];
const FICHA_RE = /^\/(?:lugar|en\/place|fr\/lieu)\/(.+)-(?:es|en|fr)$/;
const fichaViews: Record<string, number> = {};
for (const p of allPages) {
  const m = cleanPath(p.x).match(FICHA_RE);
  if (m) fichaViews[m[1]] = (fichaViews[m[1]] ?? 0) + (Number(p.y) || 0);
}
const nombrePorSlug: Record<string, string> = {};
for (const e of negociosRoster) nombrePorSlug[e.id.replace(/-es$/, "")] = e.data.name;
const colabSlugs = [...new Set([...Object.keys(nombrePorSlug), ...Object.keys(clicsNegocio)])];
const colabRows = colabSlugs
  .map((slug) => ({
    slug,
    nombre: nombrePorSlug[slug] ?? slug,
    visitas: fichaViews[slug] ?? 0,
    clics: clicsNegocio[slug] ?? 0,
  }))
  .sort((a, b) => b.clics - a.clics || b.visitas - a.visitas || a.nombre.localeCompare(b.nombre));
const totalSalidas = SALIDA_EVENTS.reduce((n, name) => n + eventCount(name), 0);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel · Analítica — Calma Society</title>
  </head>
  <body class="bg-lino font-sans text-piedra antialiased">
    <main class="mx-auto max-w-4xl px-5 py-12 sm:px-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-oro">Calma Society · Panel</p>
      <h1 class="mt-2 font-display text-3xl text-tinta">Analítica</h1>

      {
        !onVercel && (
          <div class="mt-8 rounded-xl border border-niebla bg-arena/60 p-6">
            <p class="font-medium text-tinta">Este panel funciona en el entorno de edición.</p>
            <p class="mt-2 text-sm text-piedra-suave">
              La web pública es estática y no muestra datos aquí. Abre el panel desde el
              despliegue de edición (Vercel), donde está protegido con usuario y contraseña.
            </p>
          </div>
        )
      }

      {
        onVercel && !configured && (
          <div class="mt-8 rounded-xl border border-niebla bg-arena/60 p-6">
            <p class="font-medium text-tinta">Falta configurar la analítica.</p>
            <p class="mt-2 text-sm text-piedra-suave">
              Define en Vercel las variables de entorno <code>UMAMI_API_URL</code>,
              <code>UMAMI_API_KEY</code>, <code>UMAMI_WEBSITE_ID</code>, <code>PANEL_USER</code> y
              <code>PANEL_PASS</code>, y vuelve a desplegar.
            </p>
          </div>
        )
      }

      {
        onVercel && configured && (
          <div class="mt-8 space-y-10">
            {error && (
              <p class="rounded-md bg-terracota/10 p-4 text-sm text-terracota">
                No se pudo leer la API de Umami: {error}
              </p>
            )}

            <section>
              <h2 class="font-display text-xl text-tinta">
                Resumen <span class="text-sm font-normal text-piedra-suave">· {rangeLabel}</span>
              </h2>
              <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
                <div class="rounded-xl border border-niebla p-4">
                  <p class="text-2xl font-semibold text-tinta">{num(stats?.pageviews)}</p>
                  <p class="text-xs uppercase tracking-wide text-piedra-suave">Páginas vistas</p>
                </div>
                <div class="rounded-xl border border-niebla p-4">
                  <p class="text-2xl font-semibold text-tinta">{num(stats?.visitors)}</p>
                  <p class="text-xs uppercase tracking-wide text-piedra-suave">Visitantes</p>
                </div>
                <div class="rounded-xl border border-niebla p-4">
                  <p class="text-2xl font-semibold text-tinta">{num(stats?.visits)}</p>
                  <p class="text-xs uppercase tracking-wide text-piedra-suave">Visitas</p>
                </div>
                <div class="rounded-xl border border-niebla p-4">
                  <p class="text-2xl font-semibold text-tinta">{num(stats?.bounces)}</p>
                  <p class="text-xs uppercase tracking-wide text-piedra-suave">Rebotes</p>
                </div>
              </div>
            </section>

            <section>
              <h2 class="font-display text-xl text-tinta">Herramientas interactivas</h2>
              <p class="mt-1 text-sm text-piedra-suave">
                Por herramienta: cuántos la <strong class="text-piedra">abren</strong> (visitas) y
                cuántas veces la <strong class="text-piedra">usan</strong> por dentro (acciones). Con
                poco tráfico, fíjate en la proporción (p. ej. de 40 visitas, 6 descargas), no en el
                número absoluto. Un 0 en gris = esa acción aún no se ha registrado.
              </p>
              <div class="mt-4 space-y-4">
                {toolRows.map((t) => (
                  <div class="rounded-xl border border-niebla p-4">
                    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                      <h3 class="font-display text-lg text-tinta">{t.label}</h3>
                      <p class="text-sm text-piedra-suave">
                        <span class="font-semibold text-tinta">{t.visitas}</span> visitas
                        {" · "}
                        <span class="font-semibold text-tinta">{t.interacciones}</span> acciones
                      </p>
                    </div>
                    <ul class="mt-3 grid gap-x-6 gap-y-1 sm:grid-cols-2">
                      {t.evs.map((e) => (
                        <li class="flex items-center justify-between gap-3 text-sm">
                          <span class="text-piedra-suave">{e.label}</span>
                          <span class={e.count > 0 ? "font-semibold text-tinta" : "font-semibold text-niebla"}>
                            {e.count}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </section>

            <section>
              <h2 class="font-display text-xl text-tinta">
                Colaboradores <span class="text-sm font-normal text-piedra-suave">· {rangeLabel}</span>
              </h2>
              <p class="mt-1 text-sm text-piedra-suave">
                Lo que alimenta el registro de colaboraciones (Excel): visitas a la ficha de cada
                negocio y clics que le enviamos a su web desde la ficha, el mapa de copas y el
                planificador. A primeros de mes, copia estos números a las columnas
                «Visitas/mes» y «Clics enviados/mes». El negocio puede verificarlo en su propia
                analítica: llegamos como <code>calmasociety / referral</code>.
              </p>
              {!eventDataOk && totalSalidas > 0 && (
                <p class="mt-3 rounded-md bg-terracota/10 p-3 text-sm text-terracota">
                  Umami no devuelve el detalle por negocio (API de event-data): hay {totalSalidas}
                  clics salientes registrados en total, visibles por evento en «Clics en enlaces».
                </p>
              )}
              <div class="mt-4 overflow-x-auto">
                <table class="w-full min-w-[28rem] text-sm">
                  <thead>
                    <tr class="border-b border-niebla text-left text-xs uppercase tracking-wide text-piedra-suave">
                      <th scope="col" class="py-2 pr-4 font-medium">Negocio</th>
                      <th scope="col" class="py-2 pr-4 text-right font-medium">Visitas a la ficha</th>
                      <th scope="col" class="py-2 text-right font-medium">Clics a su web</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-niebla">
                    {colabRows.map((r) => (
                      <tr>
                        <td class="py-2 pr-4 text-piedra">{r.nombre}</td>
                        <td class={`py-2 pr-4 text-right ${r.visitas > 0 ? "font-semibold text-tinta" : "font-semibold text-niebla"}`}>{r.visitas}</td>
                        <td class={`py-2 text-right ${r.clics > 0 ? "font-semibold text-tinta" : "font-semibold text-niebla"}`}>{r.clics}</td>
                      </tr>
                    ))}
                    {colabRows.length === 0 && (
                      <tr>
                        <td colspan="3" class="py-2 text-sm text-piedra-suave">Sin datos todavía.</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </section>

            <section>
              <h2 class="font-display text-xl text-tinta">Páginas más vistas</h2>
              <ul class="mt-4 divide-y divide-niebla">
                {topPages.map((p) => (
                  <li class="flex items-center justify-between gap-4 py-2 text-sm">
                    <span class="truncate text-piedra">{p.x || "—"}</span>
                    <span class="shrink-0 font-semibold text-tinta">{p.y}</span>
                  </li>
                ))}
                {topPages.length === 0 && (
                  <li class="py-2 text-sm text-piedra-suave">Sin datos todavía.</li>
                )}
              </ul>
            </section>

            <section>
              <h2 class="font-display text-xl text-tinta">Clics en enlaces (eventos)</h2>
              <p class="mt-1 text-sm text-piedra-suave">
                Incluye los CTAs de Menorca Bus (<code>cta-menorcabus</code>,
                <code>footer-menorcabus</code>, <code>home-…</code>).
              </p>
              <ul class="mt-4 divide-y divide-niebla">
                {events.map((e) => (
                  <li class="flex items-center justify-between gap-4 py-2 text-sm">
                    <span class="truncate text-piedra">{e.x || "—"}</span>
                    <span class="shrink-0 font-semibold text-tinta">{e.y}</span>
                  </li>
                ))}
                {events.length === 0 && (
                  <li class="py-2 text-sm text-piedra-suave">Sin clics registrados todavía.</li>
                )}
              </ul>
            </section>

            <p class="text-xs text-piedra-suave">
              Datos de Umami · {rangeLabel}. Para el detalle completo (mapas, fuentes, tiempo real)
              tienes también el panel de tu cuenta de Umami.
            </p>
          </div>
        )
      }
    </main>
  </body>
</html>
